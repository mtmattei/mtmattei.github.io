---
import Bare from '../layouts/Bare.astro';
import Logo from '../components/Logo.astro';
import Plate from '../components/Plate.astro';

/* A layout test, not a shipping page: the featured index moved out of the
   billboard band and up the left edge, running top to bottom so it keeps
   working as the list grows. The preview overlaps it — either above the
   rows or behind them — which is the question this page exists to answer.
   Rows and art are the real ones: the four billboard projects, the three
   hidden worlds, and the two registry entries that have plates but no world. */

/* the lab stills, drawn with each lab's own formula (lifted from the landing) */
const B_BASE = 0x2800;
const B_DOTS = [0x01, 0x02, 0x04, 0x40, 0x08, 0x10, 0x20, 0x80];
const B_ORDER = [0, 1, 2, 6, 3, 4, 5, 7];
function bChar(fill: number): string {
  if (fill <= 0) return String.fromCharCode(B_BASE);
  const on = Math.round(fill * 8);
  let code = 0;
  for (let i = 0; i < on && i < 8; i++) code |= B_DOTS[B_ORDER[i]];
  return String.fromCharCode(B_BASE + code);
}
function brailleFrame(cols: number, rows: number, phase: number, amp: number): string {
  const cx = cols / 2, cy = rows / 2;
  let out = '';
  for (let y = 0; y < rows; y++) {
    for (let x = 0; x < cols; x++) {
      const dist = Math.hypot(x - cx, y - cy);
      const wave = Math.sin(dist * 0.25 - phase * 2) * 0.5 + 0.5;
      const wave2 = Math.sin(x * 0.12 + y * 0.08 + phase * 1.3) * 0.5 + 0.5;
      out += bChar(wave * wave2 * amp);
    }
    if (y < rows - 1) out += '\n';
  }
  return out;
}
const GG_SYMBOLS = ['<', '/', '>', '<', '/', '>', '{', '}', ';', '='];
function glyphFrame(cols: number, rows: number): string {
  let out = '';
  for (let y = 0; y < rows; y++) {
    for (let x = 0; x < cols; x++) {
      const seed = Math.sin(x * 127.1 + y * 311.7) * 43758.5453;
      out += GG_SYMBOLS[Math.floor((seed - Math.floor(seed)) * GG_SYMBOLS.length)] + ' ';
    }
    if (y < rows - 1) out += '\n';
  }
  return out;
}

type Row = {
  name: string; tag: string; meta: string;
  /* listed-only rows have no destination and no art yet: they sit in the
     index, unlinked, until each one gets a world */
  href?: string;
  /* whether the art behind the type is dark or light: the overlaid rows
     lighten on dark art and darken on light art, or they vanish */
  tone?: 'dark' | 'light';
  /* art: a Plate slug, or one of the two labs that draw themselves */
  plate?: string; lab?: 'braille' | 'glyph';
};

const ROWS: Row[] = [
  { name: 'POOLSIDE', tag: 'UI · SKIASHARP · UNO PLATFORM', meta: '4 STAGES · ONE PASS', tone: 'dark', href: '/#/p/poolside', plate: 'poolside' },
  { name: 'XAML / UNO', tag: 'SKILLS · THE FEEL SYSTEM', meta: '3 SKILLS · ONE SHEET', tone: 'dark', href: '/#/p/xaml-uno', plate: 'xaml-uno' },
  { name: 'BRAILLE TRANSITION', tag: 'LAB · UNICODE U+2800', meta: '5 MODES · 256 GLYPHS', tone: 'light', href: '/#/p/braille-transition', lab: 'braille' },
  { name: 'GLYPH GRID', tag: 'LAB · MAGNETIC FIELD', meta: 'FIELD 170 · ORBIT 42', tone: 'dark', href: '/#/p/glyph-grid', lab: 'glyph' },
  { name: 'SOURCE / FIGURE', tag: 'DESIGN · STUDY · SELF-REFERENTIAL NOTATION', meta: '7 STUDIES · TWO INKS', tone: 'dark', href: '/source-figure/', plate: 'source-figure' },
];

/* the rest of the index: every public, non-fork repo, listed only.
   Descriptions are GitHub's own, verbatim - 30 of the 42 have none yet. */
const LISTED: Row[] = [
  { name: "MTMATTEI.GITHUB.IO", tag: "Personal portfolio — instrument system, Astro", meta: "2026 · Astro" },
  { name: "APPMAP", tag: "Render an Uno Platform app's full navigation structure as an interactive canvas", meta: "2026 · C#" },
  { name: "UNOCOMPOSER", tag: "", meta: "2026 · C#" },
  { name: "LIQUIDGLASSLAB", tag: "", meta: "2026 · C#" },
  { name: "DESIGN-LEDGER", tag: "A non-repetition layer for AI design generators: wrap any design skill in a persistent fingerprint ledger + collision gate so every result is provably unique across all prior generations.", meta: "2026" },
  { name: "UNO-BUILDS-NET10", tag: "Uno-Builds projects upgraded to Uno.Sdk 6.5.33 / .NET 10 — see UPGRADE-SPEC.md", meta: "2026 · C#" },
  { name: "UNO-SAMPLE-GALLERY", tag: "", meta: "2026 · HTML" },
  { name: "BUILD-2026-SELECTION", tag: "Internal selection catalog of Uno Platform apps under review for Microsoft Build 2026", meta: "2026 · HTML" },
  { name: "UNO-BUILDS", tag: "", meta: "2026 · C#" },
  { name: "WPF-MIGRATION-TEST", tag: "", meta: "2026 · C#" },
  { name: "MERIDIAN", tag: "", meta: "2026 · C#" },
  { name: "COMPOSITIONSTACK", tag: "Companion to the blog post [Composition Stack for AI-Assisted .NET Development. A starter set of the six .md files the post describes, written for a fictional field-service app called FieldKit", meta: "2026" },
  { name: "UNOPLATFORMSKILLS", tag: "Skills for Uno Platform development and WinUI 3 XAML best practices.", meta: "2026" },
  { name: "DIGITALFIDGET", tag: "", meta: "2026 · C#" },
  { name: "QUOTECRAFT", tag: "", meta: "2026 · C#" },
  { name: "SWEATHER", tag: "", meta: "2026 · C#" },
  { name: "LIQUIDMORPH", tag: "", meta: "2026 · C#" },
  { name: "NEXUS", tag: "", meta: "2026 · C#" },
  { name: "FRIENDSONAR", tag: "", meta: "2026 · C#" },
  { name: "UNOORBIT", tag: "", meta: "2026 · C#" },
  { name: "DRIFTLINE", tag: "", meta: "2026 · C#" },
  { name: "CONFPASS", tag: "A cross-platform neumorphic conference attendee badge built with Uno Platform", meta: "2026 · C#" },
  { name: "CAROUSEL", tag: "", meta: "2026 · C#" },
  { name: "MEMORY-DRIFT", tag: "", meta: "2026 · C#" },
  { name: "RADIAL-ACTION-MENU", tag: "", meta: "2026 · C#" },
  { name: "PARALLAX-INVITATION-CARDS", tag: "", meta: "2026 · C#" },
  { name: "FIBONACCISPHERE", tag: "", meta: "2025 · C#" },
  { name: "MATRIX", tag: "", meta: "2025 · C#" },
];

const ALL: Row[] = [...ROWS, ...LISTED];
---
<Bare title="Index lab">
  <div class="lab" id="lab" data-mode="above" data-tone="dark">

    <a class="home" href="/" aria-label="Back to the index"><Logo height={22} /></a>

    <div class="head">
      <span class="kick quiet">HOVER TO PREVIEW<br>CLICK TO OPEN</span>
    </div>

    <!-- the hero is the landing's billboard: the TV on its shelf, its
         proportions, radii and shadow stack lifted from index.astro and
         scaled off --hw so the object stays the same object -->
    <div class="stage" aria-hidden="true">
      <img class="shelf" src="/landing/shelf.png" alt="" />
      <div class="tv">
        <div class="screen" id="tvscreen">
          {ROWS.map((r, i) => (
            <div class:list={['shot', { on: i === 0 }]} data-shot={i}>
              {r.lab === 'braille' ? (
                <span class="lab-art braille"><pre>{brailleFrame(58, 19, 2.0, 0.9)}</pre></span>
              ) : r.lab === 'glyph' ? (
                <span class="lab-art glyph"><pre>{glyphFrame(30, 11)}</pre></span>
              ) : (
                <Plate slug={r.plate!} />
              )}
              <span class="shot-foot"><span>{r.name}</span><span>{String(i + 1).padStart(3, '0')}</span></span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="idxwrap">
      <div class="idx" id="idx">
        <div class="row hdr" aria-hidden="true">
          <span class="no">N.</span><span class="nm">P.</span><span class="tg">T.</span><span class="mt">M.</span>
        </div>
        {ALL.map((r, i) => (
          r.href ? (
            <a
              class:list={['row', { on: i === 0 }]}
              href={r.href} data-i={i} data-tone={r.tone}
              target={r.href.startsWith('http') ? '_blank' : null}
              rel={r.href.startsWith('http') ? 'noopener' : null}
            >
              <span class="no">{String(i + 1).padStart(3, '0')}</span>
              <span class="nm">{r.name}</span>
              <span class="tg">{r.tag}</span>
              <span class="mt">{r.meta}</span>
            </a>
          ) : (
            <span class="row listed">
              <span class="no">{String(i + 1).padStart(3, '0')}</span>
              <span class="nm">{r.name}</span>
              <span class="tg">{r.tag}</span>
              <span class="mt">{r.meta}</span>
            </span>
          )
        ))}
      </div>

      {/* the same rows again, in light grey, drawn over the hero and clipped
          to its rect — so the type lightens exactly where it crosses the art
          and stays ink everywhere else. The hero itself keeps full opacity. */}
      <div class="idx ghost" id="ghost" aria-hidden="true">
        <div class="row hdr">
          <span class="no">N.</span><span class="nm">P.</span><span class="tg">T.</span><span class="mt">M.</span>
        </div>
        {ALL.map((r, i) => (
          <span class:list={['row', { on: i === 0, listed: !r.href }]}>
            <span class="no">{String(i + 1).padStart(3, '0')}</span>
            <span class="nm">{r.name}</span>
            <span class="tg">{r.tag}</span>
            <span class="mt">{r.meta}</span>
          </span>
        ))}
      </div>
    </div>

    <div class="foot">
      <span>MATT MATTEI © 2026</span>
      <div class="modes" role="group" aria-label="Preview depth">
        <button type="button" class="mode on" data-mode="above">PREVIEW ABOVE</button>
        <button type="button" class="mode" data-mode="behind">PREVIEW BEHIND</button>
      </div>
      <span class="quiet">LAYOUT TEST · /index-lab/</span>
    </div>
  </div>
</Bare>

<style>
  html, body { overflow: hidden; }
  .lab {
    --hw: min(54vw, 760px);          /* the billboard's outer width */
    position: fixed; inset: 0;
    padding: 34px 44px 30px;
    display: flex; flex-direction: column;
    background:
      linear-gradient(rgba(26,24,21,.016) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26,24,21,.016) 1px, transparent 1px),
      var(--paper);
    background-size: 34px 34px;
    color: var(--ink);
  }

  .home { position: absolute; left: 44px; top: 30px; color: var(--ink); }
  .home:hover { opacity: .65; }

  /* ---- mode switch: the one question this page asks ---- */
  .modes { display: flex; gap: 6px; z-index: 6; }
  .mode {
    font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 1.6px;
    padding: 5px 11px; border: 1px solid var(--line-2); border-radius: 999px;
    background: transparent; color: var(--ink); opacity: .45; cursor: pointer;
    transition: opacity .18s ease-out, border-color .18s ease-out;
  }
  .mode:hover { opacity: .8; }
  .mode.on { opacity: 1; border-color: var(--accent); color: var(--accent); }

  .head {
    display: flex; justify-content: flex-end; align-items: flex-start;
    padding: 0 0 26px 96px; flex: none;
  }
  .kick {
    font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 1.8px;
    line-height: 16px; color: var(--ink);
  }
  .quiet { opacity: .45; }

  /* ---- the index: top to bottom, the rows share the height ---- */
  .idxwrap { position: relative; flex: 1 1 auto; min-height: 0; }
  .idx {
    position: relative; z-index: 3;
    height: 100%;
    display: flex; flex-direction: column; align-content: flex-start;
    overflow-y: auto;
  }
  /* the light-grey copy: same box, above the hero, clipped to it by script */
  .ghost {
    position: absolute; inset: 0; z-index: 5;
    pointer-events: none; overflow: hidden;
    display: none;
  }
  .ghost .row { opacity: 1; background: none; border-top-color: transparent; box-shadow: none; color: #CFCBC4; }
  .lab[data-tone="light"] .ghost .row { color: #74706A; }
  .row {
    position: relative;
    display: grid; align-items: center;
    grid-template-columns: 58px 300px 300px 160px;
    gap: 16px;
    flex: none; height: 22px;
    padding: 0 0 0 4px;
    font-size: 13px; line-height: 1;
    color: var(--ink); text-decoration: none; opacity: 1;
    border-top: 1px solid transparent;
    transition-property: background-color, border-color;
    transition-duration: .15s, .15s;
    transition-timing-function: cubic-bezier(.22,1,.36,1);
  }
  /* the hovered row is a full-bleed band with an accent rule on top */
  .row:hover, .row:focus-visible, .row.on {
    outline: none;
    background: rgba(255,255,255,.62);
    border-top-color: var(--accent);
    box-shadow: 0 1px 0 rgba(26,24,21,.14);
  }
  .row:hover .nm, .row.on .nm { font-weight: 700; }
  /* listed-only: in the index, but nothing to open yet */
  .row.listed { cursor: default; }
  .row.listed .nm { font-weight: 400; }
  .row.listed .nm::after { content: none; }
  .row.listed .tg:empty::before { content: '—'; opacity: .35; }
  .hdr {
    opacity: .5; font-size: 11px; letter-spacing: .12em;
    border-top: 0; background: none; pointer-events: none; margin-bottom: 4px;
  }
  .no { opacity: 1; }
  .nm { font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tg, .mt { opacity: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .mt { text-align: left; }

  /* ---- the preview, overlapping the rows ---- */
  .stage {
    position: absolute; left: 50%; top: 50%;
    /* centre the whole object, not just the TV: the shelf hangs 0.636*hw
       below the TV top while the TV is 0.479*hw tall, so lift by half the
       difference to put the billboard's own centre on the screen's */
    transform: translate(-50%, calc(-50% - var(--hw) * 0.079));
    width: var(--hw); aspect-ratio: 944 / 452;
    pointer-events: none;
  }
  /* shelf geometry, in the landing's own proportions:
     1055/944 wide, offset -57/944, top 445/452 down the TV */
  .shelf {
    position: absolute; z-index: 0;
    left: calc(var(--hw) * -0.0604);
    top: calc(var(--hw) * 0.4714);
    width: calc(var(--hw) * 1.1176);
    height: auto; display: block;
  }
  .tv {
    position: absolute; inset: 0; z-index: 1;
    border-radius: calc(var(--hw) * 0.0583);
    padding: calc(var(--hw) * 0.0053);
    background: linear-gradient(180deg, #E7E1DB 0%, #EEE9E4 55%, #F3F0EB 100%);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,.55),
      0 0 0 1px rgba(70,62,54,.10),
      0 14px 22px -10px rgba(70,58,46,.26),
      30px 22px 44px -16px rgba(88,76,64,.42),
      0 34px 54px -26px rgba(70,58,46,.20);
  }
  .tv .screen {
    position: relative; width: 100%; height: 100%;
    border-radius: calc(var(--hw) * 0.053);
    overflow: hidden; background: var(--ink);
    box-shadow: inset 0 0 0 1px rgba(10,9,8,.92);
  }
  .shot {
    position: absolute; inset: 0; overflow: hidden;
    background: var(--ink);
    opacity: 0; transform: scale(1.02);
    transition: opacity .32s cubic-bezier(.22,1,.36,1), transform .32s cubic-bezier(.22,1,.36,1);
  }
  .shot.on { opacity: 1; transform: none; }
  .shot :global(.plate) { width: 100%; height: 100%; object-fit: cover; }
  .shot-foot {
    position: absolute; left: 14px; right: 14px; bottom: 12px; z-index: 2;
    display: flex; justify-content: space-between; gap: 16px;
    font-family: var(--mono); font-size: 9px; font-weight: 600; letter-spacing: 1.4px;
    color: #fff; mix-blend-mode: difference;
  }
  .lab-art { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .lab-art pre { margin: 0; white-space: pre; }
  .lab-art.braille { background: linear-gradient(180deg, #F6F2EE 0%, #F0EAE3 100%); }
  .lab-art.braille pre {
    font-family: 'JetBrains Mono', var(--mono), monospace; font-size: 12px;
    line-height: 1.4; letter-spacing: .05em;
    color: #3656D4; text-shadow: 0 0 8px rgba(54,86,212,.22);
  }
  .lab-art.glyph { background: #101013; }
  .lab-art.glyph pre {
    font-family: var(--mono), monospace; font-size: 13px;
    line-height: 2.1; letter-spacing: .38em; color: #3A3A42;
  }

  /* ABOVE: the preview covers the rows it overlaps (the reference's behaviour) */
  .lab[data-mode="above"] .stage { z-index: 4; }
  /* BEHIND: the hero sits over the rows at full strength and the ghost copy
     re-draws the covered type in light grey on top of it. Difference blending
     was the first attempt and failed - paper on paper resolves to nothing. */
  .lab[data-mode="behind"] .stage { z-index: 4; }
  .lab[data-mode="behind"] .ghost { display: flex; }

  .foot {
    flex: none; display: flex; justify-content: space-between; align-items: center;
    padding-top: 12px; margin-top: 14px; border-top: 1px solid var(--line);
    font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 1.6px;
    opacity: .5;
  }

  @media (prefers-reduced-motion: reduce) {
    .row, .shot, .mode { transition-duration: .01ms; }
  }
</style>

<script>
  const lab = document.getElementById('lab')!;
  const ghost = document.getElementById('ghost')!;
  const screen = document.getElementById('tvscreen')!;
  const rows = Array.from(document.querySelectorAll<HTMLElement>('#idx a.row'));
  const ghostRows = Array.from(document.querySelectorAll<HTMLElement>('#ghost .row:not(.hdr)'));
  const shots = Array.from(document.querySelectorAll<HTMLElement>('.shot'));

  /* the ghost mirrors every row while only the linked rows have art, so `i`
     is always the position in the FULL list and each linked row carries its
     own index in data-i. Keying off array position instead would only line up
     while the linked rows happen to sit first. */
  function show(i: number) {
    const row = rows.find((r) => +r.dataset.i! === i);
    if (row) lab.dataset.tone = row.dataset.tone!;
    rows.forEach((r) => r.classList.toggle('on', +r.dataset.i! === i));
    ghostRows.forEach((r, n) => r.classList.toggle('on', n === i));
    shots.forEach((s, n) => s.classList.toggle('on', n === i));
  }

  rows.forEach((row) => {
    const preview = () => show(+row.dataset.i!);
    row.addEventListener('pointerenter', preview);
    row.addEventListener('focus', preview);
  });

  /* the ghost is only visible where the hero is: clip it to the hero's rect,
     measured rather than guessed so it survives any resize */
  function clipGhost() {
    const g = ghost.getBoundingClientRect();
    const s = screen.getBoundingClientRect();
    const top = Math.max(0, s.top - g.top);
    const left = Math.max(0, s.left - g.left);
    const right = Math.max(0, g.right - s.right);
    const bottom = Math.max(0, g.bottom - s.bottom);
    ghost.style.clipPath = `inset(${top}px ${right}px ${bottom}px ${left}px)`;
  }
  clipGhost();
  addEventListener('resize', clipGhost);

  document.querySelectorAll<HTMLButtonElement>('.mode').forEach((btn) => {
    btn.addEventListener('click', () => {
      lab.dataset.mode = btn.dataset.mode!;
      document.querySelectorAll('.mode').forEach((b) => b.classList.toggle('on', b === btn));
      clipGhost();
    });
  });
</script>
