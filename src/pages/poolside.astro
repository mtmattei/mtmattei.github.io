---
import '@fontsource/fraunces/300.css';
import '@fontsource/fraunces/400.css';
import '@fontsource/fraunces/400-italic.css';
import '@fontsource/instrument-sans/400.css';
import '@fontsource/instrument-sans/500.css';
import '@fontsource/instrument-sans/600.css';
import '../styles/poolside.css';
import Shell from '../layouts/Shell.astro';
import { highlightSource } from '../data/portfolio';

const tokens: [string, string][] = [
  ['medium', 'DOM + WebGL'],
  ['stack', 'Uno Platform'],
  ['breakdown', '4 key parts'],
  ['origin', 'SkSL · SkiaSharp 4'],
  ['faces', 'Fraunces · Instr.'],
  ['status', 'in build'],
];

const DISPERSION_SRC = `// The warp is linear in its scale, so one evaluation
// gives all three dispersion channels: s(k) = suv + k*disp.
float2 sg = waterUv(suv, 1.00);
float2 disp = sg - suv;
float2 sr = sg + disp * 0.06;
float2 sb = sg - disp * 0.06;
float3 col = float3(
    tileColor(float2(sr.x, 1.0 - sr.y)).r,
    tileColor(float2(sg.x, 1.0 - sg.y)).g,
    tileColor(float2(sb.x, 1.0 - sb.y)).b);`;

const CAUSTIC_SRC = `// Caustic web: warped-sine interference. Organic because the
// domain is rotated off-grid, warped by slow value noise, and a
// third rotated layer breaks the symmetry.
float caustic(float2 suv) {
  float t = iTime * 0.6;
  float2 p = rot(suv, 0.47) * 9.0;
  p += 2.8 * float2(
      vnoise(p * 0.35 + t * 0.25) - 0.5,
      vnoise(p * 0.35 + 7.3 - t * 0.21) - 0.5);
  float a = sin(p.x + sin(p.y + t * 1.3) * 1.6 + t);
  float b = sin(p.y + sin(p.x - t * 1.1) * 1.7 - t * 0.8);
  float2 q = rot(p, 1.9) * 0.57;
  float c = sin(q.x + sin(q.y * 1.3 - t * 0.7) * 1.8 + t * 0.5);
  float web = pow(clamp(1.0 - abs(a + b + 0.8 * c) * 0.5, 0.0, 1.0), 6.0);
  web *= 0.55 + 0.9 * vnoise(p * 0.8 + t * 0.15);
  return web;
}`;
---
<Shell title="Poolside" crumb="poolside" tokens={tokens} wide
  description="Poolside — pool chemistry read like weather. A living exhibit: explode the real interface into its key features, back to the SkiaSharp shader it grew from.">

  <div class="page-head">
    <span class="kicker">Code · exhibit · Uno Platform</span>
    <h1 class="title">Poolside</h1>
    <p class="lede">
      A premium companion for pool chemistry — water reported like weather. This is not a
      screenshot: the phone is the interface itself, running. Explode it and the key features
      lift out of the shell, still live, tethered to where they belong.
    </p>
  </div>

  <div class="sheet-note" aria-hidden="true">
    <span class="kicker">fig.02 · component breakdown · the shell keeps running · dashed voids mark where each part lives</span>
  </div>

  <div class="hero-sheet">
    <!-- key points -->
    <div class="hero-side keypoints">
      <div>
        <div class="rail-head">Key features</div>
        <ul>
          <li><b>The water is a shader.</b> Clarity, tint, and murk are uniforms fed by the chemistry.</li>
          <li><b>One etched plate,</b> four chemistries. Color only ever means a verdict.</li>
          <li><b>One typed sentence.</b> The app speaks once, then stops.</li>
          <li><b>The not-yet is dashed.</b> Projection never borrows the ink of history.</li>
        </ul>
      </div>
    </div>

    <!-- the framed exhibit -->
