                  <div class="p-status"><span id="pClock">21:41</span><span class="p-batt"><i></i></span></div>
                  <div class="p-header"><div class="glyph"></div><h2>Poolside</h2><span class="sub">Backyard · 34 000 L</span></div>

                  <div class="p-sec" data-comp="swatch">
                    <div class="swatch-stage">
                      <div class="basin flat pocket" id="basin">
                        <div class="b-wall n"></div><div class="b-wall s"></div><div class="b-wall w"></div><div class="b-wall e"></div>
                        <div class="b-floor"></div>
