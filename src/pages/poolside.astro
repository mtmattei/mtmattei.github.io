                        <div class="gtrack"><div class="gband" id="b2"></div><div class="gmark" id="m2"></div></div><div class="gnote">80–120 ppm</div></div>
                      <div class="gauge"><div class="glabel">Stabilizer</div><div class="grow"><span class="gval" id="v3">40</span><span class="gdot" id="d3"></span></div>
