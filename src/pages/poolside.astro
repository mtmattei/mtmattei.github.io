                      <div class="gauge"><div class="glabel">Chlorine</div><div class="grow"><span class="gval" id="v1">2.4</span><span class="gdot" id="d1"></span></div>
                        <div class="gtrack"><div class="gband" id="b1"></div><div class="gmark" id="m1"></div></div><div class="gnote">1–3 ppm</div></div>
