                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="p-sec" data-comp="plate">
                    <div class="plate mini" id="plate">
                      <div class="gauge"><div class="glabel">pH</div><div class="grow"><span class="gval" id="v0">7.4</span><span class="gdot" id="d0"></span></div>
