/* ---- detail world: inside the billboard ---- */
#detail {
  position: fixed; inset: 0; z-index: 10; overflow: hidden;
  display: none; opacity: 0;
  background: #060809;
  cursor: grab;
  transform: scale(.92);
  transition-property: opacity, transform;
  transition-duration: .4s;
  transition-timing-function: cubic-bezier(.17,1,.32,1);
}
#detail.on { display: block; }
#detail.in { opacity: 1; transform: scale(1); }
#detail:not(.in) { transition-duration: .25s; }
#detail.grabbing { cursor: grabbing; }

/* landing chrome fades while the camera pushes through the billboard */
.scene > * { transition-property: opacity; transition-duration: .2s; transition-timing-function: ease-out; }
/* Entering a world, everything but the billboard and its shelf used to snap
   to invisible in one frame while the push took 850ms - the one hard cut in
   an otherwise continuous move. Now the surroundings recede: a short fade and
   a 6px settle, ~30% of the push so the billboard is clearly what is left. */
.scene > :not(.tv):not(.shelf) {
  transition: opacity .26s cubic-bezier(.22,1,.36,1), transform .34s cubic-bezier(.22,1,.36,1);
}
.scene.pushing > :not(.tv):not(.shelf) { opacity: 0; transform: translateY(6px); }
.scene.pushing > * { pointer-events: none; }

