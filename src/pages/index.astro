.dstack-gauge input[type=range]::-webkit-slider-runnable-track { height: 1px; background: var(--line-2); }
.dstack-gauge input[type=range]::-moz-range-track { height: 1px; background: var(--line-2); }
.dstack-gauge input[type=range]::-webkit-slider-thumb {
  -webkit-appearance: none; width: 10px; height: 18px; margin-top: -9px; border-radius: 1px;
  background: var(--paper); border: 1px solid var(--ink); box-shadow: inset 3px 0 0 -2px var(--accent);
}
.dstack-gauge input[type=range]::-moz-range-thumb { width: 9px; height: 16px; border-radius: 1px; background: var(--paper); border: 1px solid var(--ink); }
