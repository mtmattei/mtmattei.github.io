---
import Shell from '../layouts/Shell.astro';

const tokens: [string, string][] = [
  ['concept', 'source → figure'],
  ['hero.src', 'hero.toString()'],
  ['points', '≤1500'],
  ['accent.use', 'state · future'],
];
---
<Shell title="Index" crumb="index" tokens={tokens}
  description="Matt Mattei's public notebook: ideas, experiments, sketches, software, and lessons at the intersection of design and development.">
  <section class="hero">
    <h1 class="hero-display">A public Notebook</h1>
    <p class="hero-sub">Ideas, experiments, sketches, samples, and lessons learned along the way. Some take shape. Some simply remain ideas.</p>

    <figure class="hero-plate">
      <div class="hero-frame">
        <canvas id="herocv" role="button" tabindex="0" aria-label="the name MATT MATTEI drawn from the characters of its own source; drag to reveal the source, press Enter to replay"></canvas>
        <span class="reg tl"></span><span class="reg tr"></span><span class="reg bl"></span><span class="reg br"></span>
      </div>
      <figcaption class="hero-plaque">
        <span class="mono">Plate 00</span>
        <span>hero() · the name, drawn by its own source</span>
        <span class="mono hero-hint">drag to read the source</span>
      </figcaption>
    </figure>

    <div class="hero-body">
      <p>I'm exploring the intersection of design and development, mostly because I love making things.</p>
      <a class="hero-scroll" href="#index">Explore the notebook <span aria-hidden="true">↓</span></a>
    </div>
  </section>

  <hr class="rule" />

  <span class="kicker" id="index" style="display:block;margin-bottom:var(--s3)">Index</span>
  <div class="grid">
    <a class="card" href="/poolside/"><span class="kicker">Code · exhibit<span class="no">no.01</span></span><h3>Poolside</h3><p>Water, read like weather. The real interface, exploded, back to the SkiaSharp shader it grew from.</p></a>
    <a class="card" href="/texts/"><span class="kicker">Writing<span class="no">no.02</span></span><h3>Texts</h3><p>Essays in galley: real excerpts at reading measure.</p></a>
    <a class="card" href="/xaml-uno/"><span class="kicker">Skills<span class="no">no.03</span></span><h3>XAML / Uno</h3><p>The feel system. Tuned numbers, not adjectives.</p></a>
    <a class="card" href="/ledger/"><span class="kicker">Skills · oss<span class="no">no.04</span></span><h3>Ledger</h3><p>A public, append-only record of design DNA.</p></a>
    <a class="card" href="/program/"><span class="kicker">Return<span class="no">no.05</span></span><h3>Program</h3><p>The portfolio as it runs. The source is the sitemap.</p></a>
  </div>

  <hr class="rule" />
  <p class="mono">Toggle GRID to see the baseline and column. Toggle INSPECT to read the tokens of the active view.</p>
</Shell>

<style>
  .hero { text-align: center; max-width: 760px; margin: 0 auto; padding: clamp(20px, 6vw, 80px) 0 var(--s8); }
  .hero > * { animation: heroRise .7s cubic-bezier(.22, .61, .21, 1) both; }
  .hero-eyebrow {
    font-family: var(--mono); font-size: 12px; letter-spacing: .18em; text-transform: uppercase;
    color: var(--muted); margin: 0 0 var(--s6); animation-delay: .04s;
  }
  .hero-display {
    font-family: var(--sans); font-weight: 500;
    font-size: clamp(27px, 3.8vw, 44px); line-height: 1.1; letter-spacing: -0.02em;
    color: var(--ink); margin: 0 0 var(--s4); text-wrap: balance; animation-delay: .12s;
  }
  .hero-sub {
    font-size: clamp(16px, 2vw, 19px); line-height: 1.5; color: var(--muted);
    max-width: 46ch; margin: 0 auto clamp(30px, 5vw, 52px); text-wrap: balance; animation-delay: .2s;
  }
  .hero-plate { margin: 0 0 clamp(26px, 5vw, 44px); animation-delay: .3s; }
  .hero-frame {
    position: relative;
    border: 1px solid rgba(26, 24, 21, 0.55); border-radius: var(--radius);
    background: #201C17;
    padding: clamp(24px, 4vw, 48px); max-width: 620px; margin: 0 auto;
  }
  /* faint inner keyline — the passe-partout */
  .hero-frame::after {
    content: ""; position: absolute; inset: 9px; pointer-events: none;
    border: 1px solid rgba(239, 234, 226, 0.12); border-radius: 2px;
  }
  .hero-frame canvas { display: block; margin: 0 auto; max-width: 100%; cursor: ew-resize; touch-action: pan-y; }
  /* corner registration marks */
  .hero-frame .reg { position: absolute; width: 11px; height: 11px; opacity: .5; pointer-events: none; }
  .hero-frame .reg::before, .hero-frame .reg::after { content: ""; position: absolute; background: rgba(239, 234, 226, .55); }
  .hero-frame .reg::before { left: 50%; top: 0; width: 1px; height: 100%; transform: translateX(-50%); }
  .hero-frame .reg::after { top: 50%; left: 0; height: 1px; width: 100%; transform: translateY(-50%); }
  .hero-frame .reg.tl { top: 12px; left: 12px; } .hero-frame .reg.tr { top: 12px; right: 12px; }
  .hero-frame .reg.bl { bottom: 12px; left: 12px; } .hero-frame .reg.br { bottom: 12px; right: 12px; }
  .hero-plaque {
    display: flex; justify-content: center; align-items: baseline; gap: var(--s3); flex-wrap: wrap;
    margin-top: var(--s4); font-family: var(--mono); font-size: 11px; letter-spacing: .06em; color: var(--muted);
  }
  .hero-hint { opacity: .7; }
  .hero-body { max-width: 56ch; margin: 0 auto; animation-delay: .42s; }
  .hero-body p { font-size: 16px; line-height: 1.6; color: var(--muted); margin: 0 0 var(--s6); text-wrap: pretty; }
  .hero-scroll {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: 13px; letter-spacing: .04em; color: var(--ink);
    text-decoration: none; border-bottom: var(--bw) solid var(--line-2); padding-bottom: 3px;
    transition: border-color .15s, gap .15s;
  }
  .hero-scroll:hover { border-color: var(--accent); gap: 12px; }
  @keyframes heroRise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { .hero > * { animation: none; } }
</style>

<script is:inline>
/* ============================================================
   HERO — the name is its own source (instrument edition).
   This script is inline and unminified on purpose: hero() reads
   its own toString(), so the printed prose IS this source.
   ============================================================ */

function hero(cv, t) {
  const src = hero.toString();
  const marks = glyphs(src);
  const a = prose(src), b = letterform(src);
  const g = cv.getContext('2d');
  g.clearRect(0, 0, cv.width, cv.height);
  for (let i = 0; i < b.length; i++) {
    const k = marks[i % marks.length];
    const pos = glide(a[k], b[i], t, i);
    if (pos.ink && heroReact > 0.001) {   // once settled, the name pushes away from the cursor
      const dx = pos.x - mx, dy = pos.y - my, d = Math.hypot(dx, dy) || 1;
      const push = Math.max(0, 76 - d) / 76 * 16 * heroReact;
      pos.x += (dx / d) * push; pos.y += (dy / d) * push;
    }
    stamp(g, src[k], pos);
  }
}

const INK = '#EFEAE2', ACCENT = '#8AA0EA';
const RM = matchMedia('(prefers-reduced-motion: reduce)').matches;
let CH = 7.2;

const hash01 = i => {
  let x = (i + 1) * 2654435761 % 4294967296;
  x = (x ^ (x >> 13)) * 1274126177 % 4294967296;
  return (x % 10000) / 10000;
};
const smooth = u => u <= 0 ? 0 : u >= 1 ? 1 : u * u * (3 - 2 * u);

let heroCv, prosePos = null, letterPos = null, glyphIdx = null, HW = 0, HH = 0;
let heroT = 0, heroTarget = 1, heroDrag = false, dragX0 = 0, dragT0 = 0, dragMoved = 0, heroRaf = null;
let mx = 0, my = 0, mOver = false, heroReact = 0;

function glyphs(src) {
  if (glyphIdx) return glyphIdx;
  glyphIdx = [];
  for (let i = 0; i < src.length; i++) {
    if (src[i] !== ' ' && src[i] !== '\n') glyphIdx.push(i);
  }
  return glyphIdx;
}
function prose(src) {
  if (prosePos) return prosePos;
  const chC = CH * 10.5 / 12;
  const rows = src.split('\n');
  const maxc = Math.max(...rows.map(r => r.length));
  const ox = Math.max(10, (HW - maxc * chC) / 2), oy = (HH - rows.length * 15) / 2 + 7;
  const out = [];
  let col = 0, row = 0;
  for (let i = 0; i < src.length; i++) {
    if (src[i] === '\n') { out.push(null); row++; col = 0; continue; }
    out.push({ x: ox + col * chC, y: oy + row * 15 });
    col++;
  }
  prosePos = out;
  return out;
}
function letterform(src) {
  if (letterPos) return letterPos;
  const S = Math.min((HW * 0.92) / 3.8, HH * 0.4);
  const off = document.createElement('canvas');
  off.width = HW; off.height = HH;
  const og = off.getContext('2d');
  og.font = '500 ' + S + 'px "JetBrains Mono"';
  og.textAlign = 'center'; og.textBaseline = 'middle';
  og.lineWidth = Math.max(3, S * 0.06);
  og.strokeText('MATT', HW / 2, HH / 2 - S * 0.62);
  og.strokeText('MATTEI', HW / 2, HH / 2 + S * 0.62);
  const data = og.getImageData(0, 0, HW, HH).data;
  let step = 4, pts = [];
  do {
    pts = [];
    for (let y = 2; y < HH; y += step) {
      for (let x = 2; x < HW; x += step) {
        if (data[(y * HW + x) * 4 + 3] > 140) pts.push({ x: x, y: y });
      }
    }
    step += 1;
  } while (pts.length > 1500 && step < 40);
  letterPos = pts;
  return pts;
}
function glide(p, q, t, i) {
  if (!q) return { x: p.x, y: p.y, ink: true };
  const s = hash01(i) * 0.35;
  const u = smooth((t * 1.35 - s) / 1.0);
  const x = p.x + (q.x - p.x) * u;
  const y = p.y + (q.y - p.y) * u - Math.sin(u * Math.PI) * (10 + hash01(i + 7) * 22);
  return { x: x, y: y, ink: u <= 0 || u >= 1, sz: 8.6 - 1.8 * u };
}
function stamp(g, chr, pos) {
  g.fillStyle = pos.ink ? INK : ACCENT;
  const sz = (pos.sz || 8.6).toFixed(1);
  g.font = /[{}()[\]=+\-*/<>;.,:'!&|?]/.test(chr) ? '500 ' + sz + 'px "JetBrains Mono"' : sz + 'px "JetBrains Mono"';
  g.fillText(chr, pos.x, pos.y);
}
function drawHero(t) { hero(heroCv, t); }
function tick() {
  heroRaf = null;
  if (!heroDrag) heroT += (heroTarget - heroT) * 0.045;   // slower, more deliberate settle
  heroReact += ((mOver && !heroDrag ? 1 : 0) - heroReact) * 0.14;
  const atTarget = !heroDrag && Math.abs(heroT - heroTarget) < 0.0012;
  if (atTarget) heroT = heroTarget;
  drawHero(heroT);
  if (heroDrag || !atTarget || heroReact > 0.002 || mOver) heroRaf = requestAnimationFrame(tick);
}
function kick() { if (heroRaf == null) heroRaf = requestAnimationFrame(tick); }
function wireScrub() {
  const rel = (e) => { const r = heroCv.getBoundingClientRect(); mx = e.clientX - r.left; my = e.clientY - r.top; };
  const end = () => {
    if (!heroDrag) return;
    heroDrag = false;
    if (dragMoved < 5) heroT = 0;   // a tap replays the assemble
    heroTarget = 1;
    if (RM) { heroT = 1; drawHero(1); } else kick();
  };
  heroCv.addEventListener('pointerdown', e => {
    heroCv.setPointerCapture(e.pointerId);
    heroDrag = true; dragX0 = e.clientX; dragT0 = heroT; dragMoved = 0;
    if (!RM) kick();
  });
  heroCv.addEventListener('pointermove', e => {
    rel(e);
    if (heroDrag) {
      dragMoved = Math.max(dragMoved, Math.abs(e.clientX - dragX0));
      heroT = Math.max(0, Math.min(1, dragT0 + (e.clientX - dragX0) / HW));
      if (RM) drawHero(heroT);
    } else if (!RM) { mOver = true; kick(); }
  });
  heroCv.addEventListener('pointerenter', () => { mOver = true; if (!RM) kick(); });
  heroCv.addEventListener('pointerleave', () => { mOver = false; if (!RM) kick(); });
  heroCv.addEventListener('pointerup', end);
  heroCv.addEventListener('pointercancel', end);
  heroCv.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); heroT = 0; heroTarget = 1; }
    else if (e.key === 'ArrowLeft') heroTarget = Math.max(0, heroTarget - 0.2);
    else if (e.key === 'ArrowRight') heroTarget = Math.min(1, heroTarget + 0.2);
    else return;
    if (RM) { heroT = heroTarget; drawHero(heroT); } else kick();
  });
}
let heroWired = false;
function buildHero() {
  heroCv = document.getElementById('herocv');
  const holder = heroCv.parentElement; // hero-frame
  HW = Math.min(520, Math.max(280, holder.clientWidth));
  HH = Math.round(HW * 0.52);
  const dpr = Math.min(devicePixelRatio || 1, 2);
  heroCv.width = HW * dpr; heroCv.height = HH * dpr;
  heroCv.style.width = HW + 'px'; heroCv.style.height = HH + 'px';
  const g = heroCv.getContext('2d');
  g.setTransform(dpr, 0, 0, dpr, 0, 0);
  g.textBaseline = 'middle';
  prosePos = null; letterPos = null;
  if (!heroWired) {
    heroWired = true;
    if (RM) { heroT = 1; drawHero(1); }
    else { heroT = 0; drawHero(0); setTimeout(() => { heroTarget = 1; kick(); }, 500); }  // source slowly assembles into the name
    wireScrub();
  } else {
    drawHero(heroT);
    if (!RM) kick();
  }
}

Promise.all([
  document.fonts.load('12px "JetBrains Mono"'),
  document.fonts.load('500 12px "JetBrains Mono"')
]).then(() => document.fonts.ready).then(() => {
  const mc = document.createElement('canvas').getContext('2d');
  mc.font = '12px "JetBrains Mono"';
  CH = mc.measureText('0000000000').width / 10;
  buildHero();

  let rsz = null;
  addEventListener('resize', () => {
    clearTimeout(rsz);
    rsz = setTimeout(() => {
      const t = heroT;
      buildHero();
      heroT = t; drawHero(heroT);
      if (!RM) kick();
    }, 160);
  });
});
</script>
