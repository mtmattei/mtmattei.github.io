<script is:inline define:vars={{ PROJECTS: CLIENT_PROJECTS }}>
// ---- camera: single writer for all scene transforms (fit scale + walk-through push) ----
var cam = document.getElementById('camera');
var camState = {
  fitS: 1,
  push: 0,                       // 0 = landing, 1 = through the billboard
  ZMAX: 2.2,
  FOCUS: { x: 814, y: 387 },     // billboard screen center
  CENTER: { x: 768, y: 512 }     // scene center
};
function applyCamera() {
  var c = camState;
  var k = c.fitS * Math.pow(c.ZMAX, c.push);
  var dx = (c.CENTER.x - c.FOCUS.x) * c.push * k;
  var dy = (c.CENTER.y - c.FOCUS.y) * c.push * k;
  cam.style.transform = 'translate(' + dx + 'px,' + dy + 'px) scale(' + k + ')';
}
function fit() {
  camState.fitS = Math.min(innerWidth / 1536, innerHeight / 1024);
  applyCamera();
}
addEventListener('resize', fit); fit();

// ---- landing state: featured project (index into PROJECTS) ----
var state = { mode: 'landing', featured: 0 };
var tv = document.getElementById('tv');

function setFeatured(i) {
  state.featured = i;
  var p = PROJECTS[i];
  document.querySelectorAll('.pcard').forEach(function (c) {
    c.classList.toggle('selected', c.dataset.slug === p.slug);
  });
  document.querySelectorAll('.tv .art').forEach(function (a) {
    a.classList.toggle('on', a.dataset.art === p.slug);
  });
  tv.setAttribute('aria-label', 'Step into ' + p.name);
  bbWake();
}

// ---- shared WebGL: the Poolside shaders (ported from /poolside/) ----
var GL_VS = 'attribute vec2 p;varying vec2 v_uv;void main(){v_uv=p*0.5+0.5;gl_Position=vec4(p,0.0,1.0);}';
var GL_HELPERS =
  'precision highp float;varying vec2 v_uv;uniform vec2 u_res;uniform float u_time;' +
  'float hash(vec2 p){p=fract(p*vec2(123.34,456.21));p+=dot(p,p+45.32);return fract(p.x*p.y);}' +
  'float vnoise(vec2 p){vec2 i=floor(p),f=fract(p);' +
  'float a=hash(i),b=hash(i+vec2(1,0)),c=hash(i+vec2(0,1)),d=hash(i+vec2(1,1));' +
  'vec2 u=f*f*(3.0-2.0*f);return mix(mix(a,b,u.x),mix(c,d,u.x),u.y);}' +
  'float fbm(vec2 p){float v=0.0,a=0.5;for(int i=0;i<4;i++){v+=a*vnoise(p);p=p*2.02+vec2(1.7,9.2);a*=0.5;}return v;}' +
  'float caustic(vec2 uv,float t){vec2 p=mod(uv*6.28318,6.28318)-250.0;vec2 i=p;float c=1.0,inten=0.0045;' +
  'for(int n=0;n<5;n++){float tt=t*0.5*(1.0-(3.5/float(n+1)));' +
  'i=p+vec2(cos(tt-i.x)+sin(tt+i.y),sin(tt-i.y)+cos(tt+i.x));' +
  'c+=1.0/length(vec2(p.x/(sin(i.x+tt)/inten),p.y/(cos(i.y+tt)/inten)));}' +
  'c/=5.0;c=1.17-pow(c,1.4);return clamp(pow(abs(c),8.0),0.0,1.0);}';
// figures draw in the site's inks: paper #F6F2EE, ink #1A1815
var GL_PAPER = 'vec3(0.965,0.949,0.933)', GL_INK = 'vec3(0.102,0.094,0.082)';
var GL_FRAGS = {
  water: GL_HELPERS +
    'uniform float u_clarity;uniform float u_murk;uniform float u_caustic;uniform vec3 u_murkCol;' +
    'vec3 tileCol(vec2 g){vec2 id=floor(g);vec2 f=fract(g);' +
    'vec2 e=smoothstep(0.0,0.07,f)*smoothstep(1.0,0.93,f);float grout=e.x*e.y;' +
    'float h=hash(id);vec3 tl=mix(vec3(0.15,0.64,0.76),vec3(0.07,0.44,0.57),h);' +
    'return mix(vec3(0.06,0.33,0.43),tl,grout);}' +
    'void main(){vec2 uv=v_uv;float asp=u_res.x/u_res.y;vec2 auv=vec2(uv.x*asp,uv.y);float t=u_time;' +
    'vec2 w=vec2(fbm(auv*3.2+t*0.10),fbm(auv*3.2-t*0.12+5.0));' +
    'vec2 suv=auv+(w-0.5)*0.12;' +
    'vec3 col=tileCol(suv*7.0);' +
    'vec2 cuv=auv*1.5+(w-0.5)*0.10;' +
    'float ca=caustic(cuv,t);float ca2=caustic(cuv*1.8+4.0,t*1.15);ca=max(ca,ca2*0.55);' +
    'float d=distance(uv,vec2(0.5,0.54));float depth=smoothstep(0.05,0.85,d);' +
    'col*=mix(1.08,0.85,depth);' +
    'float cVis=u_caustic*(0.30+u_clarity*0.95)*(1.0-u_murk*0.55);col+=vec3(0.72,0.95,1.0)*ca*cVis;' +
    'float e2=0.006;' +
    'float nx=fbm(auv*3.2+t*0.10)-fbm(auv*3.2+t*0.10+vec2(e2,0.0));' +
    'float ny=fbm(auv*3.2+t*0.10)-fbm(auv*3.2+t*0.10+vec2(0.0,e2));' +
    'vec3 n=normalize(vec3(nx,ny,0.06));' +
    'float spec=pow(max(dot(n,normalize(vec3(0.35,0.55,1.0))),0.0),22.0);col+=spec*0.45*u_clarity;' +
    'float hz=u_murk*(0.30+0.55*depth);col=mix(col,u_murkCol,hz);' +
    'float vig=smoothstep(1.15,0.35,d);col*=0.85+0.15*vig;' +
    'gl_FragColor=vec4(col,1.0);}',
  field: GL_HELPERS +
    'void main(){float asp=u_res.x/u_res.y;vec2 auv=vec2(v_uv.x*asp,v_uv.y);' +
    'float v=fbm(auv*3.2+u_time*0.10);v=smoothstep(0.22,0.78,v);' +
    'gl_FragColor=vec4(mix(' + GL_PAPER + ',' + GL_INK + ',v),1.0);}',
  warp: GL_HELPERS +
    'float grid(vec2 p){vec2 f=abs(fract(p)-0.5);float d=min(f.x,f.y);return 1.0-smoothstep(0.0,0.045,d);}' +
    'void main(){float asp=u_res.x/u_res.y;vec2 auv=vec2(v_uv.x*asp,v_uv.y);float t=u_time;' +
    'vec2 d1=vec2(0.83,0.55),d2=vec2(-0.42,0.91),d3=vec2(0.66,-0.75);' +
    'vec2 w=d1*sin(dot(auv,d1)*11.3+t*1.21)+d2*(0.7*sin(dot(auv,d2)*17.7-t*1.63))+d3*(0.5*sin(dot(auv,d3)*26.9+t*0.87));' +
    'vec3 col=' + GL_PAPER + ';' +
    'col=mix(col,vec3(0.79,0.80,0.82),grid(auv*6.0));' +
    'col=mix(col,' + GL_INK + ',grid((auv+w*0.03)*6.0));' +
    'gl_FragColor=vec4(col,1.0);}',
  caustic: GL_HELPERS +
    'void main(){float asp=u_res.x/u_res.y;vec2 auv=vec2(v_uv.x*asp,v_uv.y);float t=u_time;' +
    'vec2 w=vec2(fbm(auv*3.2+t*0.10),fbm(auv*3.2-t*0.12+5.0));vec2 cuv=auv*1.5+(w-0.5)*0.10;' +
    'float ca=caustic(cuv,t);float ca2=caustic(cuv*1.8+4.0,t*1.15);ca=max(ca,ca2*0.55);' +
    'gl_FragColor=vec4(mix(' + GL_PAPER + ',' + GL_INK + ',clamp(ca*1.7,0.0,1.0)),1.0);}'
};
function glSetup(cv, fsrc) {
  var g = cv.getContext('webgl', { antialias: true, premultipliedAlpha: false });
  if (!g) return null;
  function sh(t, s) { var x = g.createShader(t); g.shaderSource(x, s); g.compileShader(x); return x; }
  var p = g.createProgram();
  g.attachShader(p, sh(g.VERTEX_SHADER, GL_VS));
  g.attachShader(p, sh(g.FRAGMENT_SHADER, fsrc));
  g.linkProgram(p);
  if (!g.getProgramParameter(p, g.LINK_STATUS)) return null;
  g.useProgram(p);
  var bb = g.createBuffer();
  g.bindBuffer(g.ARRAY_BUFFER, bb);
  g.bufferData(g.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), g.STATIC_DRAW);
  var l = g.getAttribLocation(p, 'p');
  g.enableVertexAttribArray(l);
  g.vertexAttribPointer(l, 2, g.FLOAT, false, 0, 0);
  var U = {};
  ['u_res', 'u_time', 'u_clarity', 'u_murk', 'u_caustic', 'u_murkCol'].forEach(function (k) { U[k] = g.getUniformLocation(p, k); });
  return function (time) {
    g.viewport(0, 0, cv.width, cv.height);
    g.uniform2f(U.u_res, cv.width, cv.height);
    g.uniform1f(U.u_time, time);
    if (U.u_clarity) g.uniform1f(U.u_clarity, .97);
    if (U.u_murk) g.uniform1f(U.u_murk, .05);
    if (U.u_caustic) g.uniform1f(U.u_caustic, 1.076);
    if (U.u_murkCol) g.uniform3f(U.u_murkCol, .775, .844, .865);
    g.drawArrays(g.TRIANGLES, 0, 3);
  };
}

// ---- billboard water: the app's surface inside the billboard UI ----
var bbCv = document.getElementById('bbwater');
var bbDraw = null, bbRaf = null;
if (bbCv) {
  bbDraw = glSetup(bbCv, GL_FRAGS.water);       // plate underneath stays as fallback
  if (bbDraw) { bbCv.width = 1868; bbCv.height = 884; }  // 2x: crisp through the push
  else bbCv = null;
}
// the featured card's basin runs the live surface
var cardFigs = [];
document.querySelectorAll('.pcard canvas[data-fig]').forEach(function (cv) {
  var draw = glSetup(cv, GL_FRAGS[cv.dataset.fig]);
  if (!draw) return;
  cv.width = 328; cv.height = 328;
  cardFigs.push(draw);
});
/* no document.hidden gate: rAF freezes in hidden tabs and resumes on its own */
function bbOn() { return !!bbDraw && bbCv.closest('.art').classList.contains('on'); }
function bbActive() {
  return state.mode !== 'detail' && (bbOn() || cardFigs.length > 0);
}
function bbTick(now) {
  bbRaf = null;
  if (!bbActive()) return;                            // parks; bbWake() restarts it
  if (bbOn()) bbDraw(now / 1000);
  cardFigs.forEach(function (d) { d(now / 1000); });
  bbRaf = requestAnimationFrame(bbTick);
}
function bbWake() {
  if (!bbDraw && !cardFigs.length) return;
  if (reduceMotion) {                                 // a still frame, no loop
    if (bbOn()) bbDraw(3);
    cardFigs.forEach(function (d) { d(3); });
    return;
  }
  if (!bbRaf && bbActive()) bbRaf = requestAnimationFrame(bbTick);
}

// ---- detail-world figures: each Poolside iteration runs its live stage ----
var dfigs = [], dfigRaf = null;
function dfigsTeardown() {
  dfigs.forEach(function (s) {
    var g = s.cv.getContext('webgl');
    var ext = g && g.getExtension('WEBGL_lose_context');
    if (ext) ext.loseContext();
  });
  dfigs = [];
}
function dfigsBuild() {
  railEl.querySelectorAll('canvas.dfig').forEach(function (cv) {
    var draw = glSetup(cv, GL_FRAGS[cv.dataset.fig]);
    if (!draw) return;                                // ring + caption still stand
    // 2x the laid-out box so panels stay crisp at any viewport scale
    cv.width = Math.round((cv.offsetWidth || 660) * 2);
    cv.height = Math.round((cv.offsetHeight || 410) * 2);
    if (reduceMotion) draw(3);
    else dfigs.push({ cv: cv, draw: draw });
  });
  dfigWake();
}
function dfigTick(now) {
  dfigRaf = null;
  if (!dfigs.length || (state.mode !== 'detail' && state.mode !== 'entering')) return;
  dfigs.forEach(function (s) { s.draw(now / 1000); });
  dfigRaf = requestAnimationFrame(dfigTick);
}
function dfigWake() { if (!dfigRaf && dfigs.length && !reduceMotion) dfigRaf = requestAnimationFrame(dfigTick); }

/* ---- the Source / Figure plate, reused from /source-figure/ ----
   The drawing functions are copied verbatim and kept at column zero so
   Function.prototype.toString() prints clean: the pane in each study
   panel is the toString of the function that drew its figure, here too. */

function lines(fn) { return fn.toString().split('\n'); }

function beams(fn, fig) {
  const rows = lines(fn);
  for (let y = 0; y < rows.length; y++) {
    const line = rows[y];
    const indent = line.length - line.trimStart().length;
    const span = line.trim().length;
    if (span > 0) bar(fig, indent, y, span);
  }
}

function profile(fn, fig) {
  const rows = lines(fn), path = [];
  for (let y = 0; y < rows.length; y++) {
    const line = rows[y];
    if (line.trim().length === 0) continue;
    const depth = (line.length - line.trimStart().length) / 2;
    path.push([depth, y]);
  }
  steps(fig, path);
}

function arcs(fn, fig) {
  const flat = fn.toString().replace(/\s+/g, ' ');
  const open = [];
  for (let i = 0; i < flat.length; i++) {
    if ('([{'.includes(flat[i])) open.push(i);
    if (')]}'.includes(flat[i])) arch(fig, open.pop(), i, open.length);
  }
  return flat;
}

var SF_NS = 'http://www.w3.org/2000/svg';
var SF_INK = '#1A1815', SF_BLUE = '#3656D4', SF_FAINT = '#E5E9FB';
var SF_LH = 21, SF_CH = 7.5, SF_CH11 = 6.6;
function sfEl(name, attrs, parent) {
  var n = document.createElementNS(SF_NS, name);
  for (var k in attrs) n.setAttribute(k, attrs[k]);
  if (parent) parent.appendChild(n);
  return n;
}
function sfMarkup(codePart) {
  var h = esc(codePart);
  h = h.replace(/'[^']*'/g, function (m) { return '<span class="st">' + m + '</span>'; });
  h = h.replace(/\b(function|const|let|for|while|if|else|return|continue|of|new)\b/g, '<b>$1</b>');
  return h;
}
function sfHighlight(code) {
  return code.split('\n').map(function (line) {
    var m = line.match(/^(.*?)(\/\/.*)$/);
    var h = m ? sfMarkup(m[1]) + '<span class="cm">' + esc(m[2]) + '</span>' : sfMarkup(line);
    return '<span class="ln">' + (h || ' ') + '</span>';
  }).join('');
}
function bar(fig, indent, y, span) {
  sfEl('rect', {
    x: (indent * SF_CH).toFixed(1), y: y * SF_LH + 5,
    width: (span * SF_CH).toFixed(1), height: 9,
    class: 'beam on', 'data-y': y
  }, fig);
}
var sfPath = null;
function steps(fig, pts) {
  var x = function (d) { return 30 + d * 7 * SF_CH; };
  var y = function (r) { return r * SF_LH + 11.5; };
  var d = 'M ' + x(pts[0][0]) + ' ' + y(pts[0][1]);
  var fill = 'M ' + x(0) + ' ' + y(pts[0][1]) + ' L ' + x(pts[0][0]) + ' ' + y(pts[0][1]);
  for (var i = 1; i < pts.length; i++) {
    d += ' V ' + y(pts[i][1]) + ' H ' + x(pts[i][0]);
    fill += ' V ' + y(pts[i][1]) + ' H ' + x(pts[i][0]);
  }
  fill += ' V ' + y(pts[pts.length - 1][1]) + ' H ' + x(0) + ' Z';
  sfEl('path', { d: fill, fill: SF_FAINT, stroke: 'none', class: 'terr' }, fig);
  sfPath = sfEl('path', { d: d, fill: 'none', stroke: SF_INK, 'stroke-width': 1.8 }, fig);
}
var sfArcpaths = [];
function arch(fig, a, b, depth) {
  var x1 = (a + 0.5) * SF_CH11, x2 = (b + 0.5) * SF_CH11;
  var h = Math.min(16 + (x2 - x1) * 0.22, 88);
  var p = sfEl('path', {
    d: 'M ' + x1.toFixed(1) + ' 104 C ' + x1.toFixed(1) + ' ' + (104 - h).toFixed(1) +
       ' ' + x2.toFixed(1) + ' ' + (104 - h).toFixed(1) + ' ' + x2.toFixed(1) + ' 104',
    fill: 'none', stroke: SF_INK, 'stroke-width': Math.max(0.7, 1.5 - depth * 0.2)
  }, fig);
  sfEl('line', { x1: x1.toFixed(1), y1: 104, x2: x1.toFixed(1), y2: 110, stroke: SF_BLUE, 'stroke-width': 1 }, fig);
  sfEl('line', { x1: x2.toFixed(1), y1: 104, x2: x2.toFixed(1), y2: 110, stroke: SF_BLUE, 'stroke-width': 1 }, fig);
  sfArcpaths.push(p);
}
function sfBuild() {
  railEl.querySelectorAll('.dstudy').forEach(function (panel) {
    var kind = panel.getAttribute('data-study');
    var pre = panel.querySelector('pre');
    var hold = panel.querySelector('.figwrap');
    if (!pre || !hold) return;
    if (kind === 'beams') {
      pre.innerHTML = sfHighlight(beams.toString());
      var rows = lines(beams);
      var w = Math.max.apply(null, rows.map(function (r) { return r.length; })) * SF_CH + 6;
      var hgt = rows.length * SF_LH;
      var svg = sfEl('svg', { width: Math.ceil(w), height: hgt, 'aria-label': 'each source line rendered as a beam' });
      for (var yy = 0; yy < rows.length; yy++) {
        sfEl('line', { x1: 0, y1: yy * SF_LH + 16.5, x2: Math.ceil(w), y2: yy * SF_LH + 16.5, class: 'baseline' }, svg);
      }
      hold.appendChild(svg);
      beams(beams, svg);
      svg.querySelectorAll('.beam').forEach(function (b) {
        var k = +b.getAttribute('data-y');
        b.addEventListener('pointerenter', function () { var l = pre.querySelectorAll('.ln')[k]; if (l) l.classList.add('pc'); });
        b.addEventListener('pointerleave', function () { var l = pre.querySelectorAll('.ln')[k]; if (l) l.classList.remove('pc'); });
      });
    } else if (kind === 'profile') {
      pre.innerHTML = sfHighlight(profile.toString());
      var rows2 = lines(profile);
      var h2 = rows2.length * SF_LH;
      var w2 = 30 + 3 * 7 * SF_CH + 64;
      var svg2 = sfEl('svg', { width: Math.ceil(w2), height: h2 + 26, 'aria-label': 'indentation depth of each row as a step profile' });
      for (var dd = 0; dd <= 3; dd++) {
        var gx = 30 + dd * 7 * SF_CH;
        sfEl('line', { x1: gx, y1: 14, x2: gx, y2: h2 + 4, class: 'guide', 'stroke-dasharray': '1 4' }, svg2);
        var t = sfEl('text', { x: gx - 2, y: 8, class: 'guide-label' }, svg2);
        t.textContent = dd;
      }
      var lbl = sfEl('text', { x: 30 + 3 * 7 * SF_CH + 14, y: 8, class: 'guide-label' }, svg2);
      lbl.textContent = 'DEPTH';
      hold.appendChild(svg2);
      profile(profile, svg2);
    } else if (kind === 'arcs') {
      pre.innerHTML = sfHighlight(arcs.toString());
      var probe = arcs(beams, { appendChild: function () {} });
      var w3 = Math.ceil(probe.length * SF_CH11) + 12;
      var svg3 = sfEl('svg', { width: w3, height: 112, 'aria-label': 'bracket pairs of the flattened source drawn as arcs' });
      hold.appendChild(svg3);
      sfArcpaths = [];
      var flat = arcs(beams, svg3);
      var div = document.createElement('div');
      div.className = 'flat';
      div.innerHTML = esc(flat).replace(/([(){}[\]])/g, '<b>$1</b>');
      hold.appendChild(div);
    }
  });
}

// ---- detail world ----
var detail = document.getElementById('detail');
var dcam = document.getElementById('dcam');
var railEl = document.getElementById('rail');
var rail = { x: 0, target: 0, max: 0, width: 0, centers: [] };

function esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;'); }

function frameHtml(p, it, kind) {
  if (it.fig) {
    // the artifact is real: the iteration's live WebGL stage (see /poolside/)
    return '<div class="dframe dframe-fig" style="color:' + p.ink + '">' +
      '<canvas class="dfig" data-fig="' + esc(it.fig) + '"></canvas>' +
      '<span class="dframe-ring"></span>' +
      '<span class="dframe-live">LIVE · ' + esc(it.fig).toUpperCase() + ' · WEBGL</span>' +
      '</div>';
  }
  // artifact slot: designed placeholder until the real image lands (per-iter img in PROJECTS)
  return '<div class="dframe" style="background:radial-gradient(120% 140% at 30% 20%, ' + p.deep + ' 0%, rgba(6,8,9,.0) 100%); color:' + p.ink + '">' +
    '<div class="dframe-inner"></div>' +
    '<div class="dframe-v" style="color:' + p.accent + '">' + esc(it.v) + '</div>' +
    '<div class="dframe-tag">' + esc(p.name) + ' — ' + esc(kind) + ' SLOT 1280×800</div>' +
    '</div>';
}

function rowsHtml(rows) {
  if (!rows || !rows.length) return '';
  return '<div class="drows">' + rows.map(function (r) { return '<span class="drow">' + esc(r).toUpperCase() + '</span>'; }).join('') + '</div>';
}
function extraHtml(p, x) {
  if (x.kind === 'app') {
    return '<div class="dpanel dinterface">' +
      '<div class="dv" style="color:' + p.accent + '">' + esc(x.label) + '</div>' +
      '<div class="dh">' + esc(x.title || '') + '</div>' +
      '<div class="dint-row">' +
      '<div class="dapp-hold"></div>' +
      '<div class="dint-side"><p class="dcap">' + esc(x.body || '') + '</p>' + rowsHtml(x.rows) + '</div>' +
      '</div></div>';
  }
  if (x.kind === 'stack') {
    // the exhibit's exploded deck: four live layers + its legend, side by side
    return '<div class="dpanel dstack">' +
      '<div class="dv" style="color:' + p.accent + '">' + esc(x.label) + '</div>' +
      '<div class="dh">' + esc(x.title || '') + '</div>' +
      '<div class="dstack-row">' +
      '<div class="dstack-col">' +
      '<div class="dstack-stage"><div class="dstack-deck">' +
      ['water', 'caustic', 'warp', 'field'].map(function (f, n) {
        return '<div class="pl-layer" style="transform:translateZ(' + (n * 36) + 'px)"><canvas class="dfig" data-fig="' + f + '"></canvas></div>';
      }).join('') +
      '</div></div>' +
      '<div class="dstack-gauge">' +
      '<div class="pl-gauge-top"><span class="dstack-kicker">exploded view · fig.04–07</span><span class="dstack-readout">lift 15</span></div>' +
      '<input type="range" min="0" max="40" step="1" value="15" aria-label="Layer separation, 0 one pass to 40 exploded">' +
      '<div class="pl-ticks"><span>0 · one pass</span><span>20</span><span>40 · exploded</span></div>' +
      '</div>' +
      '</div>' +
      '<div class="dstack-side"><p class="dcap">' + esc(x.body || '') + '</p>' +
      '<ol class="dstack-legend">' + (x.items || []).map(function (it) {
        return '<li><span class="dstack-tag">' + esc(it.no) + '</span><b>' + esc(it.title) + '</b><p>' + esc(it.body) + '</p></li>';
      }).join('') + '</ol></div>' +
      '</div></div>';
  }
  if (x.kind === 'study') {
    // a Source / Figure study: the source pane and the figure it draws,
    // built by the plate functions after insertion (sfBuild)
    return '<div class="dpanel dstudy" data-study="' + esc(x.fig) + '">' +
      '<div class="dv" style="color:' + p.accent + '">' + esc(x.label) + '</div>' +
      '<div class="dh">' + esc(x.title || '') + '</div>' +
      '<div class="sf"><div class="cols">' +
      '<div class="pane"><div class="pane-label">' + esc(x.paneLabel || '') + '</div><pre class="src"></pre></div>' +
      '<div class="pane"><div class="pane-label">' + esc(x.figLabel || '') + '</div><div class="figclip"><div class="figwrap"></div></div></div>' +
      '</div><p class="caption">' + (x.capHtml || '') + '</p></div>' +
      '</div>';
  }
  if (x.kind === 'list') {
    // a skill sheet: name, tagline, install, tokens, and its rule rows
    return '<div class="dpanel dlist">' +
      '<div class="dv" style="color:' + p.accent + '">' + esc(x.label) + '</div>' +
      '<div class="dh">' + esc(x.title || '') + '</div>' +
      '<p class="dcap">' + esc(x.body || '') + '</p>' +
      (x.cmd ? '<div class="dcmd">' + esc(x.cmd) + '</div>' : '') +
      rowsHtml(x.rows) +
      '<div class="dlist-grid">' + (x.items || []).map(function (it) {
        return '<div class="dlist-row"><span class="dlist-tag">' + esc(it.no) + '</span><span><b>' + esc(it.title) + '</b><p>' + esc(it.body) + '</p></span></div>';
      }).join('') + '</div></div>';
  }
  if (x.kind === 'exploded') {
    // the exhibit's exploded view: the four features out of the shell,
    // each with its fig-tag and x-note; components cloned from #pphone
    return '<div class="dpanel dexploded">' +
      '<div class="dv" style="color:' + p.accent + '">' + esc(x.label) + '</div>' +
      '<div class="dh">' + esc(x.title || '') + '</div>' +
      '<p class="dcap dexp-lede">' + esc(x.body || '') + '</p>' +
      '<div class="dexp-grid">' + (x.items || []).map(function (it) {
        return '<div class="dexp-part">' +
          '<div class="fig-tag"><span class="fig-no">' + esc(it.no) + '</span><span class="fig-cap">' + esc(it.title) + '</span></div>' +
          '<div class="dexp-body"><div class="dexp-hold"></div>' +
          '<p class="x-note"><b>' + esc(it.lead || '') + '</b> ' + esc(it.body) + '</p></div>' +
          '</div>';
      }).join('') + '</div></div>';
  }
  if (x.kind === 'parts') {
    return '<div class="dpanel dparts">' +
      '<div class="dv" style="color:' + p.accent + '">' + esc(x.label) + '</div>' +
      '<div class="dh">' + esc(x.title || '') + '</div>' +
      '<div class="dparts-grid">' + (x.items || []).map(function (it) {
        return '<div class="dpart"><span class="dpart-no">' + esc(it.no) + '</span><b>' + esc(it.title) + '</b><p>' + esc(it.body) + '</p><span class="dpart-read">' + esc(it.read) + '</span></div>';
      }).join('') + '</div></div>';
  }
  if (x.kind === 'code') {
    // the highlighted SkSL passages, cloned from the server-rendered template
    return '<div class="dpanel dcode">' +
      '<div class="dv" style="color:' + p.accent + '">' + esc(x.label) + '</div>' +
      '<div class="dh">' + esc(x.title || '') + '</div>' +
      '<p class="dcap">' + esc(x.body || '') + '</p>' +
      '<div class="dcode-hold"></div>' +
      '</div>';
  }
  var noteInner =
    '<div class="dv" style="color:' + p.accent + '">' + esc(x.label) + '</div>' +
    '<div class="dh">' + esc(x.title || '') + '</div>' +
    '<p class="dcap">' + esc(x.body || '') + '</p>' + rowsHtml(x.rows);
  if (x.video) {
    // the project's own footage rides beside the note (videocard as on the page)
    return '<div class="dpanel dnote dnote-media"><div class="dnote-text">' + noteInner + '</div>' +
      '<div class="videocard"><video controls muted playsinline preload="metadata" src="' + esc(x.video.src) + '"></video>' +
      '<div class="cap"><b>' + esc(x.video.cap) + '</b><span class="mono">' + esc(x.video.sub) + '</span></div></div>' +
      '</div>';
  }
  return '<div class="dpanel dnote">' + noteInner + '</div>';
}

function buildDetail(i) {
  var p = PROJECTS[i];
  dfigsTeardown();
  detail.style.background = 'radial-gradient(130% 120% at 30% 10%, ' + p.deep + ' 0%, ' + (p.base || '#060809') + ' 78%)';
  detail.style.color = p.ink;

  var no = String(i + 1).padStart(2, '0');
  var h = '';
  h += '<div class="dpanel dtitle' + (p.lede ? ' rich' : '') + '">' +
       '<div class="dnum">' + no + '</div>' +
       '<div class="dlbl">PROJECT ' + no + ' — WALKED IN</div>' +
       '<h2 class="dname" style="color:' + p.accent + '" tabindex="-1" id="dfocus">' + esc(p.name) + '</h2>' +
       '<div class="dtag">' + esc(p.tag) + '</div>' +
       (p.lede ? '<p class="dlede">' + esc(p.lede) + '</p>' : '') +
       '<div class="dmeta"><span>' + esc(p.meta || (p.iters.length + ' ITERATIONS')) + '</span><span>2026</span><span>SCROLL →</span></div>' +
       (p.facts ? '<div class="dfacts">' + p.facts.map(function (f) { return '<div class="dfact"><i></i>' + esc(f) + '</div>'; }).join('') + '</div>' : '') +
       (p.href
         ? '<a class="dposter" href="' + p.href + '"' + (p.href.indexOf('http') === 0 ? ' target="_blank" rel="noopener"' : '') + ' aria-label="Open ' + esc(p.name) + '"></a>' +
           '<a class="dopen" href="' + p.href + '"' + (p.href.indexOf('http') === 0 ? ' target="_blank" rel="noopener"' : '') + ' style="color:' + p.accent + '">' + esc(p.linkLabel || 'OPEN CASE STUDY') + ' <span aria-hidden="true">↗</span></a>'
         : '<span class="dposter"></span>') +
       '</div>';
  (p.pre || []).forEach(function (x) { h += extraHtml(p, x); });
  p.iters.forEach(function (it, n) {
    h += '<div class="dpanel diter' + (n % 2 ? ' alt' : '') + '">' +
         '<div class="dnum">' + esc(it.v.replace('V', '')) + '</div>' +
         frameHtml(p, it, 'ARTIFACT') +
         '<div class="dtext">' +
         '<div class="dv" style="color:' + p.accent + '">' + esc(it.v) + '</div>' +
         '<div class="dh">' + esc(it.title) + '</div>' +
         '<p class="dcap">' + esc(it.cap) + '</p>' +
         '<div class="drows">' + it.rows.map(function (r) { return '<span class="drow">' + esc(r).toUpperCase() + '</span>'; }).join('') + '</div>' +
         '</div></div>';
  });
  (p.post || []).forEach(function (x) { h += extraHtml(p, x); });
  h += '<div class="dpanel dend">' +
       (p.question ? '<p class="dq">' + esc(p.question) + '</p>' : '') +
       '<div class="dlbl">END OF TIMELINE</div>' +
       '<a class="dback" href="#/" style="color:' + p.accent + '">STEP BACK OUT</a>' +
       '</div><div class="dend-pad"></div>';
  railEl.innerHTML = h;

  // the poster: for poolside, a scaled clone of the real interface;
  // otherwise the project's plate, cloned from its template
  var poster = railEl.querySelector('.dposter');
  var papp = p.slug === 'poolside' ? document.querySelector('.tv .bb-app') : null;
  if (papp) {
    var pclone = papp.cloneNode(true);
    var pcv = pclone.querySelector('canvas');
    if (pcv) { pcv.removeAttribute('id'); pcv.classList.add('dfig'); pcv.dataset.fig = 'water'; }
    var wrap = document.createElement('span');
    wrap.className = 'bb-scale';
    wrap.appendChild(pclone);
    poster.appendChild(wrap);
  } else {
    var tpl = document.getElementById('plate-' + p.slug);
    if (tpl) poster.appendChild(tpl.content.cloneNode(true));
  }

  // the app panel gets the original mobile build (the #pphone template)
  var hold = railEl.querySelector('.dapp-hold');
  var phoneTpl = document.getElementById('pphone');
  if (hold && phoneTpl) hold.appendChild(phoneTpl.content.cloneNode(true));

  // the code panel gets the server-highlighted SkSL passages
  var codeHold = railEl.querySelector('.dcode-hold');
  var srcTpl = document.getElementById('psrc');
  if (codeHold && srcTpl) codeHold.appendChild(srcTpl.content.cloneNode(true));

  sfBuild();                                          // Source / Figure study plates

  // the exploded panel's holds get the phone's own sections, out of the shell
  var expHolds = railEl.querySelectorAll('.dexp-hold');
  if (expHolds.length && phoneTpl) {
    var secs = phoneTpl.content.querySelectorAll('.p-sec');
    expHolds.forEach(function (hh, n) {
      if (!secs[n]) return;
      var wrap = document.createElement('div');
      wrap.className = 'pworld lg dexp-comp';
      wrap.appendChild(secs[n].cloneNode(true));
      hh.appendChild(wrap);
    });
  }

  dfigsBuild();                                       // live stages, when the project has them

  // the exploded-view slider, wired as on the exhibit (SCALE 2.4, FADE 7)
  var sdeck = railEl.querySelector('.dstack-deck');
  var slider = railEl.querySelector('.dstack-gauge input');
  var readout = railEl.querySelector('.dstack-readout');
  if (sdeck && slider) {
    var slayers = sdeck.querySelectorAll('.pl-layer');
    var applyLift = function (E) {
      slayers.forEach(function (ly, n) {
        ly.style.transform = 'translateZ(' + (n * E * 2.4).toFixed(1) + 'px)';
        ly.style.opacity = n === 0 ? '1' : Math.max(0, Math.min(1, E / 7)).toFixed(3);
      });
      readout.textContent = 'lift ' + String(E).padStart(2, '0');
    };
    slider.addEventListener('input', function () { applyLift(+slider.value); });
    applyLift(15);
  }

  // timeline ruler: one tick per stop (title + panels + end)
  var tl = document.getElementById('dtimeline');
  var stops = ['IN']
    .concat((p.pre || []).map(function (x) { return x.label; }))
    .concat(p.iters.map(function (it) { return it.v; }))
    .concat((p.post || []).map(function (x) { return x.label; }))
    .concat(['OUT']);
  var t = '<div class="tl-rule"></div>';
  stops.forEach(function (s, n) {
    var pct = stops.length > 1 ? (n / (stops.length - 1)) * 100 : 0;
    t += '<div class="tl-tick" style="left:' + pct + '%"></div>';
    t += '<div class="tl-lbl" style="left:' + pct + '%">' + esc(s) + '</div>';
  });
  t += '<div class="tl-dot" id="tldot" style="left:0%"></div>';
  tl.innerHTML = t;

  rail.x = rail.target = 0;
  dfit();
}

function dfit() {
  if (!detail.classList.contains('on')) return;
  var ds = innerHeight / 1024;
  rail.width = railEl.scrollWidth;
  rail.max = Math.max(0, rail.width * ds - innerWidth) / ds;   // in world px
  rail.centers = [];
  railEl.querySelectorAll('.dpanel').forEach(function (el) {
    rail.centers.push(Math.min(rail.max, Math.max(0, el.offsetLeft + el.offsetWidth / 2 - (innerWidth / ds) / 2)));
  });
  applyRail(ds);
}
function applyRail(ds) {
  ds = ds || innerHeight / 1024;
  dcam.style.transform = 'scale(' + ds + ') translate3d(' + (-rail.x) + 'px,0,0)';
  var dot = document.getElementById('tldot');
  if (dot) dot.style.left = (rail.max ? Math.min(1, Math.max(0, rail.x / rail.max)) : 0) * 100 + '%';
}
addEventListener('resize', dfit);

// ---- rail input: wheel / drag / keys, smoothing, idle snap, edge exit ----
var railInput = {
  lastInput: 0, dragging: false, dragX: 0, dragStart: 0,
  raf: null, EXIT_TRIGGER: 200, RESIST: .35
};
function railWake() {
  railInput.lastInput = performance.now();
  if (!railInput.raf) railTick();
}
function railTick() {
  var r = rail, ri = railInput;
  var idle = performance.now() - ri.lastInput > 150;
  if (idle && !ri.dragging) {
    if (r.target < 0) {
      // released in the overscroll zone: exit if past the threshold, else spring home
      if (r.target < -ri.EXIT_TRIGGER && state.mode === 'detail') { location.hash = '#/'; r.target = 0; }
      else r.target += (0 - r.target) * .12;
    } else if (r.centers.length) {
      var best = r.centers[0];
      r.centers.forEach(function (c) { if (Math.abs(c - r.target) < Math.abs(best - r.target)) best = c; });
      r.target += (best - r.target) * .06;     // gentle magnet, free while scrolling
    }
  }
  r.target = Math.min(r.target, r.max + 80);
  r.x += (r.target - r.x) * (reduceMotion ? 1 : .12);
  applyRail();
  if (Math.abs(r.target - r.x) > .1 || !idle || ri.dragging) railInput.raf = requestAnimationFrame(railTick);
  else { railInput.raf = null; r.x = r.target; applyRail(); }
}
detail.addEventListener('wheel', function (e) {
  if (state.mode !== 'detail') return;
  e.preventDefault();
  var d = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
  if (rail.target + d < 0) d *= railInput.RESIST;             // resistance before the edge exit
  rail.target = Math.max(-railInput.EXIT_TRIGGER - 60, Math.min(rail.max + 80, rail.target + d));
  railWake();
}, { passive: false });
detail.addEventListener('pointerdown', function (e) {
  if (state.mode !== 'detail' || e.target.closest('a') || e.target.closest('input') || e.target.closest('video')) return;
  railInput.dragging = true; railInput.dragX = e.clientX; railInput.dragStart = rail.target;
  detail.classList.add('grabbing');
  detail.setPointerCapture(e.pointerId);
  railWake();
});
detail.addEventListener('pointermove', function (e) {
  if (!railInput.dragging) return;
  var ds = innerHeight / 1024;
  var d = (railInput.dragX - e.clientX) / ds;
  var t = railInput.dragStart + d;
  if (t < 0) t *= railInput.RESIST;
  rail.target = Math.max(-railInput.EXIT_TRIGGER - 60, Math.min(rail.max + 80, t));
  railWake();
});
['pointerup', 'pointercancel'].forEach(function (ev) {
  detail.addEventListener(ev, function () {
    railInput.dragging = false;
    detail.classList.remove('grabbing');
    railWake();
  });
});
document.addEventListener('keydown', function (e) {
  if (state.mode !== 'detail') return;
  var i, cur = rail.centers.indexOf(rail.centers.reduce(function (a, b) {
    return Math.abs(b - rail.target) < Math.abs(a - rail.target) ? b : a;
  }, rail.centers[0] || 0));
  if (e.key === 'ArrowRight') { i = Math.min(rail.centers.length - 1, cur + 1); rail.target = rail.centers[i]; railWake(); }
  if (e.key === 'ArrowLeft')  { i = Math.max(0, cur - 1); rail.target = rail.centers[i]; railWake(); }
});

// ---- walk-through transition ----
var reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

function cubicBezier(x1, y1, x2, y2) {
  function f(t, a, b) { var o = 1 - t; return 3*o*o*t*a + 3*o*t*t*b + t*t*t; }
  return function (x) {
    if (x <= 0) return 0; if (x >= 1) return 1;
    var t = x;
    for (var i = 0; i < 6; i++) {
      var cx = f(t, x1, x2) - x;
      var dx = 3*(1-t)*(1-t)*x1 + 6*(1-t)*t*(x2-x1) + 3*t*t*(1-x2);
      if (Math.abs(dx) < 1e-6) break;
      t -= cx / dx;
      t = Math.max(0, Math.min(1, t));
    }
    return f(t, y1, y2);
  };
}
var easePush = cubicBezier(.7, 0, .3, 1);

var pushAnim = null, transTimers = [];
function animatePush(to, dur, done) {
  if (pushAnim) cancelAnimationFrame(pushAnim);
  var from = camState.push, t0 = performance.now();
  cam.style.willChange = 'transform';
  function tick(now) {
    var t = Math.min(1, (now - t0) / dur);
    camState.push = from + (to - from) * easePush(t);
    applyCamera();
    if (t < 1) { pushAnim = requestAnimationFrame(tick); }
    else {
      pushAnim = null; cam.style.willChange = '';
      if (done) done();
    }
  }
  pushAnim = requestAnimationFrame(tick);
}
function clearTransTimers() { transTimers.forEach(clearTimeout); transTimers = []; }

var scene = document.getElementById('scene');

function animEnter(i) {
  state.mode = 'entering';
  setFeatured(i);
  buildDetail(i);
  clearTransTimers();
  document.body.classList.add('walked');
  scene.classList.add('pushing');
  detail.style.willChange = 'opacity, transform';

  function arrive() {
    detail.classList.add('on');
    dfit();
    void detail.offsetWidth;                 // commit start state before transitioning
    detail.classList.add('in');
  }
  function settle() {
    state.mode = 'detail';
    if (!reduceMotion) { camState.push = 1; applyCamera(); }  // deterministic even if rAF was throttled
    detail.style.willChange = '';
    var f = document.getElementById('dfocus');
    if (f) f.focus({ preventScroll: true });
    route();                                 // catch hash changes made mid-transition
  }
  if (reduceMotion) {
    arrive();
    transTimers.push(setTimeout(settle, 260));
  } else {
    animatePush(1, 850, null);
    transTimers.push(setTimeout(arrive, 450));
    transTimers.push(setTimeout(settle, 870));
  }
}

function animExit() {
  state.mode = 'exiting';
  clearTransTimers();
  detail.classList.remove('in');            // recede + fade (250ms)
  detail.style.willChange = 'opacity, transform';

  function land() {
    state.mode = 'landing';
    camState.push = 0; applyCamera();        // deterministic even if rAF was throttled
    document.body.classList.remove('walked');
    scene.classList.remove('pushing');
    detail.classList.remove('on');
    detail.style.willChange = '';
    var card = document.querySelector('.pcard.selected');
    if (card) card.focus({ preventScroll: true });
    route();
    bbWake();
  }
  if (reduceMotion) {
    scene.classList.remove('pushing');
    transTimers.push(setTimeout(land, 260));
  } else {
    animatePush(0, 650, null);
    transTimers.push(setTimeout(function () { scene.classList.remove('pushing'); }, 300));
    transTimers.push(setTimeout(land, 670));
  }
}

// ---- router: #/ landing, #/p/{slug} detail ----
function currentRoute() {
  var m = location.hash.match(/^#\/p\/([a-z-]+)$/);
  if (!m) return -1;
  for (var i = 0; i < PROJECTS.length; i++) if (PROJECTS[i].slug === m[1]) return i;
  return -1;
}
function route(initial) {
  var i = currentRoute();
  if (state.mode === 'entering' || state.mode === 'exiting') return;  // re-checked on completion
  if (i >= 0 && state.mode === 'landing') {
    if (initial) {                            // deep link: no motion
      state.mode = 'detail';
      setFeatured(i); buildDetail(i);
      document.body.classList.add('walked');
      scene.classList.add('pushing');
      camState.push = 1; applyCamera();
      detail.classList.add('on'); detail.classList.add('in');
      dfit();
    } else animEnter(i);
  } else if (i < 0 && state.mode === 'detail') {
    animExit();
  } else if (i >= 0 && state.mode === 'detail' && i !== state.featured) {
    setFeatured(i); buildDetail(i);          // project switch while inside: rebuild in place
  }
}
addEventListener('hashchange', function () { route(false); });

function enterProject(i) { location.hash = '#/p/' + PROJECTS[i].slug; }
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape' && state.mode === 'detail') location.hash = '#/';
});

// ---- side rail: strip toggles the nav; leaving the rail closes it ----
var lrail = document.getElementById('lrail');
var lrailStrip = document.getElementById('lrailStrip');
function lrailSet(open) {
  lrail.classList.toggle('open', open);
  lrailStrip.setAttribute('aria-expanded', String(open));
  lrailStrip.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
}
lrailStrip.addEventListener('click', function () { lrailSet(!lrail.classList.contains('open')); });
lrail.addEventListener('pointerleave', function () { lrailSet(false); });
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape' && state.mode === 'landing' && lrail.classList.contains('open')) lrailSet(false);
});
route(true);
bbWake();

// ---- room tone: generated, never autoplayed ----
var sound = document.getElementById('sound');
var sndState = document.getElementById('sndState');
var actx = null, gain = null;
sound.addEventListener('click', function () {
  var on = sound.getAttribute('aria-checked') !== 'true';
  sound.setAttribute('aria-checked', String(on));
  sndState.textContent = on ? 'ON' : 'OFF';
  if (!actx && on) {
    actx = new AudioContext();
    /* filtered noise: the room the plates are hung in */
    var len = actx.sampleRate * 4;
    var buf = actx.createBuffer(1, len, actx.sampleRate);
    var d = buf.getChannelData(0);
    var last = 0;
    for (var i = 0; i < len; i++) {
      var white = Math.random() * 2 - 1;
      last = (last + 0.02 * white) / 1.02;
      d[i] = last * 3.5;
    }
    var src = actx.createBufferSource();
    src.buffer = buf; src.loop = true;
    var lp = actx.createBiquadFilter();
    lp.type = 'lowpass'; lp.frequency.value = 520; lp.Q.value = 0.6;
    gain = actx.createGain(); gain.gain.value = 0;
    src.connect(lp).connect(gain).connect(actx.destination);
    src.start();
  }
  if (actx && gain) {
    actx.resume();
    gain.gain.cancelScheduledValues(actx.currentTime);
    gain.gain.linearRampToValueAtTime(on ? 0.06 : 0, actx.currentTime + 0.6);
  }
});

// headline calibration: pin each line's ink box exactly onto the measured mockup box
function calibrate() {
  document.querySelectorAll('.hl').forEach(function (el) {
    var cs = getComputedStyle(el);
    var fs = parseFloat(cs.fontSize);
    var lh = parseFloat(cs.lineHeight);
    var g = document.createElement('canvas').getContext('2d');
    g.font = cs.fontWeight + ' ' + fs + 'px ' + cs.fontFamily;
    var m = g.measureText(el.textContent);
    var capAsc = m.actualBoundingBoxAscent;
    var inkW = m.actualBoundingBoxLeft + m.actualBoundingBoxRight;
    var fbAsc = m.fontBoundingBoxAscent, fbDesc = m.fontBoundingBoxDescent;
    var targetW = parseFloat(el.dataset.w);
    var targetCapTop = parseFloat(el.dataset.captop);
    var targetCapH = 60;
    var sx = targetW / inkW, sy = targetCapH / capAsc;
    var baselineLocal = (lh - (fbAsc + fbDesc)) / 2 + fbAsc;
    var inkTopLocal = baselineLocal - capAsc;
    el.style.left = el.dataset.x + 'px';
    el.style.top = (targetCapTop - inkTopLocal * sy) + 'px';
    el.style.transform = 'scale(' + sx + ',' + sy + ')';
  });
}
document.fonts.ready.then(calibrate);
</script>
