---
import Bare from '../layouts/Bare.astro';
import Logo from '../components/Logo.astro';
import Plate from '../components/Plate.astro';
/* Fraunces: the Poolside app's display face, used in the billboard UI */
import '@fontsource/fraunces/300.css';
import '@fontsource/fraunces/400.css';
/* the Poolside phone build's own styles, scoped under .pworld */
import '../styles/poolside-app.css';
import { highlightSource, SKILLS } from '../data/portfolio';
/* Source / Figure's own sheet styles (namespaced .sf) + its serif */
import '@fontsource/radley/400.css';
import '@fontsource/radley/400-italic.css';
import '../styles/source-figure.css';
import { DISPERSION_SRC, CAUSTIC_SRC } from '../data/poolside-src';

/* The landing rebuilt from the billboard mockup (mockup-landing, SPEC.md):
   a fixed 1536×1024 stage fit-scaled to the viewport. Entering a project is
   a walk through the billboard; inside, the project reads as a horizontal
   timeline of its iterations. Exiting reverses the walk.
   Portfolio identity kept: the M mark, the Plates (art drawn by the page),
   the house blue accent for state, Instrument Sans / IBM Plex Mono. */

type Iter = { v: string; title: string; cap: string; rows: string[]; fig?: string };
/* extra world panels beyond the iteration timeline:
   note = a prose panel; app = the running interface; parts = a card grid;
   stack = the exploded shader deck with its legend (from /poolside/) */
type Extra = {
  kind: 'note' | 'app' | 'parts' | 'stack' | 'exploded' | 'code' | 'study' | 'list';
  label: string;
  title?: string;
  body?: string;
  rows?: string[];
  items?: { no: string; title: string; body: string; read?: string; lead?: string }[];
  /* a note panel may carry the project's video beside the text */
  video?: { src: string; cap: string; sub: string };
  /* study panels (Source / Figure): which plate function draws the figure */
  fig?: string;
  paneLabel?: string;
  figLabel?: string;
  capHtml?: string;
  /* list panels (skills): the install command */
  cmd?: string;
};
type Proj = {
  slug: string;
  name: string;
  tag: string;
  /* absent href = no case study yet; linkLabel names the destination */
  href?: string;
  linkLabel?: string;
  /* detail-world palette: surface tone, display accent, body ink;
     base is the far radial color (near-black default; paper = light world) */
  deep: string;
  accent: string;
  ink: string;
  base?: string;
  iters: Iter[];
  pre?: Extra[];
  post?: Extra[];
  question?: string;
  /* overrides the "N ITERATIONS" line in the title panel's meta row */
  meta?: string;
  /* the case-study page head, carried into the title panel */
  lede?: string;
  facts?: string[];
};

/* the three skill sheets, one world panel each, from the SKILLS data */
const SKILL_EXTRAS: Extra[] = SKILLS.map((s) => ({
  kind: 'list' as const,
  label: s.name.toUpperCase(),
  title: s.name,
  body: s.tagline,
  cmd: s.install,
  rows: s.tokens.map(([k, v]) => `${k} · ${v}`),
  items: s.sections[0].rows.map((r) => ({ no: r.tag || '', title: r.label, body: r.desc })),
}));

const PROJECTS: Proj[] = [
  {
    /* light world: Poolside's exhibit is paper-and-ink like the rest of the
       site; each iteration's artifact is the live WebGL stage from /poolside/ */
    /* the world IS the Poolside detail page: /poolside/ replicated for the
       horizontal scrolling concept */
    slug: 'poolside', name: 'POOLSIDE', tag: 'UI · SKIASHARP · UNO PLATFORM',
    deep: '#EFE7DD', accent: '#0A6C88', ink: '#1A1815', base: '#F6F2EE',
    meta: '4 STAGES · ONE PASS',
    lede: 'A pool chemistry companion created to explore real-time shaders with SkiaSharp. The experience became a playground for exploring water caustics, real-time shaders, and interactive rendering with SkiaSharp.',
    facts: [
      'Uno Platform · net10.0 · desktop + Android',
      'SkiaSharp 4.148 GA · runtime SkSL water',
      'MVUX · Toolkit TabBar · ShadowContainer',
      'Fraunces readings · Instrument Sans actions',
    ],
    pre: [
      /* the finished product leads; the making-of follows */
      {
        kind: 'app', label: 'APP', title: 'The home screen, running',
        body: 'The surface is an SKCanvasElement inside a folding basin control; chemistry binds to an MVUX IState of PoolSnapshot; the one-sentence insight comes from a DI-registered IWaterAnalyzer. Fraunces carries the readings, Instrument Sans the actions.',
        rows: ['uno platform', 'net10.0', 'desktop + android', 'mvux'],
      },
      {
        /* the exhibit's exploded view, paired with the app it takes apart */
        kind: 'exploded', label: 'EXPLODED', title: 'The interface, exploded.',
        body: 'Explode the interface and its key features lift out of the shell, remaining fully interactive and tethered to their original positions.',
        items: [
          { no: '1', title: 'WaterConditionCanvas · WaterCondition.sksl', lead: 'WaterConditionCanvas is an SKCanvasElement', body: 'running WaterCondition.sksl. Clarity, green, milky, and sediment are DependencyProperties snapshotted to fields for the render thread; the loop is vsync-aligned, capped at 30fps, and lives inside the folding IsoBasin control.' },
          { no: '2', title: 'engraved plate · IState‹PoolSnapshot›', lead: 'One recessed plate, four gauges in a 2×2 grid.', body: 'Toolkit ShadowContainer inner shadows and engraved hairlines. Readings bind to the MVUX IState of PoolSnapshot; a ChemistryExpanded state swaps compact numbers for full range bands.' },
          { no: '3', title: 'IWaterAnalyzer · PoolModel · one line', lead: 'The insight is a service.', body: 'IWaterAnalyzer is DI-registered and injected through the PoolModel(IWaterAnalyzer Analyzer) primary constructor. It reads the snapshot and the test strip (StripReader), then returns one sentence carrying a status tone.' },
          { no: '4', title: 'TrendsModel · Polyline · WaterThumbnail', lead: 'History is a Polyline sparkline', body: 'fed by TrendsModel; each week on the season shelf is a WaterThumbnail rendered by the same shader. The projection stays dashed, so projected weeks are never drawn in the solid ink of the ones already measured.' },
        ],
      },
      {
        kind: 'note', label: 'ORIGIN', title: 'It started as a shader, not an app.',
        body: 'The first build was Refraction Pixels, an Uno Platform desktop sample written to test SkiaSharp 4.148’s runtime SkSL through SKCanvasElement. Watching the caustics run, the question changed from “can the canvas do this” to “what product deserves this water.” That answer is Poolside.',
        rows: ['refraction pixels', 'skiasharp 4.148', 'runtime sksl'],
        video: { src: '/videos/water-shader.mp4', cap: 'The water shader, live', sub: 'Uno Platform · SkiaSharp 4.148' },
      },
      {
        /* the exploded layer stack, exactly as on the exhibit (pl-deck + legend) */
        kind: 'stack', label: 'STAGES', title: 'Four stages, one pass.',
        body: 'The figures are not diagrams: each layer runs its isolated stage in WebGL, in this site’s inks — stacked as the layers they are, composited in a single pass.',
        items: [
          { no: 'fig.04 · field', title: 'Value noise → fbm', body: 'A hashed lattice smoothed with a cubic fade, then four octaves summed. Everything organic in the shader (surface wobble, caustic warp, murk) is drawn from this field.' },
          { no: 'fig.05 · warp', title: 'Directional wave warp', body: 'Three sine waves at odd angles with incommensurate frequencies displace the sampling position, so nothing ever lines up with the grid. Gray is the undisturbed grid; ink is what the water does to it.' },
          { no: 'fig.06 · caustic', title: 'Caustic web', body: 'Warped-sine interference, rotated off-grid and bent by slow value noise. A sixth-power falloff pinches the bright bands into filaments; a third rotated layer breaks the remaining symmetry.' },
          { no: 'fig.07 · water · own inks', title: 'Composite · Poolside’s water', body: 'Depth tint, caustics scaled by clarity, spec highlights from the noise gradient, and sparkle on the filament cores. The app runs exactly this.' },
        ],
      },
    ],
    iters: [],
    post: [
      {
        kind: 'note', label: 'ONE PASS', title: 'In the app.',
        body: 'In the app the stages are not four passes: they are one half4 main(float2 fragCoord) SkSL program, compiled once into an SKRuntimeEffect and drawn by a single SKCanvasElement. field, warp, and caustic are helper functions feeding the composite, so the whole stack resolves per pixel in a single pass. The builder is cached once, uniforms are snapshotted to plain fields, and the render loop rides CompositionTarget.Rendering.',
        rows: ['skruntimeeffect', 'one pass', 'vsync'],
      },
      {
        kind: 'code', label: 'CODE', title: 'Key passages · PoolWater.sksl',
        body: 'The exact passages behind the dispersion and the caustic web, as they run in the app.',
      },
      {
        kind: 'parts', label: 'NOTES', title: 'Field notes',
        items: [
          { no: '01', title: 'One warp, three channels', body: 'The displacement is linear in its scale, so s(k) = suv + k·disp derives the red and blue samples exactly from the green evaluation.', read: 'disp ±0.06 · dispersion for free' },
          { no: '02', title: 'Cache the builder', body: 'SKRuntimeShaderBuilder is created once and reused. Disposing it per frame frees native state shared with the effect, and the next render access-violates.', read: 'build once · feed uniforms' },
          { no: '03', title: 'Zero-alloc loop', body: 'The render loop rides CompositionTarget.Rendering, snapshots inputs to plain fields, and reuses uniform buffers. At 0% intensity it stops painting.', read: 'vsync · idle at 0%' },
          { no: '04', title: 'GLSL to SkSL', body: 'No varyings, no gl_FragColor. Return a half4 from main(float2 fragCoord). Coordinates arrive in element DIPs, Y down; normalize and flip yourself.', read: 'half4 · Y-down DIPs' },
        ],
      },
    ],
  },
  {
    /* the world IS the Source / Figure detail page: /source-figure/ replicated
       for the scrolling concept; studies 01-03 draw themselves live */
    slug: 'source-figure', name: 'SOURCE / FIGURE', tag: 'DESIGN · STUDY · SELF-REFERENTIAL NOTATION',
    deep: '#E9E9F2', accent: '#3656D4', ink: '#1A1815', base: '#F6F2EE',
    meta: '7 STUDIES · TWO INKS',
    lede: 'Seven studies in which source code is the structure, texture, and rhythm of the image drawn from it. The code becomes the image.',
    facts: [
      'INK — executed, prints',
      'NON-PHOTO BLUE — construction, does not print',
      'Set in IBM Plex Mono & Radley · plotted in ch × 21px',
    ],
    pre: [
      {
        kind: 'note', label: 'METHOD', title: 'The pane is the plate.',
        body: 'Every figure on this sheet is drawn, at runtime, by the function printed beside it — and the printed text is the function: each source pane is Function.prototype.toString(), read back from the object that did the drawing.',
        rows: ['fn.toString()', 'two inks', 'canvas + svg'],
      },
      {
        kind: 'study', label: 'STUDY 01', title: 'A line of code is a line', fig: 'beams',
        paneLabel: 'fn beams — Function.prototype.toString()', figLabel: 'Fig. 1 — beams(beams, fig)',
        capHtml: 'Fig.&nbsp;1 is <b>beams</b> applied to itself: every printed line of the function becomes one beam — indentation for offset, character count for length. Point at a beam and its line answers.',
      },
      {
        kind: 'study', label: 'STUDY 02', title: 'Indentation is depth', fig: 'profile',
        paneLabel: 'fn profile — Function.prototype.toString()', figLabel: 'Fig. 2 — profile(profile, fig)',
        capHtml: 'Read the left edge of any program and a terrain appears. <b>profile</b> traces its own margin: each row contributes its depth, the staircase is the scope structure, and the blue wash is the mass of nesting.',
      },
      {
        kind: 'study', label: 'STUDY 03', title: 'Brackets contain', fig: 'arcs',
        paneLabel: 'fn arcs — Function.prototype.toString()', figLabel: 'Fig. 3 — arcs(beams, fig)',
        capHtml: '<b>arcs</b> flattens Study&nbsp;01 to a single line — a line of code owes you no line break — and draws a span for every matched pair. Containment becomes altitude: outer pairs arc higher, inner pairs shelter beneath them.',
      },
    ],
    iters: [],
    post: [
      {
        kind: 'parts', label: 'STUDIES 04–07', title: 'Further studies',
        items: [
          { no: 'STUDY 04 · REPETITION', title: 'A loop is a rhythm', body: 'One motif and a rule. The loop body prints eight times; each cell inks the current iteration and leaves the previous one in blue. Superimposed at Σ, the cycle closes into a figure no single iteration contains.', read: 'unroll(fig) · TURN = π/16' },
          { no: 'STUDY 05 · CHOICE', title: 'A condition forks', body: 'Both branches exist in the source, so both panels exist on the plate. Only the branch that executes receives ink; the alternate stays in non-photo blue. Code that does not run leaves no ink.', read: 'fork(fig) · one branch inked' },
          { no: 'STUDY 06 · VOICE', title: 'Comments are the human hand', body: 'The machine text stays in the column; its comments step out into the margin, set in a human hand. Voice and instruction are different materials, and the typeface says so.', read: 'execute(pre, step, ms)' },
          { no: 'STUDY 07 · QUINE', title: 'Portrait of a function as itself', body: 'The portrait’s only material is its own text: portrait.toString(), placed character by character. At t = 0 you can read it; at t = 1 you can only see it. The code does not describe the image; it becomes it.', read: 'portrait(cv, t)' },
        ],
      },
      {
        kind: 'note', label: 'COLOPHON', title: 'One theme only.',
        body: 'This is a printed sheet, and non-photo blue does not survive inversion. Every figure was drawn at runtime by the function shown beside it. View source — the page is the program that drew it.',
        rows: ['sheet no. 1', 'plex mono & radley', 'ch × 21px'],
      },
    ],
  },
  {
    slug: 'unoannotation', name: 'UNOANNOTATION', tag: 'TOOLING / AGENT MCP',
    deep: '#10231A', accent: '#5FC98F', ink: '#EAF5EE',
    iters: [
      { v: 'V0.1', title: 'Blind agent', cap: 'An AI agent building UI it cannot see. Every fix was a guess relayed through screenshots.', rows: ['no eyes', 'guesswork'] },
      { v: 'V0.4', title: 'Eyes', cap: 'The running app exposes its visual tree over MCP; the agent reads structure instead of pixels.', rows: ['mcp server', 'visual tree'] },
      { v: 'V0.7', title: 'Hands', cap: 'Element peers let the agent press what it sees. Verify loops replace describe-and-hope.', rows: ['peer actions', 'verify loop'] },
      { v: 'NOW', title: 'In progress', cap: 'Eyes and hands for agents, hardening into the everyday Uno Platform toolchain.', rows: ['uno platform', 'daily use'] },
    ],
  },
  {
    /* the world IS the XAML / Uno detail page: the feel system with all
       three skills on the same page */
    slug: 'xaml-uno', name: 'XAML / UNO', tag: 'SKILLS · THE FEEL SYSTEM',
    deep: '#EFE7DD', accent: '#3656D4', ink: '#1A1815', base: '#F6F2EE',
    meta: '3 SKILLS · ONE SHEET',
    lede: 'The motion-and-feel system I bring to Uno Platform and WinUI surfaces. Numbers, not adjectives: every interaction has a tuned value it must hit, and the same sheet travels from prototype to shipped app. If a state cannot be named, the design is not finished yet.',
    facts: [
      'easing · KeySpline 0.22,1 0.36,1 · fast out, long settle',
      'durations · 150ms micro · 200ms standard · 280ms entrance',
      'press · scale 0.98 on XAML surfaces',
      'entrances · fade + 6px rise · blur-in for hero surfaces',
      'shadows · layered ambient + key · never one big blur',
      'drag · spring physics · two-zone snap points',
    ],
    iters: [],
    post: [
      ...SKILL_EXTRAS,
      {
        kind: 'parts', label: 'PRINCIPLES', title: 'Principles',
        items: [
          { no: '01', title: 'State-driven, not event-driven', body: 'Visual states own the look; interactions only request transitions. If a state cannot be named, the design is not finished yet.', read: 'VisualStateManager first' },
          { no: '02', title: 'Reduced motion is a contract', body: 'Every animation is gated on the platform’s animation setting, each with a static fallback that was designed on purpose. The quiet version is a real state, never a broken one.', read: 'gated · static fallback' },
          { no: '03', title: 'Tokens over hex', body: 'Color comes from Material roles, type from the scale, overrides through lightweight styling keys. A hardcoded hex in XAML is a bug report I file against myself.', read: 'roles · scale · lightweight styling' },
          { no: '04', title: 'Proved on this site', body: 'Poolside’s shader water, the FLIP explode, and the tuned Skia effects all come from the same sheet.', read: 'see poolside' },
        ],
      },
    ],
  },
  {
    slug: 'design-ledger', name: 'DESIGN-LEDGER', tag: 'OSS / DESIGN DNA', href: 'https://github.com/mtmattei/design-ledger', linkLabel: 'OPEN REPO',
    deep: '#26221B', accent: '#E7DECF', ink: '#F4EFE8',
    iters: [
      { v: 'V0.1', title: 'First entry', cap: 'One decision written down: what was chosen, why, and what it cost. The format followed later.', rows: ['1 entry', 'chose / why / cost'] },
      { v: 'V0.4', title: 'Append-only', cap: 'No edits, no deletions. The record keeps its mistakes on purpose; a ledger that forgets is a brochure.', rows: ['append-only', 'keeps mistakes'] },
      { v: 'V0.7', title: 'Design DNA', cap: 'Entries structured so the taste can be read back out of the record — by a person or by an agent.', rows: ['structured', 'machine-readable'] },
      { v: 'V1.0', title: 'Public', cap: 'Open sourced. The decisions behind the work, auditable by anyone who cares to check.', rows: ['open source', 'github'] },
    ],
  },
];

/* client copy of the data — palette, copy, and route per project */
const CLIENT_PROJECTS = PROJECTS.map(({ slug, name, tag, href, linkLabel, deep, accent, ink, base, iters, pre, post, question, meta, lede, facts }) => ({
  slug, name, tag, href, linkLabel, deep, accent, ink, base, iters, pre, post, question, meta, lede, facts,
}));

/* landing card positions, from the mockup measurements */
const CARD_X = [304, 492, 680, 868, 1056];
---
<Bare
  title="Index"
  description="Matt Mattei's public notebook: ideas, experiments, sketches, software, and lessons at the intersection of design and development.">

<div id="fit">
  <div class="camera" id="camera">
  <div class="scene" id="scene">

    <a class="logo" href="/" aria-label="Matt Mattei — home">
      <Logo height={62} />
    </a>

    <h1 aria-label="Design what connects.">
      <span class="t hl" id="hl1" data-x="84" data-w="123" data-captop="229">DESIGN</span>
      <span class="t hl" id="hl2" data-x="84" data-w="97"  data-captop="302">WHAT</span>
      <span class="t hl" id="hl3" data-x="86" data-w="187" data-captop="372">CONNECTS.</span>
    </h1>

    <p class="t para">Ideas, experiments, and lessons<br>learned along the way.<br>Some take shape. Some simply<br>remain ideas.</p>

    <div class="t lbl" style="left:86px; top:608px; line-height:17px;">SCROLL<br>TO EXPLORE</div>
    <div class="scroll-arrow"></div>

    <div class="t lbl" style="left:1383px; top:405px; line-height:18px;">SWIPE<br>TO CHANGE</div>

    <div class="shelf"><img src="/landing/shelf.png" alt=""></div>
    <div class="tv" id="tv" role="button" tabindex="0" aria-label="Step into the featured project">
      <div class="screen">
        {PROJECTS.map((p, i) => (
          <span class:list={['art', { on: i === 0 }]} data-art={p.slug}>
            {p.slug === 'poolside' ? (
              /* the Poolside app itself, landscape: its real UI is the billboard */
              <span class="bb-app" aria-label="Poolside — the app's home screen">
                <span class="bb-rail">
                  <span class="bb-tab active"><svg viewBox="0 0 24 24"><path d="M12 3 C8.5 8 7 10.5 7 13.5 a5 5 0 0 0 10 0 C17 10.5 15.5 8 12 3 Z"/></svg><i></i></span>
                  <span class="bb-tab"><svg viewBox="0 0 24 24"><path d="M3.5 16.5 9 11l4 4 7-7.5M15.5 7.5H20V12"/></svg></span>
                  <span class="bb-tab"><svg viewBox="0 0 24 24"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v15.5H6.5A2.5 2.5 0 0 0 4 21z"/><path d="M4 18.5A2.5 2.5 0 0 1 6.5 16H20"/></svg></span>
                  <span class="bb-tab"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3.6"/><path d="M5 20c.8-3.6 3.6-5.5 7-5.5s6.2 1.9 7 5.5"/></svg></span>
                </span>
                <span class="bb-main">
                  <span class="bb-head">
                    <span class="bb-greet">
                      <span class="bb-gsub">Good morning</span>
                      <span class="bb-gname">Backyard Pool</span>
                    </span>
                    <span class="bb-wpill">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4" fill="#eebb55" stroke="none"/><g stroke="#e0a63f" stroke-width="1.6" stroke-linecap="round"><path d="M12 2.8v2.4M12 18.8v2.4M2.8 12h2.4M18.8 12h2.4M5.2 5.2l1.7 1.7M17.1 17.1l1.7 1.7M5.2 18.8l1.7-1.7M17.1 6.9l1.7-1.7"/></g></svg>
                      Sunny · 24°
                    </span>
                  </span>
                  <span class="bb-water">
                    <Plate slug="poolside" />
                    <canvas id="bbwater" aria-hidden="true"></canvas>
                    <span class="bb-pill"><i></i>Crystal clear</span>
                    <span class="bb-badge"><b>97</b><em>Water clarity</em></span>
                    <span class="bb-fab"><svg viewBox="0 0 24 24"><path d="M4 8.5a2 2 0 0 1 2-2h1.6l1.2-1.8h6.4l1.2 1.8H18a2 2 0 0 1 2 2V17a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><circle cx="12" cy="12.6" r="3.2"/></svg></span>
                  </span>
                </span>
                <span class="bb-side">
                  <span class="bb-card">
                    <span class="bb-chemhead">Chemistry<em>Tested 2h ago</em></span>
                    <span class="bb-gauges">
                      <span class="bb-gauge"><span class="bb-grow"><i>pH</i><b>7.4</b><u></u></span><span class="bb-gtrack"><span class="bb-gband" style="left:35%;width:40%"></span><span class="bb-gmark" style="left:55%"></span></span></span>
                      <span class="bb-gauge"><span class="bb-grow"><i>Chlorine</i><b>2.4</b><u></u></span><span class="bb-gtrack"><span class="bb-gband" style="left:25%;width:45%"></span><span class="bb-gmark" style="left:48%"></span></span></span>
                      <span class="bb-gauge"><span class="bb-grow"><i>Alkalinity</i><b>100</b><u></u></span><span class="bb-gtrack"><span class="bb-gband" style="left:30%;width:50%"></span><span class="bb-gmark" style="left:50%"></span></span></span>
                      <span class="bb-gauge"><span class="bb-grow"><i>Stabilizer</i><b>40</b><u></u></span><span class="bb-gtrack"><span class="bb-gband" style="left:28%;width:37%"></span><span class="bb-gmark" style="left:45%"></span></span></span>
                    </span>
                  </span>
                  <span class="bb-card bb-fc">
                    <span class="bb-fchip"><svg viewBox="0 0 24 24"><path d="M3.5 16.5 9 11l4 4 7-7.5M15.5 7.5H20V12"/></svg>Forecast</span>
                    <svg class="bb-spark" viewBox="0 0 260 104" preserveAspectRatio="none">
                      <line class="fc-thresh" x1="4" y1="34" x2="256" y2="34"/>
                      <polyline class="fc-line" points="6,20 34,24 62,30 90,26 118,38 146,48 174,44 202,58"/>
                      <line class="fc-proj" x1="202" y1="58" x2="248" y2="80"/>
                      <circle class="fc-ghost" cx="248" cy="80" r="4"/>
                    </svg>
                    <span class="bb-warn">Clarity has slipped 18 points over three weeks. A shock this week holds it clear.</span>
                  </span>
                </span>
              </span>
            ) : (
              <Plate slug={p.slug} />
            )}
          </span>
        ))}
        <span class="vignette" aria-hidden="true"></span>
        <span class="sheen" aria-hidden="true"></span>
      </div>
    </div>

    <div class="swipe">
      <a class="prev" href="#prev" aria-label="Previous project">
        <svg width="9" height="15" viewBox="0 0 9 15" fill="none"><path d="M8 1 L1.5 7.5 L8 14" stroke="#1A1815" stroke-width="2.4"/></svg>
      </a>
      <a class="next" href="#next" aria-label="Next project">
        <svg width="9" height="15" viewBox="0 0 9 15" fill="none"><path d="M1 1 L7.5 7.5 L1 14" stroke="#1A1815" stroke-width="2.4"/></svg>
      </a>
    </div>

    <div class="t lbl" style="left:86px; top:808px;">FEATURED WORK</div>
    <div class="hrule" style="left:210px; top:810px; width:55px; height:1.5px;"></div>

    <div class="hrule" style="left:1234px; top:813px; width:84px; height:2px;"></div>
    <a class="t lbl viewall" href="/program/" style="left:1332px; top:806px;">VIEW ALL WORK</a>
    <span class="ne-arrow" style="left:1433px; top:806px;">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
