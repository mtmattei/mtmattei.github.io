function buildDetail(i) {
  var p = PROJECTS[i];
  dfigsTeardown();
  detail.style.background = 'radial-gradient(130% 120% at 30% 10%, ' + p.deep + ' 0%, ' + (p.base || '#060809') + ' 78%)';
  detail.style.color = p.ink;

  var no = String(i + 1).padStart(2, '0');
  var h = '';
  h += '<div class="dpanel dtitle' + (p.lede ? ' rich' : '') + '">' +
       '<div class="dnum">' + no + '</div>' +
       '<div class="dlbl">PROJECT ' + no + ' — WALKED IN</div>' +
       '<h2 class="dname" style="color:' + p.accent + '" tabindex="-1" id="dfocus">' + esc(p.name) + '</h2>' +
       '<div class="dtag">' + esc(p.tag) + '</div>' +
       (p.lede ? '<p class="dlede">' + esc(p.lede) + '</p>' : '') +
       '<div class="dmeta"><span>' + esc(p.meta || (p.iters.length + ' ITERATIONS')) + '</span><span>2026</span><span>SCROLL →</span></div>' +
       (p.facts ? '<div class="dfacts">' + p.facts.map(function (f) { return '<div class="dfact"><i></i>' + esc(f) + '</div>'; }).join('') + '</div>' : '') +
       (p.href
         ? '<a class="dposter" href="' + p.href + '"' + (p.href.indexOf('http') === 0 ? ' target="_blank" rel="noopener"' : '') + ' aria-label="Open ' + esc(p.name) + '"></a>' +
           '<a class="dopen" href="' + p.href + '"' + (p.href.indexOf('http') === 0 ? ' target="_blank" rel="noopener"' : '') + ' style="color:' + p.accent + '">' + esc(p.linkLabel || 'OPEN CASE STUDY') + ' <span aria-hidden="true">↗</span></a>'
         : '<span class="dposter"></span>') +
