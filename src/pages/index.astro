          { no: '03', title: 'The cheap path', body: 'A glyph at rest snaps to its home, skips physics, and draws with a single fillText — most of the grid, most of the time.', read: 'atRest · early continue' },
          { no: '04', title: 'Springs everywhere', body: 'Velocity damping 0.86, spring home 0.045, pointer velocity flings at 0.35, and clicks push a 9.5 impulse through the field.', read: 'DAMP · K_HOME · KICK · SHOCK' },
        ],
      },
    ],
  },
];

