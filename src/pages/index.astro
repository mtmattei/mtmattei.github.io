  width: 100%; height: 100%; display: block;
  border: 1px solid currentColor; background: var(--paper);
}
/* the lift gauge, rules reused from /poolside/ (.pl-gauge) */
.dstack-gauge {
  width: 560px; border: 1px solid var(--line); border-radius: var(--radius);
  padding: var(--s3) var(--s4) 10px; background: var(--paper);
}
.pl-gauge-top { display: flex; align-items: baseline; justify-content: space-between; gap: var(--s3); margin-bottom: 8px; }
.dstack-kicker { font-family: var(--mono); font-size: 12px; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); }
.dstack-readout { font-family: var(--mono); font-size: 12px; color: var(--accent); font-variant-numeric: tabular-nums; white-space: nowrap; }
.dstack-gauge input[type=range] {
  -webkit-appearance: none; appearance: none; width: 100%; height: 20px; background: transparent; cursor: ew-resize; margin: 0;
}
