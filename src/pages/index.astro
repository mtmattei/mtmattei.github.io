.bbe-target { position: absolute; right: 0; top: 0; width: 34px; height: 34px; border: 1.5px dashed var(--line-2); border-radius: 4px; }
.bbe-foot { font-family: var(--mono); font-size: 14px; letter-spacing: .03em; color: var(--muted); margin-top: 2px; }

/* ---- lab art: each lab shown in its own medium ---- */
