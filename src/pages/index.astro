  p.iters.forEach(function (it, n) {
    h += '<div class="dpanel diter' + (n % 2 ? ' alt' : '') + '">' +
         '<div class="dnum">' + esc(it.v.replace('V', '')) + '</div>' +
         frameHtml(p, it, 'ARTIFACT') +
         '<div class="dtext">' +
         '<div class="dv" style="color:' + p.accent + '">' + esc(it.v) + '</div>' +
         '<div class="dh">' + esc(it.title) + '</div>' +
         '<p class="dcap">' + esc(it.cap) + '</p>' +
         '<div class="drows">' + it.rows.map(function (r) { return '<span class="drow">' + esc(r).toUpperCase() + '</span>'; }).join('') + '</div>' +
         '</div></div>';
  });
  (p.post || []).forEach(function (x) { h += extraHtml(p, x); });
  h += '<div class="dpanel dend">' +
       (p.question ? '<p class="dq">' + esc(p.question) + '</p>' : '') +
       '<div class="dlbl">END OF TIMELINE</div>' +
       '<a class="dback" href="#/" style="color:' + p.accent + '">STEP BACK OUT</a>' +
       '</div><div class="dend-pad"></div>';
  railEl.innerHTML = h;

  // the poster: for poolside, a scaled clone of the real interface;
  // otherwise the project's plate, cloned from its template
  var poster = railEl.querySelector('.dposter');
  var papp = p.slug === 'poolside' ? document.querySelector('.tv .bb-app') : null;
  if (papp) {
    var pclone = papp.cloneNode(true);
    var pcv = pclone.querySelector('canvas');
    if (pcv) { pcv.removeAttribute('id'); pcv.classList.add('dfig'); pcv.dataset.fig = 'water'; }
    var wrap = document.createElement('span');
    wrap.className = 'bb-scale';
    wrap.appendChild(pclone);
    poster.appendChild(wrap);
  } else {
    var tpl = document.getElementById('plate-' + p.slug);
    if (tpl) poster.appendChild(tpl.content.cloneNode(true));
  }

  // the app panel gets the original mobile build (the #pphone template)
  var hold = railEl.querySelector('.dapp-hold');
  var phoneTpl = document.getElementById('pphone');
  if (hold && phoneTpl) hold.appendChild(phoneTpl.content.cloneNode(true));

  // the code panel gets the server-highlighted SkSL passages
  var codeHold = railEl.querySelector('.dcode-hold');
  var srcTpl = document.getElementById('psrc');
  if (codeHold && srcTpl) codeHold.appendChild(srcTpl.content.cloneNode(true));

  sfBuild();                                          // Source / Figure study plates

  // the exploded panel's holds get the phone's own sections, out of the shell
  var expHolds = railEl.querySelectorAll('.dexp-hold');
  if (expHolds.length && phoneTpl) {
    var secs = phoneTpl.content.querySelectorAll('.p-sec');
    expHolds.forEach(function (hh, n) {
      if (!secs[n]) return;
      var wrap = document.createElement('div');
      wrap.className = 'pworld lg dexp-comp';
      wrap.appendChild(secs[n].cloneNode(true));
      hh.appendChild(wrap);
    });
  }

  dfigsBuild();                                       // live stages, when the project has them

  // the exploded-view slider, wired as on the exhibit (SCALE 2.4, FADE 7)
  var sdeck = railEl.querySelector('.dstack-deck');
  var slider = railEl.querySelector('.dstack-gauge input');
  var readout = railEl.querySelector('.dstack-readout');
  if (sdeck && slider) {
    var slayers = sdeck.querySelectorAll('.pl-layer');
    var applyLift = function (E) {
      slayers.forEach(function (ly, n) {
        ly.style.transform = 'translateZ(' + (n * E * 2.4).toFixed(1) + 'px)';
        ly.style.opacity = n === 0 ? '1' : Math.max(0, Math.min(1, E / 7)).toFixed(3);
      });
      readout.textContent = 'lift ' + String(E).padStart(2, '0');
    };
    slider.addEventListener('input', function () { applyLift(+slider.value); });
    applyLift(15);
  }

  // timeline ruler: one tick per stop (title + panels + end)
  var tl = document.getElementById('dtimeline');
  var stops = ['IN']
    .concat((p.pre || []).map(function (x) { return x.label; }))
    .concat(p.iters.map(function (it) { return it.v; }))
    .concat((p.post || []).map(function (x) { return x.label; }))
    .concat(['OUT']);
  var t = '<div class="tl-rule"></div>';
  stops.forEach(function (s, n) {
    var pct = stops.length > 1 ? (n / (stops.length - 1)) * 100 : 0;
    t += '<div class="tl-tick" style="left:' + pct + '%"></div>';
    t += '<div class="tl-lbl" style="left:' + pct + '%">' + esc(s) + '</div>';
  });
  t += '<div class="tl-dot" id="tldot" style="left:0%"></div>';
  tl.innerHTML = t;

  rail.x = rail.target = 0;
  dfit();
}

function dfit() {
  if (!detail.classList.contains('on')) return;
  var ds = innerHeight / 1024;
  rail.width = railEl.scrollWidth;
  rail.max = Math.max(0, rail.width * ds - innerWidth) / ds;   // in world px
  rail.centers = [];
  railEl.querySelectorAll('.dpanel').forEach(function (el) {
    rail.centers.push(Math.min(rail.max, Math.max(0, el.offsetLeft + el.offsetWidth / 2 - (innerWidth / ds) / 2)));
  });
  applyRail(ds);
}
function applyRail(ds) {
  ds = ds || innerHeight / 1024;
  dcam.style.transform = 'scale(' + ds + ') translate3d(' + (-rail.x) + 'px,0,0)';
  var dot = document.getElementById('tldot');
  if (dot) dot.style.left = (rail.max ? Math.min(1, Math.max(0, rail.x / rail.max)) : 0) * 100 + '%';
}
addEventListener('resize', dfit);

// ---- rail input: wheel / drag / keys, smoothing, idle snap, edge exit ----
var railInput = {
  lastInput: 0, dragging: false, dragX: 0, dragStart: 0,
  raf: null, EXIT_TRIGGER: 200, RESIST: .35
};
function railWake() {
  railInput.lastInput = performance.now();
  if (!railInput.raf) railTick();
}
function railTick() {
  var r = rail, ri = railInput;
  var idle = performance.now() - ri.lastInput > 150;
  if (idle && !ri.dragging) {
    if (r.target < 0) {
      // released in the overscroll zone: exit if past the threshold, else spring home
      if (r.target < -ri.EXIT_TRIGGER && state.mode === 'detail') { location.hash = '#/'; r.target = 0; }
      else r.target += (0 - r.target) * .12;
    } else if (r.centers.length) {
      var best = r.centers[0];
      r.centers.forEach(function (c) { if (Math.abs(c - r.target) < Math.abs(best - r.target)) best = c; });
      r.target += (best - r.target) * .06;     // gentle magnet, free while scrolling
    }
  }
  r.target = Math.min(r.target, r.max + 80);
  r.x += (r.target - r.x) * (reduceMotion ? 1 : .12);
  applyRail();
  if (Math.abs(r.target - r.x) > .1 || !idle || ri.dragging) railInput.raf = requestAnimationFrame(railTick);
  else { railInput.raf = null; r.x = r.target; applyRail(); }
}
detail.addEventListener('wheel', function (e) {
  if (state.mode !== 'detail') return;
  e.preventDefault();
  var d = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
  if (rail.target + d < 0) d *= railInput.RESIST;             // resistance before the edge exit
  rail.target = Math.max(-railInput.EXIT_TRIGGER - 60, Math.min(rail.max + 80, rail.target + d));
  railWake();
}, { passive: false });
detail.addEventListener('pointerdown', function (e) {
  if (state.mode !== 'detail' || e.target.closest('a') || e.target.closest('input') || e.target.closest('video')) return;
  railInput.dragging = true; railInput.dragX = e.clientX; railInput.dragStart = rail.target;
  detail.classList.add('grabbing');
  detail.setPointerCapture(e.pointerId);
  railWake();
});
detail.addEventListener('pointermove', function (e) {
  if (!railInput.dragging) return;
  var ds = innerHeight / 1024;
  var d = (railInput.dragX - e.clientX) / ds;
  var t = railInput.dragStart + d;
  if (t < 0) t *= railInput.RESIST;
  rail.target = Math.max(-railInput.EXIT_TRIGGER - 60, Math.min(rail.max + 80, t));
  railWake();
});
['pointerup', 'pointercancel'].forEach(function (ev) {
  detail.addEventListener(ev, function () {
    railInput.dragging = false;
    detail.classList.remove('grabbing');
    railWake();
  });
});
document.addEventListener('keydown', function (e) {
  if (state.mode !== 'detail') return;
  var i, cur = rail.centers.indexOf(rail.centers.reduce(function (a, b) {
    return Math.abs(b - rail.target) < Math.abs(a - rail.target) ? b : a;
  }, rail.centers[0] || 0));
  if (e.key === 'ArrowRight') { i = Math.min(rail.centers.length - 1, cur + 1); rail.target = rail.centers[i]; railWake(); }
  if (e.key === 'ArrowLeft')  { i = Math.max(0, cur - 1); rail.target = rail.centers[i]; railWake(); }
});

// ---- walk-through transition ----
var reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

function cubicBezier(x1, y1, x2, y2) {
  function f(t, a, b) { var o = 1 - t; return 3*o*o*t*a + 3*o*t*t*b + t*t*t; }
  return function (x) {
    if (x <= 0) return 0; if (x >= 1) return 1;
    var t = x;
    for (var i = 0; i < 6; i++) {
      var cx = f(t, x1, x2) - x;
      var dx = 3*(1-t)*(1-t)*x1 + 6*(1-t)*t*(x2-x1) + 3*t*t*(1-x2);
      if (Math.abs(dx) < 1e-6) break;
      t -= cx / dx;
      t = Math.max(0, Math.min(1, t));
    }
    return f(t, y1, y2);
  };
}
var easePush = cubicBezier(.7, 0, .3, 1);

var pushAnim = null, transTimers = [];
function animatePush(to, dur, done) {
  if (pushAnim) cancelAnimationFrame(pushAnim);
  var from = camState.push, t0 = performance.now();
  cam.style.willChange = 'transform';
  function tick(now) {
    var t = Math.min(1, (now - t0) / dur);
    camState.push = from + (to - from) * easePush(t);
    applyCamera();
    if (t < 1) { pushAnim = requestAnimationFrame(tick); }
    else {
      pushAnim = null; cam.style.willChange = '';
      if (done) done();
    }
  }
  pushAnim = requestAnimationFrame(tick);
}
function clearTransTimers() { transTimers.forEach(clearTimeout); transTimers = []; }

var scene = document.getElementById('scene');

function animEnter(i) {
  state.mode = 'entering';
  scrollTo({ top: 0, behavior: 'instant' });   // the push is composed on the hero
  setFeatured(i);
  buildDetail(i);
  clearTransTimers();
  document.body.classList.add('walked');
  scene.classList.add('pushing');
  detail.style.willChange = 'opacity, transform';

  function arrive() {
    detail.classList.add('on');
    dfit();
    void detail.offsetWidth;                 // commit start state before transitioning
    detail.classList.add('in');
  }
  function settle() {
    state.mode = 'detail';
    if (!reduceMotion) { camState.push = 1; applyCamera(); }  // deterministic even if rAF was throttled
    detail.style.willChange = '';
    var f = document.getElementById('dfocus');
    if (f) f.focus({ preventScroll: true });
    route();                                 // catch hash changes made mid-transition
  }
  if (reduceMotion) {
    arrive();
    transTimers.push(setTimeout(settle, 260));
  } else {
    animatePush(1, 850, null);
    transTimers.push(setTimeout(arrive, 450));
    transTimers.push(setTimeout(settle, 870));
  }
}

function animExit() {
  state.mode = 'exiting';
  clearTransTimers();
  detail.classList.remove('in');            // recede + fade (250ms)
  detail.style.willChange = 'opacity, transform';

  function land() {
    state.mode = 'landing';
    camState.push = 0; applyCamera();        // deterministic even if rAF was throttled
    document.body.classList.remove('walked');
    scene.classList.remove('pushing');
    detail.classList.remove('on');
    detail.style.willChange = '';
    var row = document.querySelector('.prow.selected');
    if (row) row.focus({ preventScroll: true });
    route();
    bbWake();
  }
  if (reduceMotion) {
    scene.classList.remove('pushing');
    transTimers.push(setTimeout(land, 260));
  } else {
    animatePush(0, 650, null);
    transTimers.push(setTimeout(function () { scene.classList.remove('pushing'); }, 300));
    transTimers.push(setTimeout(land, 670));
  }
}

// ---- router: #/ landing, #/p/{slug} detail ----
function currentRoute() {
  var m = location.hash.match(/^#\/p\/([a-z-]+)$/);
  if (!m) return -1;
  for (var i = 0; i < PROJECTS.length; i++) if (PROJECTS[i].slug === m[1]) return i;
  return -1;
}
function route(initial) {
  var i = currentRoute();
  if (state.mode === 'entering' || state.mode === 'exiting') return;  // re-checked on completion
  if (i >= 0 && state.mode === 'landing') {
    if (initial) {                            // deep link: no motion
      state.mode = 'detail';
      setFeatured(i); buildDetail(i);
      document.body.classList.add('walked');
      scene.classList.add('pushing');
      camState.push = 1; applyCamera();
      detail.classList.add('on'); detail.classList.add('in');
      dfit();
    } else animEnter(i);
  } else if (i < 0 && state.mode === 'detail') {
    animExit();
  } else if (i >= 0 && state.mode === 'detail' && i !== state.featured) {
    setFeatured(i); buildDetail(i);          // project switch while inside: rebuild in place
  }
}
addEventListener('hashchange', function () { route(false); });

function enterProject(i) { location.hash = '#/p/' + PROJECTS[i].slug; }
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape' && state.mode === 'detail') location.hash = '#/';
});

// ---- side rail: strip toggles the nav; leaving the rail closes it ----
var lrail = document.getElementById('lrail');
var lrailStrip = document.getElementById('lrailStrip');
function lrailSet(open) {
  lrail.classList.toggle('open', open);
  lrailStrip.setAttribute('aria-expanded', String(open));
  lrailStrip.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
}
lrailStrip.addEventListener('click', function () { lrailSet(!lrail.classList.contains('open')); });
lrail.addEventListener('pointerleave', function () { lrailSet(false); });
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape' && state.mode === 'landing' && lrail.classList.contains('open')) lrailSet(false);
});
route(true);
bbWake();

// ---- room tone: generated, never autoplayed ----
var sound = document.getElementById('sound');
var sndState = document.getElementById('sndState');
var actx = null, gain = null;
sound.addEventListener('click', function () {
  var on = sound.getAttribute('aria-checked') !== 'true';
  sound.setAttribute('aria-checked', String(on));
  sndState.textContent = on ? 'ON' : 'OFF';
  if (!actx && on) {
    actx = new AudioContext();
    /* filtered noise: the room the plates are hung in */
    var len = actx.sampleRate * 4;
    var buf = actx.createBuffer(1, len, actx.sampleRate);
    var d = buf.getChannelData(0);
    var last = 0;
    for (var i = 0; i < len; i++) {
      var white = Math.random() * 2 - 1;
      last = (last + 0.02 * white) / 1.02;
      d[i] = last * 3.5;
    }
    var src = actx.createBufferSource();
    src.buffer = buf; src.loop = true;
    var lp = actx.createBiquadFilter();
    lp.type = 'lowpass'; lp.frequency.value = 520; lp.Q.value = 0.6;
    gain = actx.createGain(); gain.gain.value = 0;
    src.connect(lp).connect(gain).connect(actx.destination);
    src.start();
  }
  if (actx && gain) {
    actx.resume();
    gain.gain.cancelScheduledValues(actx.currentTime);
    gain.gain.linearRampToValueAtTime(on ? 0.06 : 0, actx.currentTime + 0.6);
  }
});

// headline calibration: pin each line's ink box exactly onto the measured mockup box
function calibrate() {
  document.querySelectorAll('.hl').forEach(function (el) {
    var cs = getComputedStyle(el);
    var fs = parseFloat(cs.fontSize);
    var lh = parseFloat(cs.lineHeight);
    var g = document.createElement('canvas').getContext('2d');
    g.font = cs.fontWeight + ' ' + fs + 'px ' + cs.fontFamily;
    var m = g.measureText(el.textContent);
    var capAsc = m.actualBoundingBoxAscent;
    var inkW = m.actualBoundingBoxLeft + m.actualBoundingBoxRight;
    var fbAsc = m.fontBoundingBoxAscent, fbDesc = m.fontBoundingBoxDescent;
    var targetW = parseFloat(el.dataset.w);
    var targetCapTop = parseFloat(el.dataset.captop);
    var targetCapH = 60;
    var sx = targetW / inkW, sy = targetCapH / capAsc;
    var baselineLocal = (lh - (fbAsc + fbDesc)) / 2 + fbAsc;
    var inkTopLocal = baselineLocal - capAsc;
    el.style.left = el.dataset.x + 'px';
    el.style.top = (targetCapTop - inkTopLocal * sy) + 'px';
    el.style.transform = 'scale(' + sx + ',' + sy + ')';
  });
}
document.fonts.ready.then(calibrate);
</script>
