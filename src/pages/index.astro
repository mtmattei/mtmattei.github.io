.bbe-axis { stroke: var(--muted); stroke-width: .8; }
.bbe-linear { stroke: var(--line-2); stroke-width: .8; stroke-dasharray: 3 3; fill: none; }
.bbe-handle { stroke: var(--accent); stroke-width: .8; }
.bbe-cp { fill: var(--accent); }
.bbe-curve { stroke: var(--ink); stroke-width: 1.6; fill: none; }
.bbe-marker { fill: var(--ink); }
.bbe-lbl { font-family: var(--mono); font-size: 7px; fill: var(--muted); }
.bbe-rails { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; gap: 34px; }
.bbe-rail { display: flex; flex-direction: column; gap: 12px; }
.bbe-tag { font-family: var(--mono); font-size: 14px; letter-spacing: .04em; color: var(--muted); }
.bbe-track { position: relative; display: block; height: 34px; }
.bbe-track::before { content: ""; position: absolute; left: 0; right: 0; top: 50%; height: 1px; background: var(--line-2); }
.bbe-tile { position: absolute; left: 0; top: 0; width: 34px; height: 34px; border-radius: 4px; }
.bbe-tile.ink { background: var(--ink); }
