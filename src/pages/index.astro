  flex: none; width: 560px; height: 560px;
  perspective: 1250px; perspective-origin: 50% 44%;
  display: flex; align-items: center; justify-content: center;
}
.dstack-deck {
  position: relative; width: 420px; height: 420px;
  transform-style: preserve-3d;
  transform: rotateX(54deg) rotateZ(-32deg);
}
.dstack-col { flex: none; display: flex; flex-direction: column; gap: 12px; }
.dstack-deck .pl-layer {
  position: absolute; inset: 0;
  transition: transform .4s cubic-bezier(.22,.8,.3,1), opacity .4s ease;
}
