<style is:global>
/* the landing draws with the site's tokens; type is BigShoulders (display),
   Instrument Sans (body, via global.css), IBM Plex Mono (ticks + numerals) */
@font-face {
  font-family: 'BigShoulders';
  font-style: normal;
  font-weight: 800;
  font-display: swap;
  src: url('/fonts/big-shoulders-800.woff2') format('woff2');
}

/* the pushed-in camera's transformed bounds overflow the document; clip (not
   hide) so no scrollable region exists at all — not even programmatically */
html, body { overflow: clip; }
body {
  background: radial-gradient(115% 115% at 50% 46%, #EFE9E2 0%, #F2EDE8 52%, #F6F2EE 82%, #F8F6F3 100%) fixed;
  font-size: 16px;
  line-height: normal;
}
#fit { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; overflow: clip; }
.camera { width: 1536px; height: 1024px; flex: none; transform-origin: center center; }
.scene { position: relative; width: 1536px; height: 1024px; }
.grain { position: fixed; inset: 0; z-index: 5; pointer-events: none; background-image: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='240' height='240'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3CfeComponentTransfer%3E%3CfeFuncA type='linear' slope='0.055'/%3E%3C/feComponentTransfer%3E%3C/filter%3E%3Crect width='240' height='240' filter='url(%23n)'/%3E%3C/svg%3E"); }
.t { position: absolute; color: var(--ink); white-space: nowrap; }
/* the mockup ran on a global margin reset; scope it to the stage */
.scene h1, .scene p, #detail h2, #detail p { margin: 0; }
.scene img, .scene svg { user-select: none; -webkit-user-drag: none; }

/* ---- logo: the M mark, in place of the mockup's studio logo ---- */
.logo { position: absolute; left: 62px; top: 42px; display: block; color: var(--ink); }

/* ---- side rail: the Shell's collapsed rail, incorporated on the stage ---- */
.lrail { position: fixed; left: 0; top: 0; bottom: 0; z-index: 6; display: flex; transition: opacity .2s ease-out; }
body.walked .lrail { opacity: 0; pointer-events: none; }
.lrail-strip {
  width: 34px; border: 0; border-right: var(--bw) solid var(--line);
  background: rgba(246,242,238,.55); cursor: pointer;
  display: flex; justify-content: center; align-items: flex-start; padding-top: var(--s6);
  transition: background .15s;
}
.lrail-strip:hover { background: var(--gray-1); }
.lrail-label {
  writing-mode: vertical-rl;
  font-family: var(--mono); font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--muted); transition: color .15s;
}
.lrail-strip:hover .lrail-label, .lrail.open .lrail-label { color: var(--ink); }
.lnav {
  position: absolute; left: 34px; top: 0; bottom: 0; width: 236px;
  background: var(--paper); border-right: var(--bw) solid var(--line);
  box-shadow: 22px 0 44px -30px rgba(26,24,21,.4);
  padding: var(--s6) 0; overflow-y: auto;
  transform: translateX(-10px); opacity: 0; pointer-events: none; visibility: hidden;
  transition: transform .22s cubic-bezier(.22,1,.36,1), opacity .18s ease-out, visibility .22s;
}
.lrail.open .lnav { transform: none; opacity: 1; pointer-events: auto; visibility: visible; }
.lnav-g + .lnav-g { margin-top: var(--s4); }
.lnav-k {
  display: block; padding: 0 var(--s4); margin-bottom: var(--s2);
  font-family: var(--mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
  color: var(--muted);
}
.lnav-i {
  display: flex; align-items: center; gap: var(--s3);
  padding: 7px var(--s4); font-size: 14px; color: var(--ink); text-decoration: none;
  transition: background .15s;
}
.lnav-i:hover { background: var(--gray-1); }
.ltick { width: 2px; height: 14px; border-radius: 1px; background: transparent; flex: none; }
.lnav-i.is-active .ltick { background: var(--accent); }
.lnav-quiet .lnav-i { opacity: .62; }
.lnav-quiet .lnav-i:hover { opacity: 1; }

/* ---- headline ---- */
.hl {
  left: 84px; font-family: 'BigShoulders', sans-serif; font-weight: 800;
  font-size: 83px; line-height: 1; letter-spacing: 0;
  -webkit-text-stroke: 1.4px var(--ink);
  transform-origin: left top;
}

/* ---- paragraph ---- */
.para {
  left: 86px; top: 470px; font-size: 15.5px; line-height: 22.6px;
  font-weight: 400; color: var(--ink); letter-spacing: .1px;
}

/* ---- small labels ---- */
.lbl { font-size: 10px; font-weight: 600; letter-spacing: 1.8px; color: var(--ink); }
.lbl b { font-weight: 600; }
a.viewall { text-decoration: none; }
a.viewall:hover { opacity: .65; }

/* scroll arrow */
.scroll-arrow { position: absolute; left: 89px; top: 646px; width: 1.5px; height: 40px; background: var(--ink); }
.scroll-arrow::after {
  content: ''; position: absolute; left: -4.4px; bottom: 1.4px;
  width: 8px; height: 8px;
  border-right: 1.5px solid var(--ink); border-bottom: 1.5px solid var(--ink);
  transform: rotate(45deg);
}

/* featured / view-all rules */
.hrule { position: absolute; height: 1px; background: #BCB8B4; }
.ne-arrow { position: absolute; width: 14px; height: 14px; }
.ne-arrow svg { display: block; }

/* ---- shelf + billboard ---- */
.shelf { position: absolute; left: 285px; top: 606px; }
.shelf img { display: block; width: 1055px; height: 156px; }
.tv {
  position: absolute; left: 342px; top: 161px; width: 944px; height: 452px;
  border-radius: 55px; padding: 5px; cursor: pointer;
  background: linear-gradient(180deg, #E7E1DB 0%, #EEE9E4 55%, #F3F0EB 100%);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.55),
    0 0 0 1px rgba(70,62,54,.10),
    0 14px 22px -10px rgba(70,58,46,.26),
    30px 22px 44px -16px rgba(88,76,64,.42),
    0 34px 54px -26px rgba(70,58,46,.20);
}
.tv .screen {
  position: relative; width: 934px; height: 442px; border-radius: 50px;
  overflow: hidden; background: var(--ink);
  box-shadow: inset 0 0 0 1px rgba(10,9,8,.92);
  transition-property: transform; transition-duration: .2s; transition-timing-function: ease-out;
}
.tv .art {
  position: absolute; inset: 0;
  opacity: 0; transform: scale(1.02);
  transition: opacity .32s cubic-bezier(.22,1,.36,1), transform .32s cubic-bezier(.22,1,.36,1);
}
.tv .art.on { opacity: 1; transform: none; }
/* ---- poolside billboard: the app's real UI in landscape ----
   Inks are the app's own (--lg-* on /poolside/); Fraunces carries display
   numbers. The water surface runs the app's WebGL shader; the plate
   underneath it is the no-WebGL fallback. */
.bb-app {
  --bb-ink: #12333D; --bb-slate: #5F7B85; --bb-slate2: #93A8B0;
  --bb-deep: #0A6C88; --bb-sage: #57B394; --bb-line: rgba(60,52,40,.11);
  position: absolute; inset: 0; display: flex;
  background: linear-gradient(170deg, #F2EDE3, #E9E3D6);
  font-family: 'Instrument Sans', system-ui, sans-serif; color: var(--bb-ink);
  text-align: left;
}
.bb-rail {
  width: 64px; flex: none; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 34px;
  border-right: 1px solid var(--bb-line);
}
.bb-tab { position: relative; color: var(--bb-slate2); }
.bb-tab svg { display: block; width: 24px; height: 24px; fill: none; stroke: currentColor; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
.bb-tab.active { color: var(--bb-deep); }
.bb-tab.active i { position: absolute; left: 50%; bottom: -9px; width: 4px; height: 4px; border-radius: 50%; background: var(--bb-deep); transform: translateX(-50%); }
.bb-main { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; padding: 24px 24px 26px 28px; }
.bb-head { display: flex; align-items: flex-start; justify-content: space-between; padding-bottom: 18px; }
.bb-gsub { display: block; font-size: 13px; font-weight: 500; color: var(--bb-slate2); }
.bb-gname { display: block; font-family: 'Fraunces', serif; font-weight: 400; font-size: 30px; line-height: 1.1; letter-spacing: -.3px; }
.bb-wpill {
  display: inline-flex; align-items: center; gap: 7px; margin-top: 4px;
  font-size: 12px; font-weight: 600; color: var(--bb-slate);
  background: rgba(255,255,255,.6); border: 1px solid var(--bb-line);
  border-radius: 999px; padding: 6px 12px;
}
.bb-wpill svg { width: 15px; height: 15px; display: block; }
.bb-water { position: relative; flex: 1 1 auto; border-radius: 18px; overflow: hidden; background: #0E3444; box-shadow: inset 0 0 0 1px rgba(18,51,61,.35); }
.bb-water .plate, .bb-water canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
.bb-pill {
  position: absolute; left: 14px; top: 13px; display: inline-flex; align-items: center; gap: 7px;
  font-size: 12px; font-weight: 600; color: var(--bb-ink);
  background: rgba(255,255,255,.88); border-radius: 999px; padding: 6px 12px;
}
.bb-pill i { width: 7px; height: 7px; border-radius: 50%; background: var(--bb-sage); display: block; }
.bb-badge { position: absolute; left: 16px; bottom: 12px; color: #fff; }
.bb-badge b { display: block; font-family: 'Fraunces', serif; font-weight: 300; font-size: 46px; line-height: .9; }
.bb-badge em { display: block; font-style: normal; font-size: 12px; font-weight: 500; letter-spacing: .2px; opacity: .92; }
.bb-fab {
  position: absolute; right: 14px; bottom: 12px; width: 40px; height: 40px; border-radius: 50%;
  background: var(--bb-deep); display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8px 16px -8px rgba(10,58,74,.7);
}
.bb-fab svg { width: 18px; height: 18px; stroke: #fff; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
.bb-side { width: 292px; flex: none; display: flex; flex-direction: column; gap: 14px; padding: 24px 24px 26px 0; }
.bb-card {
  background: rgba(255,255,255,.55); border: 1px solid var(--bb-line);
  border-radius: 16px; padding: 14px 16px;
}
.bb-chemhead { display: flex; align-items: baseline; justify-content: space-between; font-size: 11px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; color: var(--bb-slate); }
.bb-chemhead em { font-style: normal; font-size: 10.5px; font-weight: 500; letter-spacing: .2px; text-transform: none; color: var(--bb-slate2); }
.bb-gauges { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 18px; margin-top: 12px; }
.bb-grow { display: flex; align-items: baseline; gap: 6px; }
.bb-grow i { font-style: normal; font-size: 11.5px; font-weight: 500; color: var(--bb-slate); }
.bb-grow b { margin-left: auto; font-family: 'Fraunces', serif; font-weight: 400; font-size: 19px; }
.bb-grow u { width: 6px; height: 6px; border-radius: 50%; background: var(--bb-sage); }
.bb-gtrack { position: relative; display: block; margin-top: 7px; height: 5px; border-radius: 3px; background: rgba(60,52,40,.1); }
.bb-gband { position: absolute; top: 0; bottom: 0; border-radius: 3px; background: rgba(87,179,148,.4); }
.bb-gmark { position: absolute; top: 50%; width: 10px; height: 10px; border-radius: 50%; transform: translate(-50%,-50%); background: var(--bb-sage); box-shadow: 0 0 0 2px rgba(255,255,255,.85); }
.bb-fc { flex: 1 1 auto; display: flex; flex-direction: column; }
.bb-fchip { display: inline-flex; align-items: center; gap: 7px; font-size: 10.5px; font-weight: 700; letter-spacing: .9px; text-transform: uppercase; color: var(--bb-deep); }
.bb-fchip svg { width: 13px; height: 13px; stroke: var(--bb-deep); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
