/* the exploded shader deck, values reused from /poolside/ (.pl-stage/.pl-deck):
   perspective 1250 at 50% 44%, deck 420px, rotateX(54) rotateZ(-32),
   lift 15 x SCALE 2.4 -> translateZ steps of 36px (inline per layer) */
.dstack { width: 1280px; padding: 88px 0 0 60px; }
