<style is:global>
/* the landing draws with the site's tokens; type is BigShoulders (display),
   Instrument Sans (body, via global.css), IBM Plex Mono (ticks + numerals) */
@font-face {
  font-family: 'BigShoulders';
  font-style: normal;
  font-weight: 800;
  font-display: swap;
  src: url('/fonts/big-shoulders-800.woff2') format('woff2');
}

/* the pushed-in camera's transformed bounds overflow the document; clip (not
   hide) so no scrollable region exists at all — not even programmatically */
/* the pushed-in camera overflows sideways, so x stays clipped; y scrolls,
   because the index runs past the hero */
html, body { overflow-x: clip; }
/* the stage's own type metrics; the ground itself comes from global.css.
   Astro leaves body selectors unscoped, so a background here would silently
   override the site ground - it did, until this was split out. */
body { font-size: 16px; line-height: normal; }
#fit { position: relative; display: flex; align-items: flex-start; justify-content: center; }
/* 1024 of hero, then the index: the camera scales from the top edge so the
   hero still meets the viewport exactly and the rest falls below the fold */
.camera { width: 1536px; height: 1640px; flex: none; transform-origin: top center; }
.scene { position: relative; width: 1536px; height: 1640px; }
.t { position: absolute; color: var(--ink); white-space: nowrap; }
/* the mockup ran on a global margin reset; scope it to the stage */
.scene h1, .scene p, #detail h2, #detail p { margin: 0; }
.scene img, .scene svg { user-select: none; -webkit-user-drag: none; }



/* ---- side rail: the Shell's collapsed rail, incorporated on the stage ---- */
.lrail { position: fixed; left: 0; top: 0; bottom: 0; z-index: 6; display: flex; flex-direction: column; transition: opacity .2s ease-out; }
.lrail-logo {
  width: 34px; display: flex; justify-content: center; padding: 13px 0 11px;
  color: var(--ink); background: rgba(246,242,238,.55);
  border-right: var(--bw) solid var(--line);
}
.lrail-logo:hover { background: var(--gray-1); }
body.walked .lrail { opacity: 0; pointer-events: none; }
.lrail-strip {
  width: 34px; flex: 1 1 auto; border: 0; border-right: var(--bw) solid var(--line);
  background: rgba(246,242,238,.55); cursor: pointer;
  display: flex; justify-content: center; align-items: flex-start; padding-top: var(--s6);
  transition: background .15s;
}
.lrail-strip:hover { background: var(--gray-1); }
.lrail-label {
  writing-mode: vertical-rl;
  font-family: var(--mono); font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--muted); transition: color .15s;
}
.lrail-strip:hover .lrail-label, .lrail.open .lrail-label { color: var(--ink); }
.lnav {
  position: absolute; left: 34px; top: 0; bottom: 0; width: 236px;
  background: var(--paper); border-right: var(--bw) solid var(--line);
  box-shadow: 22px 0 44px -30px rgba(26,24,21,.4);
  padding: var(--s6) 0; overflow-y: auto;
  transform: translateX(-10px); opacity: 0; pointer-events: none; visibility: hidden;
  transition: transform .22s cubic-bezier(.22,1,.36,1), opacity .18s ease-out, visibility .22s;
}
.lrail.open .lnav { transform: none; opacity: 1; pointer-events: auto; visibility: visible; }
.lnav-g + .lnav-g { margin-top: var(--s4); }
.lnav-k {
  display: block; padding: 0 var(--s4); margin-bottom: var(--s2);
  font-family: var(--mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
  color: var(--muted);
}
.lnav-i {
  display: flex; align-items: center; gap: var(--s3);
  padding: 7px var(--s4); font-size: 14px; color: var(--ink); text-decoration: none;
  transition: background .15s;
}
.lnav-i:hover { background: var(--gray-1); }
.ltick { width: 2px; height: 14px; border-radius: 1px; background: transparent; flex: none; }
.lnav-i.is-active .ltick { background: var(--accent); }
.lnav-quiet .lnav-i { opacity: .62; }
.lnav-quiet .lnav-i:hover { opacity: 1; }

/* ---- headline ---- */
.hl {
  left: 84px; font-family: 'BigShoulders', sans-serif; font-weight: 800;
  font-size: 83px; line-height: 1; letter-spacing: 0;
  -webkit-text-stroke: 1.4px var(--ink);
  transform-origin: left top;
}

/* ---- paragraph ---- */
.para {
  left: 86px; top: 470px; font-size: 15.5px; line-height: 22.6px;
  font-weight: 400; color: var(--ink); letter-spacing: .1px;
}

/* ---- small labels ---- */
.lbl { font-size: 10px; font-weight: 600; letter-spacing: 1.8px; color: var(--ink); }
.lbl b { font-weight: 600; }
a.viewall { text-decoration: none; }
a.viewall:hover { opacity: .65; }
/* tactile press on the controls that are actually button-sized. Deliberately
   not on the ledger rows or the TV: 0.96 of a 1150px row is a 46px lurch,
   which reads as a glitch rather than a press. Those keep the step-right. */
a.viewall, .sound, .lrail-strip {
  transition-property: transform, opacity, background-color;
  transition-duration: .12s; transition-timing-function: ease-out;
}
a.viewall:active, .sound:active, .lrail-strip:active { transform: scale(.96); }

/* scroll arrow */
.scroll-arrow { position: absolute; left: 89px; top: 646px; width: 1.5px; height: 40px; background: var(--ink); }
.scroll-arrow::after {
  content: ''; position: absolute; left: -4.4px; bottom: 1.4px;
  width: 8px; height: 8px;
  border-right: 1.5px solid var(--ink); border-bottom: 1.5px solid var(--ink);
  transform: rotate(45deg);
}

/* featured / view-all rules */
.hrule { position: absolute; height: 1px; background: #BCB8B4; }
.ne-arrow { position: absolute; width: 14px; height: 14px; }
.ne-arrow svg { display: block; }

/* ---- shelf + billboard ---- */
.shelf { position: absolute; left: 285px; top: 606px; }
.shelf img { display: block; width: 1055px; height: 156px; }
.tv {
  position: absolute; left: 342px; top: 161px; width: 944px; height: 452px;
  border-radius: 55px; padding: 5px; cursor: pointer;
  background: linear-gradient(180deg, #E7E1DB 0%, #EEE9E4 55%, #F3F0EB 100%);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.55),
    0 0 0 1px rgba(70,62,54,.10),
    0 14px 22px -10px rgba(70,58,46,.26),
    30px 22px 44px -16px rgba(88,76,64,.42),
    0 34px 54px -26px rgba(70,58,46,.20);
}
.tv .screen {
  position: relative; width: 934px; height: 442px; border-radius: 50px;
  overflow: hidden; background: var(--ink);
  box-shadow: inset 0 0 0 1px rgba(10,9,8,.92);
  transition-property: transform; transition-duration: .2s; transition-timing-function: ease-out;
}
.tv .art {
  position: absolute; inset: 0;
  opacity: 0; transform: scale(1.02);
  transition: opacity .32s cubic-bezier(.22,1,.36,1), transform .32s cubic-bezier(.22,1,.36,1);
}
.tv .art.on { opacity: 1; transform: none; }
/* ---- featured index ----
   the lab's ledger, fitted to the band under the shelf: the four billboard
   projects drive the TV on hover, everything below is listed only. 33 rows
   do not fit 130px, so the list scrolls inside the band. */
.pindex {
  position: absolute; left: 300px; top: 792px; width: 1150px;
}
.prow {
  position: relative; display: grid; align-items: center;
  grid-template-columns: 58px 300px 300px 160px; gap: 16px;
  height: 22px; padding: 0 0 0 4px;
  font-size: 13px; line-height: 1;
  color: var(--ink); text-decoration: none;
  border-top: 1px solid transparent;
  transition-property: background-color, border-color, padding-left, opacity;
  transition-duration: .15s, .15s, .22s, .2s;
  transition-timing-function: cubic-bezier(.22,1,.36,1);
}
/* the prototype's two motions: the row under the pointer steps right, and
   everything else recedes so the list reads as one live line */
.pindex:hover .prow:not(.phdr):not(:hover) { opacity: .34; }
.prow:hover, .prow:focus-visible { padding-left: 12px; }
.prow:hover, .prow:focus-visible, .prow.selected {
  outline: none;
  background: rgba(255,255,255,.62);
  border-top-color: var(--accent);
  box-shadow: 0 1px 0 rgba(26,24,21,.14);
}
.prow:hover .pname, .prow.selected .pname { font-weight: 700; }
/* one staged sequence on load: the header rule, then the rows in order.
   Keyframes rather than transitions because it runs once and is not a
   response to input. 16ms a row - 100ms would take 2.8s across 28 of them. */
@keyframes ledgerIn {
  from { opacity: 0; transform: translateY(5px); }
  to   { opacity: 1; transform: none; }
}
.pindex { animation: ledgerIn .34s cubic-bezier(.22,1,.36,1) both; }
/* rows hold at rest until they are approached: firing all 28 on load meant
   the ~22 below the fold had long settled before anyone scrolled to them */
.prow { opacity: 0; }
.prow.in { animation: ledgerIn .42s cubic-bezier(.22,1,.36,1) both;
  animation-delay: var(--d, 0ms); }
.phdr {
  opacity: .5; font-size: 11px; letter-spacing: .12em;
  border-top: 0; background: none; pointer-events: none; margin-bottom: 4px;
}
.phdr:hover { background: none; border-top-color: transparent; box-shadow: none; }
.pno { opacity: .6; }
/* body sets oldstyle figures for running text; an index column needs lining
   and tabular ones or 001 / 028 / 2026 sit at different heights and ragged
   widths, and the column stops reading as a column */
.pno, .pmeta { font-variant-numeric: tabular-nums lining-nums; }
.pname { font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.pname::after { content: ' ↗'; font-size: .8em; opacity: 0; transition: opacity .18s ease-out; }
.prow:hover .pname::after, .prow:focus-visible .pname::after { opacity: 1; }
.ptag, .pmeta { opacity: .6; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
/* listed only: in the index, nothing to open yet */
.prow.listed { cursor: default; }
.prow.listed .pname { font-weight: 400; }
.prow.listed .pname::after { content: none; }
.prow.listed .ptag:empty::before { content: '—'; opacity: .35; }
@media (prefers-reduced-motion: reduce) {
  .pindex, .prow.in { animation: none; }
  .prow { opacity: 1; }
  a.viewall, .sound, .lrail-strip { transition-duration: .01ms; }
}
.idxhint { font-size: 9.5px; line-height: 15px; letter-spacing: 1.3px; opacity: .5; }

/* the IsoBasin construction, now only for the phone cloned into the
   Poolside world (rules reused from /poolside/) */
.b-wall {
  position: absolute; background: linear-gradient(180deg, #e3f0f2, #bcdadf);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.5), inset 0 -8px 12px -8px rgba(0,30,40,.35);
}
.b-wall.n { top: 0; left: 0; width: 100%; height: 22px; transform-origin: top center; transform: rotateX(-90deg); }
.b-wall.s { bottom: 0; left: 0; width: 100%; height: 22px; transform-origin: bottom center; transform: rotateX(90deg); }
.b-wall.w { top: 0; left: 0; width: 22px; height: 100%; transform-origin: left center; transform: rotateY(90deg); }
.b-wall.e { top: 0; right: 0; width: 22px; height: 100%; transform-origin: right center; transform: rotateY(-90deg); }
.b-floor { position: absolute; inset: 0; background: #b3d3d9; transform: translateZ(-22px); }
.b-surf {
  position: absolute; inset: 0; border-radius: 16px; overflow: hidden;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.55), inset 0 -18px 26px -18px rgba(0,20,30,.5), 0 22px 34px -26px rgba(9,80,102,.75);
}
.b-surf .plate, .b-surf canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }

/* ---- xaml billboard hero: the EasingDemo figure at billboard scale ---- */
.bb-ease {
