---
import Bare from '../layouts/Bare.astro';
import Logo from '../components/Logo.astro';
import Plate from '../components/Plate.astro';

/* The landing rebuilt from the billboard mockup (mockup-landing, SPEC.md):
   a fixed 1536×1024 stage fit-scaled to the viewport. Entering a project is
   a walk through the billboard; inside, the project reads as a horizontal
   timeline of its iterations. Exiting reverses the walk.
   Portfolio identity kept: the M mark, the Plates (art drawn by the page),
   the house blue accent for state, Instrument Sans / IBM Plex Mono. */

type Iter = { v: string; title: string; cap: string; rows: string[] };
type Proj = {
  slug: string;
  name: string;
  tag: string;
  href: string;
  /* detail-world palette: surface tone, display accent, body ink */
  deep: string;
  accent: string;
  ink: string;
  iters: Iter[];
};

const PROJECTS: Proj[] = [
  {
    slug: 'poolside', name: 'POOLSIDE', tag: 'CODE / SKIASHARP', href: '/poolside/',
    deep: '#0E3444', accent: '#2FB7BF', ink: '#EAF7F6',
    iters: [
      { v: 'V0.1', title: 'Flat water', cap: 'A sine ripple on a SkiaSharp canvas. Wrong on arrival: real water reads as weather, not as waves.', rows: ['one sine', 'sksl', 'desktop'] },
      { v: 'V0.4', title: 'Displacement', cap: 'A runtime shader bends the pool tiles instead of drawing lines on them. The surface starts refracting.', rows: ['runtime shader', 'refraction', '60fps'] },
      { v: 'V0.7', title: 'Weather states', cap: 'Calm, breeze, and rain as states of one shader. You read the water the way you read a sky.', rows: ['3 states', 'one shader', 'uno platform'] },
      { v: 'V1.0', title: 'Exhibit', cap: 'The shipped interface, exploded back to its source. Every figure on the project page is drawn by the code that ships.', rows: ['exhibit', 'shader → page', '2026'] },
    ],
  },
  {
    slug: 'source-figure', name: 'SOURCE / FIGURE', tag: 'DESIGN / SYSTEM', href: '/source-figure/',
    deep: '#151A2B', accent: '#6F87EE', ink: '#EFF2FA',
    iters: [
      { v: 'V0.1', title: 'The draft program', cap: 'portfolio() written before any layout existed. The sitemap is the source; the pages are its output.', rows: ['portfolio()', 'source first'] },
      { v: 'V0.4', title: 'Typeset by source', cap: 'The name set by its own code: the hero draws its own toString(), glyph boxes measured and pinned.', rows: ['self-typeset', 'measured boxes'] },
      { v: 'V0.7', title: 'Plates', cap: 'Each project’s artwork drawn as SVG by the page that hangs it. No photography, no stock, no exports.', rows: ['5 plates', 'svg only'] },
      { v: 'V1.0', title: 'Method', cap: 'The drawing method that runs the whole site: figure follows source, and the page is the program that drew it.', rows: ['method', 'site-wide'] },
    ],
  },
  {
    slug: 'xaml-uno', name: 'XAML / UNO', tag: 'SKILLS / MOTION', href: '/xaml-uno/',
    deep: '#221E19', accent: '#C8B37E', ink: '#F4EFE8',
    iters: [
      { v: 'V0.1', title: 'Adjectives', cap: 'Motion described as smooth and snappy. Unbuildable. The fix was deciding to write numbers down instead.', rows: ['no numbers', 'unbuildable'] },
      { v: 'V0.4', title: 'House curves', cap: 'EaseSmooth 0.22,1 0.36,1. Durations 150, 200, 280. Press 0.98. The feel, fixed once as tokens.', rows: ['keyspline', '3 durations', 'press .98'] },
      { v: 'V0.7', title: 'Ten rules', cap: 'The rules that make a XAML surface read hand-built, each with the wrong version, the right version, and why.', rows: ['10 rules', 'wrong vs right'] },
      { v: 'V1.0', title: 'Skills', cap: 'Shipped as installable Claude Code skills. The taste is written down precisely enough to hand to an agent.', rows: ['npx skills add', '2 repos'] },
    ],
  },
  {
    slug: 'ledger', name: 'LEDGER', tag: 'SKILLS / OSS', href: '/ledger/',
    deep: '#26221B', accent: '#E7DECF', ink: '#F4EFE8',
    iters: [
      { v: 'V0.1', title: 'First entry', cap: 'One decision written down: what was chosen, why, and what it cost. The format followed later.', rows: ['1 entry', 'chose / why / cost'] },
      { v: 'V0.4', title: 'Append-only', cap: 'No edits, no deletions. The record keeps its mistakes on purpose; a ledger that forgets is a brochure.', rows: ['append-only', 'keeps mistakes'] },
      { v: 'V0.7', title: 'Design DNA', cap: 'Entries structured so the taste can be read back out of the record — by a person or by an agent.', rows: ['structured', 'machine-readable'] },
      { v: 'V1.0', title: 'Public', cap: 'Open sourced. The decisions behind the work, auditable by anyone who cares to check.', rows: ['open source', 'github'] },
    ],
  },
  {
    slug: 'program', name: 'PROGRAM', tag: 'RETURN / META', href: '/program/',
    deep: '#10141B', accent: '#9FB0F4', ink: '#EEF1F8',
    iters: [
      { v: 'V0.1', title: 'Sitemap as source', cap: 'The site printed as the function that draws it. Each line of the program routes a page.', rows: ['printed source', 'lines route'] },
      { v: 'V0.4', title: 'Highlight', cap: 'The printed source gains syntax color and live anchors. Reading the program is navigating the site.', rows: ['syntax color', 'live anchors'] },
      { v: 'V0.7', title: 'Return values', cap: 'contact() returns the real coordinates. The program ends where a conversation starts.', rows: ['contact()', 'returns real'] },
      { v: 'V1.0', title: 'Running', cap: 'The portfolio as it runs: this page is the output of the code it prints.', rows: ['self-hosting', '2026'] },
    ],
  },
];

/* client copy of the data — palette, copy, and route per project */
const CLIENT_PROJECTS = PROJECTS.map(({ slug, name, tag, href, deep, accent, ink, iters }) => ({
  slug, name, tag, href, deep, accent, ink, iters,
}));

/* landing card positions, from the mockup measurements */
const CARD_X = [304, 492, 680, 868, 1056];
---
<Bare
  title="Index"
  description="Matt Mattei's public notebook: ideas, experiments, sketches, software, and lessons at the intersection of design and development.">

<div id="fit">
  <div class="camera" id="camera">
  <div class="scene" id="scene">

    <a class="logo" href="/" aria-label="Matt Mattei — home">
      <Logo height={62} />
    </a>

    <nav aria-label="Sections">
      <a href="/"          style="left:926px;">WORK</a>
      <a href="/texts/"    style="left:1031.5px;">TEXTS</a>
      <a href="/xaml-uno/" style="left:1150.5px;">SKILLS</a>
      <a href="/program/"  style="left:1281px;">PROGRAM</a>
      <a href="/contact/"  style="left:1412px;">CONTACT</a>
      <span class="dot"></span>
    </nav>

    <h1 aria-label="We design what connects.">
      <span class="t hl" id="hl1" data-x="84" data-w="183" data-captop="229">WE DESIGN</span>
      <span class="t hl" id="hl2" data-x="84" data-w="97"  data-captop="302">WHAT</span>
      <span class="t hl" id="hl3" data-x="86" data-w="187" data-captop="372">CONNECTS.</span>
    </h1>

    <p class="t para">Digital experiences that feel<br>intentional, human, and<br>unforgettable.</p>

    <div class="t lbl" style="left:86px; top:608px; line-height:17px;">SCROLL<br>TO EXPLORE</div>
    <div class="scroll-arrow"></div>

    <div class="t lbl" style="left:1383px; top:405px; line-height:18px;">SWIPE<br>TO CHANGE</div>

    <div class="shelf"><img src="/landing/shelf.png" alt=""></div>
    <div class="tv" id="tv" role="button" tabindex="0" aria-label="Step into the featured project">
      <div class="screen">
        {PROJECTS.map((p, i) => (
          <span class:list={['art', { on: i === 0 }]} data-art={p.slug}><Plate slug={p.slug} /></span>
        ))}
        <span class="vignette" aria-hidden="true"></span>
        <span class="sheen" aria-hidden="true"></span>
      </div>
    </div>

    <div class="swipe">
      <a class="prev" href="#prev" aria-label="Previous project">
        <svg width="9" height="15" viewBox="0 0 9 15" fill="none"><path d="M8 1 L1.5 7.5 L8 14" stroke="#1A1815" stroke-width="2.4"/></svg>
      </a>
      <a class="next" href="#next" aria-label="Next project">
        <svg width="9" height="15" viewBox="0 0 9 15" fill="none"><path d="M1 1 L7.5 7.5 L1 14" stroke="#1A1815" stroke-width="2.4"/></svg>
      </a>
    </div>

    <div class="t lbl" style="left:86px; top:808px;">FEATURED WORK</div>
    <div class="hrule" style="left:210px; top:810px; width:55px; height:1.5px;"></div>

    <div class="hrule" style="left:1234px; top:813px; width:84px; height:2px;"></div>
    <a class="t lbl viewall" href="/program/" style="left:1332px; top:806px;">VIEW ALL WORK</a>
    <span class="ne-arrow" style="left:1433px; top:806px;">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M2.5 11.5 L11 3 M4.5 3 H11 V9.5" stroke="#3656D4" stroke-width="1.6"/>
      </svg>
    </span>

    {PROJECTS.map((p, i) => (
      <a
        class:list={['pcard', { selected: i === 0 }]}
        href={`#/p/${p.slug}`} data-slug={p.slug}
        style={`left:${CARD_X[i]}px; top:772px; width:176px; height:95px;`}
        aria-label={p.name}
      ><Plate slug={p.slug} /></a>
    ))}

    <div class="t quote">&ldquo;Every figure on this site is drawn by the code that describes it.&rdquo;</div>
    <span class="sig-mark"><Logo height={30} /></span>

    <span class="wave">
      <svg width="32" height="24" viewBox="0 0 32 24" fill="#1A1815">
        <rect x="0"  y="11" width="3.4" height="2"/>
        <rect x="5.4" y="11" width="2" height="2"/>
        <rect x="9.4" y="8"  width="2" height="8"/>
        <rect x="13.4" y="4" width="2" height="16"/>
        <rect x="17.4" y="1" width="2" height="22"/>
        <rect x="21.4" y="4" width="2" height="16"/>
        <rect x="25.4" y="8" width="2" height="8"/>
        <rect x="29.4" y="11" width="2" height="2"/>
      </svg>
    </span>
    <div class="t lbl" style="left:1381px; top:949px; font-size:9.5px; line-height:13px; letter-spacing:1.3px;">SOUND<br><b id="sndState">OFF</b></div>
    <button class="sound" id="sound" role="switch" aria-checked="false" aria-label="Room tone"><span class="knob"></span></button>

  </div>
  </div>
</div>
<div class="grain"></div>

<div id="detail" role="region" aria-label="Project detail">
  <div class="dcam" id="dcam"><div class="rail" id="rail"></div></div>
  <div class="dchrome">
    <a class="dexit" href="#/" id="dexit"><span class="dexit-arrow"></span>STEP BACK</a>
    <div class="dtimeline" id="dtimeline"></div>
  </div>
</div>

<!-- plates for the detail worlds: cloned into posters when a world is built -->
{PROJECTS.map((p) => (
  <template id={`plate-${p.slug}`}><Plate slug={p.slug} /></template>
))}

</Bare>

<style is:global>
/* the landing draws with the site's tokens; type is BigShoulders (display),
   Instrument Sans (body, via global.css), IBM Plex Mono (ticks + numerals) */
@font-face {
  font-family: 'BigShoulders';
  font-style: normal;
  font-weight: 800;
  font-display: swap;
  src: url('/fonts/big-shoulders-800.woff2') format('woff2');
}

/* the pushed-in camera's transformed bounds overflow the document; clip (not
   hide) so no scrollable region exists at all — not even programmatically */
html, body { overflow: clip; }
body {
  background: radial-gradient(115% 115% at 50% 46%, #EFE9E2 0%, #F2EDE8 52%, #F6F2EE 82%, #F8F6F3 100%) fixed;
  font-size: 16px;
  line-height: normal;
}
#fit { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; overflow: clip; }
.camera { width: 1536px; height: 1024px; flex: none; transform-origin: center center; }
.scene { position: relative; width: 1536px; height: 1024px; }
.grain { position: fixed; inset: 0; z-index: 5; pointer-events: none; background-image: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='240' height='240'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3CfeComponentTransfer%3E%3CfeFuncA type='linear' slope='0.055'/%3E%3C/feComponentTransfer%3E%3C/filter%3E%3Crect width='240' height='240' filter='url(%23n)'/%3E%3C/svg%3E"); }
.t { position: absolute; color: var(--ink); white-space: nowrap; }
/* the mockup ran on a global margin reset; scope it to the stage */
.scene h1, .scene p, #detail h2, #detail p { margin: 0; }
.scene img, .scene svg { user-select: none; -webkit-user-drag: none; }

/* ---- logo: the M mark, in place of the mockup's studio logo ---- */
.logo { position: absolute; left: 62px; top: 42px; display: block; color: var(--ink); }

/* ---- nav: moved to the top, real routes ---- */
.scene nav a {
  position: absolute; top: 52px; transform: translateX(-50%);
  font-size: 12.4px; font-weight: 600; letter-spacing: 1.9px;
  color: var(--ink); text-decoration: none; line-height: 20px;
  transition-property: opacity; transition-duration: .15s; transition-timing-function: ease-out;
}
.scene nav a:hover { opacity: .65; }
.scene nav a::after { content: ''; position: absolute; inset: -10px -14px; }
.scene nav .dot { position: absolute; left: 926px; top: 84px; width: 7px; height: 7px; border-radius: 50%; background: var(--accent); transform: translateX(-50%); }

/* ---- headline ---- */
.hl {
  left: 84px; font-family: 'BigShoulders', sans-serif; font-weight: 800;
  font-size: 83px; line-height: 1; letter-spacing: 0;
  -webkit-text-stroke: 1.4px var(--ink);
  transform-origin: left top;
}

/* ---- paragraph ---- */
.para {
  left: 86px; top: 470px; font-size: 15.5px; line-height: 22.6px;
  font-weight: 400; color: var(--ink); letter-spacing: .1px;
}

/* ---- small labels ---- */
.lbl { font-size: 10px; font-weight: 600; letter-spacing: 1.8px; color: var(--ink); }
.lbl b { font-weight: 600; }
a.viewall { text-decoration: none; }
a.viewall:hover { opacity: .65; }

/* scroll arrow */
.scroll-arrow { position: absolute; left: 89px; top: 646px; width: 1.5px; height: 40px; background: var(--ink); }
.scroll-arrow::after {
  content: ''; position: absolute; left: -4.4px; bottom: 1.4px;
  width: 8px; height: 8px;
  border-right: 1.5px solid var(--ink); border-bottom: 1.5px solid var(--ink);
  transform: rotate(45deg);
}

/* featured / view-all rules */
.hrule { position: absolute; height: 1px; background: #BCB8B4; }
.ne-arrow { position: absolute; width: 14px; height: 14px; }
.ne-arrow svg { display: block; }

/* ---- shelf + billboard ---- */
.shelf { position: absolute; left: 285px; top: 606px; }
.shelf img { display: block; width: 1055px; height: 156px; }
.tv {
  position: absolute; left: 342px; top: 161px; width: 944px; height: 452px;
  border-radius: 55px; padding: 5px; cursor: pointer;
  background: linear-gradient(180deg, #E7E1DB 0%, #EEE9E4 55%, #F3F0EB 100%);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.55),
    0 0 0 1px rgba(70,62,54,.10),
    0 14px 22px -10px rgba(70,58,46,.26),
    30px 22px 44px -16px rgba(88,76,64,.42),
    0 34px 54px -26px rgba(70,58,46,.20);
}
.tv .screen {
  position: relative; width: 934px; height: 442px; border-radius: 50px;
  overflow: hidden; background: var(--ink);
  box-shadow: inset 0 0 0 1px rgba(10,9,8,.92);
  transition-property: transform; transition-duration: .2s; transition-timing-function: ease-out;
}
.tv:hover .screen { transform: scale(1.01); }
.tv:active .screen { transform: scale(.995); }
.tv .art {
  position: absolute; inset: 0;
  opacity: 0; transform: scale(1.02);
  transition: opacity .32s cubic-bezier(.22,1,.36,1), transform .32s cubic-bezier(.22,1,.36,1);
}
.tv .art.on { opacity: 1; transform: none; }
/* the display darkens at its perimeter and carries a light sheen */
.vignette {
  position: absolute; inset: 0; pointer-events: none; z-index: 2;
  background: radial-gradient(118% 96% at 50% 42%, rgba(0,0,0,0) 52%, rgba(0,0,0,.38) 100%);
}
.sheen {
  position: absolute; inset: 0; pointer-events: none; z-index: 3;
  background: linear-gradient(116deg,
    rgba(255,255,255,.10) 0%, rgba(255,255,255,.035) 16%,
    rgba(255,255,255,0) 34%, rgba(255,255,255,0) 100%);
}

/* ---- swipe control ---- */
.swipe {
  position: absolute; left: 1377px; top: 457px; width: 76px; height: 76px;
  border-radius: 50%;
  background: radial-gradient(120% 120% at 50% 28%, #FAF7F4 0%, #F6F2EF 58%, #F1ECE8 100%);
  box-shadow:
    0 2px 3px rgba(80,68,56,.08),
    0 10px 16px -6px rgba(80,68,56,.16),
    0 24px 32px -18px rgba(80,68,56,.15);
}
.swipe a { position: absolute; top: 0; width: 38px; height: 76px; display: flex; align-items: center; }
.swipe a.prev { left: 0; border-radius: 38px 0 0 38px; justify-content: flex-end; padding-right: 7px; }
.swipe a.next { right: 0; border-radius: 0 38px 38px 0; justify-content: flex-start; padding-left: 7px; }
.swipe svg { display: block; transition-property: transform; transition-duration: .12s; transition-timing-function: ease-out; }
.swipe a:active svg { transform: scale(.9); }

/* ---- featured cards ---- */
.pcard {
  position: absolute; display: block; border-radius: 16px; overflow: hidden;
  background: var(--ink);
  transition-property: transform, opacity; transition-duration: .12s, .2s; transition-timing-function: ease-out;
  box-shadow:
    inset 0 0 0 1px rgba(0,0,0,.1),
    0 2px 3px rgba(95,85,72,.16),
    0 5px 9px -4px rgba(95,85,72,.42);
}
.pcard:active { transform: scale(.96); }
.pcard.selected {
  box-shadow:
    0 0 0 1.5px var(--paper),
    0 0 0 4px var(--accent),
    0 2px 3px rgba(95,85,72,.16),
    0 5px 9px -4px rgba(95,85,72,.42);
}

/* ---- quote + mark ---- */
.sig-mark { position: absolute; left: 753px; top: 944px; color: var(--ink); opacity: .8; }
.quote {
  top: 927px; left: 768px; transform: translateX(-50%);
  font-style: italic; font-size: 17px; letter-spacing: .05px;
  color: var(--ink);
}

/* ---- sound: room tone, off until asked ---- */
.wave { position: absolute; left: 1344px; top: 952px; }
.sound {
  position: absolute; left: 1431px; top: 952px; width: 38px; height: 23px;
  border-radius: 11.5px; display: block; border: 0; cursor: pointer; background: #FAFAF9;
  box-shadow:
    inset 0 0 0 1px rgba(80,68,56,.05),
    0 1px 2px rgba(80,68,56,.14),
    0 4px 8px -2px rgba(80,68,56,.14);
}
.sound::after { content: ''; position: absolute; inset: -10px; border-radius: 22px; }
.sound .knob {
  position: absolute; left: 5px; top: 5px; width: 13px; height: 13px;
  border-radius: 50%; background: var(--muted);
  box-shadow: 0 1px 2px rgba(26,24,21,.30);
  transition: left .18s cubic-bezier(.22,1,.36,1), background .18s;
}
.sound[aria-checked="true"] .knob { left: 20px; background: var(--accent); }

/* ---- detail world: inside the billboard ---- */
#detail {
  position: fixed; inset: 0; z-index: 10; overflow: hidden;
  display: none; opacity: 0;
  background: #060809;
  cursor: grab;
  transform: scale(.92);
  transition-property: opacity, transform;
  transition-duration: .4s;
  transition-timing-function: cubic-bezier(.17,1,.32,1);
}
#detail.on { display: block; }
#detail.in { opacity: 1; transform: scale(1); }
#detail:not(.in) { transition-duration: .25s; }
#detail.grabbing { cursor: grabbing; }

/* landing chrome fades while the camera pushes through the billboard */
.scene > * { transition-property: opacity; transition-duration: .2s; transition-timing-function: ease-out; }
.scene.pushing > :not(.tv):not(.shelf) { opacity: 0; }
.scene.pushing > * { pointer-events: none; }

.dcam { position: absolute; left: 0; top: 0; height: 1024px; transform-origin: 0 0; }
.rail { display: flex; align-items: stretch; height: 1024px; }
.rail > * { flex: none; }

.dpanel { position: relative; height: 1024px; }
.dtitle { width: 1250px; padding: 150px 0 0 140px; }
.dnum {
  position: absolute; right: -40px; top: 70px;
  font-family: var(--mono); font-weight: 600; font-size: 460px; line-height: 1;
  opacity: .055; letter-spacing: -8px; pointer-events: none;
}
.dlbl { font-size: 11px; font-weight: 600; letter-spacing: 2.4px; opacity: .6; }
.dname {
  font-family: 'BigShoulders', sans-serif; font-weight: 800; font-size: 190px; line-height: .94;
  -webkit-text-stroke: 2.4px currentColor; margin: 18px 0 22px -8px;
}
.dname:focus { outline: none; }
.dtag { font-size: 12px; font-weight: 600; letter-spacing: 2.6px; opacity: .75; }
.dmeta { display: flex; gap: 34px; margin-top: 56px; font-family: var(--mono);
  font-size: 13px; letter-spacing: 1.6px; opacity: .55; }
.dposter { display: block; margin-top: 48px; width: 264px; height: 143px; border-radius: 14px; overflow: hidden;
  box-shadow: 0 10px 26px -8px rgba(0,0,0,.6); }
.dposter svg { display: block; width: 100%; height: 100%; }
.dopen {
  display: inline-flex; align-items: center; gap: 10px; margin-top: 30px;
  font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 2px;
  color: inherit; text-decoration: none;
  transition-property: opacity; transition-duration: .15s; transition-timing-function: ease-out;
}
.dopen:hover { opacity: .7; }

.diter { width: 920px; margin-left: 150px; }
.diter .dnum { right: auto; left: -60px; top: 40px; }
.dframe {
  position: absolute; left: 80px; width: 660px; height: 410px; border-radius: 22px;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
  overflow: hidden;
}
.diter.alt .dframe { top: 130px; }
.diter:not(.alt) .dframe { top: 420px; }
.dframe .dframe-inner {
  position: absolute; inset: 16px; border: 1px dashed currentColor; border-radius: 12px;
  opacity: .3; pointer-events: none;
}
.dframe .dframe-tag { font-size: 10px; font-weight: 600; letter-spacing: 2px; opacity: .6; }
.dframe .dframe-v { font-family: var(--mono); font-size: 44px; letter-spacing: 2px; opacity: .9; }
.dtext { position: absolute; left: 110px; width: 420px; }
.diter.alt .dtext { top: 600px; }
.diter:not(.alt) .dtext { top: 150px; }
.dv { font-family: var(--mono); font-size: 15px; letter-spacing: 2.4px; }
.dh {
  font-family: 'BigShoulders', sans-serif; font-weight: 800; font-size: 52px; line-height: 1;
  -webkit-text-stroke: 1px currentColor; margin: 14px 0 16px;
}
.dcap { font-size: 15.5px; line-height: 23.5px; opacity: .82; max-width: 400px; margin: 0; }
.drows { display: flex; gap: 12px; margin-top: 26px; flex-wrap: wrap; }
.drow {
  font-family: var(--mono); font-size: 11px; letter-spacing: 1.4px;
  padding: 6px 12px; border: 1px solid currentColor; border-radius: 20px; opacity: .55;
  white-space: nowrap;
}
.dend { width: 860px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 30px; }
.dend .dlbl { opacity: .5; }
.dback {
  font-family: 'BigShoulders', sans-serif; font-weight: 800; font-size: 64px;
  -webkit-text-stroke: 1.2px currentColor; color: inherit; text-decoration: none;
  transition-property: opacity; transition-duration: .15s; transition-timing-function: ease-out;
}
.dback:hover { opacity: .7; }
.dend-pad { width: 300px; }

/* fixed viewport chrome inside detail */
.dchrome { position: absolute; inset: 0; pointer-events: none; }
.dexit {
  position: absolute; left: 34px; top: 30px; pointer-events: auto;
  font-size: 10px; font-weight: 600; letter-spacing: 1.8px; color: inherit; text-decoration: none;
  display: flex; align-items: center; gap: 10px;
  transition-property: opacity; transition-duration: .15s; transition-timing-function: ease-out;
}
.dexit:hover { opacity: .65; }
.dexit .dexit-arrow { width: 26px; height: 1.5px; background: currentColor; position: relative; }
.dexit .dexit-arrow::before {
  content: ''; position: absolute; left: -1px; top: -3.2px; width: 8px; height: 8px;
  border-left: 1.5px solid currentColor; border-bottom: 1.5px solid currentColor;
  transform: rotate(45deg) scale(.8);
}
.dtimeline {
  position: absolute; left: 120px; right: 120px; bottom: 44px; height: 40px; pointer-events: none;
}
.dtimeline .tl-rule { position: absolute; left: 0; right: 0; top: 19px; height: 1px; background: currentColor; opacity: .25; }
.dtimeline .tl-tick { position: absolute; top: 14px; width: 1px; height: 11px; background: currentColor; opacity: .4; }
.dtimeline .tl-lbl {
  position: absolute; top: -8px; transform: translateX(-50%);
  font-family: var(--mono); font-size: 10.5px; letter-spacing: 1.6px; opacity: .55;
}
.dtimeline .tl-dot {
  position: absolute; top: 15.5px; width: 8px; height: 8px; border-radius: 50%;
  background: var(--accent); transform: translateX(-50%);
  box-shadow: 0 0 0 3px var(--accent-soft);
}
</style>

<script is:inline define:vars={{ PROJECTS: CLIENT_PROJECTS }}>
// ---- camera: single writer for all scene transforms (fit scale + walk-through push) ----
var cam = document.getElementById('camera');
var camState = {
  fitS: 1,
  push: 0,                       // 0 = landing, 1 = through the billboard
  ZMAX: 2.2,
  FOCUS: { x: 814, y: 387 },     // billboard screen center
  CENTER: { x: 768, y: 512 }     // scene center
};
function applyCamera() {
  var c = camState;
  var k = c.fitS * Math.pow(c.ZMAX, c.push);
  var dx = (c.CENTER.x - c.FOCUS.x) * c.push * k;
  var dy = (c.CENTER.y - c.FOCUS.y) * c.push * k;
  cam.style.transform = 'translate(' + dx + 'px,' + dy + 'px) scale(' + k + ')';
}
function fit() {
  camState.fitS = Math.min(innerWidth / 1536, innerHeight / 1024);
  applyCamera();
}
addEventListener('resize', fit); fit();

// ---- landing state: featured project (index into PROJECTS) ----
var state = { mode: 'landing', featured: 0 };
var tv = document.getElementById('tv');

function setFeatured(i) {
  state.featured = i;
  var p = PROJECTS[i];
  document.querySelectorAll('.pcard').forEach(function (c) {
    c.classList.toggle('selected', c.dataset.slug === p.slug);
  });
  document.querySelectorAll('.tv .art').forEach(function (a) {
    a.classList.toggle('on', a.dataset.art === p.slug);
  });
  tv.setAttribute('aria-label', 'Step into ' + p.name);
}

document.querySelectorAll('.pcard').forEach(function (c, i) {
  c.addEventListener('click', function (e) {
    e.preventDefault();
    if (state.featured === i) enterProject(i);
    else setFeatured(i);
  });
});
document.querySelector('.swipe .prev').addEventListener('click', function (e) {
  e.preventDefault(); setFeatured((state.featured + PROJECTS.length - 1) % PROJECTS.length);
});
document.querySelector('.swipe .next').addEventListener('click', function (e) {
  e.preventDefault(); setFeatured((state.featured + 1) % PROJECTS.length);
});
tv.addEventListener('click', function () { enterProject(state.featured); });
tv.addEventListener('keydown', function (e) { if (e.key === 'Enter') enterProject(state.featured); });

// ---- detail world ----
var detail = document.getElementById('detail');
var dcam = document.getElementById('dcam');
var railEl = document.getElementById('rail');
var rail = { x: 0, target: 0, max: 0, width: 0, centers: [] };

function esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;'); }

function frameHtml(p, it, kind) {
  // artifact slot: designed placeholder until the real image lands (per-iter img in PROJECTS)
  return '<div class="dframe" style="background:radial-gradient(120% 140% at 30% 20%, ' + p.deep + ' 0%, rgba(6,8,9,.0) 100%); color:' + p.ink + '">' +
    '<div class="dframe-inner"></div>' +
    '<div class="dframe-v" style="color:' + p.accent + '">' + esc(it.v) + '</div>' +
    '<div class="dframe-tag">' + esc(p.name) + ' — ' + esc(kind) + ' SLOT 1280×800</div>' +
    '</div>';
}

function buildDetail(i) {
  var p = PROJECTS[i];
  detail.style.background = 'radial-gradient(130% 120% at 30% 10%, ' + p.deep + ' 0%, #060809 78%)';
  detail.style.color = p.ink;

  var no = String(i + 1).padStart(2, '0');
  var h = '';
  h += '<div class="dpanel dtitle">' +
       '<div class="dnum">' + no + '</div>' +
       '<div class="dlbl">PROJECT ' + no + ' — WALKED IN</div>' +
       '<h2 class="dname" style="color:' + p.accent + '" tabindex="-1" id="dfocus">' + esc(p.name) + '</h2>' +
       '<div class="dtag">' + esc(p.tag) + '</div>' +
       '<div class="dmeta"><span>' + p.iters.length + ' ITERATIONS</span><span>2026</span><span>SCROLL →</span></div>' +
       '<a class="dposter" href="' + p.href + '" aria-label="Open ' + esc(p.name) + ' case study"></a>' +
       '<a class="dopen" href="' + p.href + '" style="color:' + p.accent + '">OPEN CASE STUDY <span aria-hidden="true">↗</span></a>' +
       '</div>';
  p.iters.forEach(function (it, n) {
    h += '<div class="dpanel diter' + (n % 2 ? ' alt' : '') + '">' +
         '<div class="dnum">' + esc(it.v.replace('V', '')) + '</div>' +
         frameHtml(p, it, 'ARTIFACT') +
         '<div class="dtext">' +
         '<div class="dv" style="color:' + p.accent + '">' + esc(it.v) + '</div>' +
         '<div class="dh">' + esc(it.title) + '</div>' +
         '<p class="dcap">' + esc(it.cap) + '</p>' +
         '<div class="drows">' + it.rows.map(function (r) { return '<span class="drow">' + esc(r).toUpperCase() + '</span>'; }).join('') + '</div>' +
         '</div></div>';
  });
  h += '<div class="dpanel dend">' +
       '<div class="dlbl">END OF TIMELINE</div>' +
       '<a class="dback" href="#/" style="color:' + p.accent + '">STEP BACK OUT</a>' +
       '</div><div class="dend-pad"></div>';
  railEl.innerHTML = h;

  // the poster is the project's plate, cloned from its template
  var tpl = document.getElementById('plate-' + p.slug);
  if (tpl) railEl.querySelector('.dposter').appendChild(tpl.content.cloneNode(true));

  // timeline ruler: one tick per stop (title + iterations + end)
  var tl = document.getElementById('dtimeline');
  var stops = ['IN'].concat(p.iters.map(function (it) { return it.v; })).concat(['OUT']);
  var t = '<div class="tl-rule"></div>';
  stops.forEach(function (s, n) {
    var pct = stops.length > 1 ? (n / (stops.length - 1)) * 100 : 0;
    t += '<div class="tl-tick" style="left:' + pct + '%"></div>';
    t += '<div class="tl-lbl" style="left:' + pct + '%">' + esc(s) + '</div>';
  });
  t += '<div class="tl-dot" id="tldot" style="left:0%"></div>';
  tl.innerHTML = t;

  rail.x = rail.target = 0;
  dfit();
}

function dfit() {
  if (!detail.classList.contains('on')) return;
  var ds = innerHeight / 1024;
  rail.width = railEl.scrollWidth;
  rail.max = Math.max(0, rail.width * ds - innerWidth) / ds;   // in world px
  rail.centers = [];
  railEl.querySelectorAll('.dpanel').forEach(function (el) {
    rail.centers.push(Math.min(rail.max, Math.max(0, el.offsetLeft + el.offsetWidth / 2 - (innerWidth / ds) / 2)));
  });
  applyRail(ds);
}
function applyRail(ds) {
  ds = ds || innerHeight / 1024;
  dcam.style.transform = 'scale(' + ds + ') translate3d(' + (-rail.x) + 'px,0,0)';
  var dot = document.getElementById('tldot');
  if (dot) dot.style.left = (rail.max ? Math.min(1, Math.max(0, rail.x / rail.max)) : 0) * 100 + '%';
}
addEventListener('resize', dfit);

// ---- rail input: wheel / drag / keys, smoothing, idle snap, edge exit ----
var railInput = {
  lastInput: 0, dragging: false, dragX: 0, dragStart: 0,
  raf: null, EXIT_TRIGGER: 200, RESIST: .35
};
function railWake() {
  railInput.lastInput = performance.now();
  if (!railInput.raf) railTick();
}
function railTick() {
  var r = rail, ri = railInput;
  var idle = performance.now() - ri.lastInput > 150;
  if (idle && !ri.dragging) {
    if (r.target < 0) {
      // released in the overscroll zone: exit if past the threshold, else spring home
      if (r.target < -ri.EXIT_TRIGGER && state.mode === 'detail') { location.hash = '#/'; r.target = 0; }
      else r.target += (0 - r.target) * .12;
    } else if (r.centers.length) {
      var best = r.centers[0];
      r.centers.forEach(function (c) { if (Math.abs(c - r.target) < Math.abs(best - r.target)) best = c; });
      r.target += (best - r.target) * .06;     // gentle magnet, free while scrolling
    }
  }
  r.target = Math.min(r.target, r.max + 80);
  r.x += (r.target - r.x) * (reduceMotion ? 1 : .12);
  applyRail();
  if (Math.abs(r.target - r.x) > .1 || !idle || ri.dragging) railInput.raf = requestAnimationFrame(railTick);
  else { railInput.raf = null; r.x = r.target; applyRail(); }
}
detail.addEventListener('wheel', function (e) {
  if (state.mode !== 'detail') return;
  e.preventDefault();
  var d = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
  if (rail.target + d < 0) d *= railInput.RESIST;             // resistance before the edge exit
  rail.target = Math.max(-railInput.EXIT_TRIGGER - 60, Math.min(rail.max + 80, rail.target + d));
  railWake();
}, { passive: false });
detail.addEventListener('pointerdown', function (e) {
  if (state.mode !== 'detail' || e.target.closest('a')) return;
  railInput.dragging = true; railInput.dragX = e.clientX; railInput.dragStart = rail.target;
  detail.classList.add('grabbing');
  detail.setPointerCapture(e.pointerId);
  railWake();
});
detail.addEventListener('pointermove', function (e) {
  if (!railInput.dragging) return;
  var ds = innerHeight / 1024;
  var d = (railInput.dragX - e.clientX) / ds;
  var t = railInput.dragStart + d;
  if (t < 0) t *= railInput.RESIST;
  rail.target = Math.max(-railInput.EXIT_TRIGGER - 60, Math.min(rail.max + 80, t));
  railWake();
});
['pointerup', 'pointercancel'].forEach(function (ev) {
  detail.addEventListener(ev, function () {
    railInput.dragging = false;
    detail.classList.remove('grabbing');
    railWake();
  });
});
document.addEventListener('keydown', function (e) {
  if (state.mode !== 'detail') return;
  var i, cur = rail.centers.indexOf(rail.centers.reduce(function (a, b) {
    return Math.abs(b - rail.target) < Math.abs(a - rail.target) ? b : a;
  }, rail.centers[0] || 0));
  if (e.key === 'ArrowRight') { i = Math.min(rail.centers.length - 1, cur + 1); rail.target = rail.centers[i]; railWake(); }
  if (e.key === 'ArrowLeft')  { i = Math.max(0, cur - 1); rail.target = rail.centers[i]; railWake(); }
});

// ---- walk-through transition ----
var reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

function cubicBezier(x1, y1, x2, y2) {
  function f(t, a, b) { var o = 1 - t; return 3*o*o*t*a + 3*o*t*t*b + t*t*t; }
  return function (x) {
    if (x <= 0) return 0; if (x >= 1) return 1;
    var t = x;
    for (var i = 0; i < 6; i++) {
      var cx = f(t, x1, x2) - x;
      var dx = 3*(1-t)*(1-t)*x1 + 6*(1-t)*t*(x2-x1) + 3*t*t*(1-x2);
      if (Math.abs(dx) < 1e-6) break;
      t -= cx / dx;
      t = Math.max(0, Math.min(1, t));
    }
    return f(t, y1, y2);
  };
}
var easePush = cubicBezier(.7, 0, .3, 1);

var pushAnim = null, transTimers = [];
function animatePush(to, dur, done) {
  if (pushAnim) cancelAnimationFrame(pushAnim);
  var from = camState.push, t0 = performance.now();
  cam.style.willChange = 'transform';
  function tick(now) {
    var t = Math.min(1, (now - t0) / dur);
    camState.push = from + (to - from) * easePush(t);
    applyCamera();
    if (t < 1) { pushAnim = requestAnimationFrame(tick); }
    else {
      pushAnim = null; cam.style.willChange = '';
      if (done) done();
    }
  }
  pushAnim = requestAnimationFrame(tick);
}
function clearTransTimers() { transTimers.forEach(clearTimeout); transTimers = []; }

var scene = document.getElementById('scene');

function animEnter(i) {
  state.mode = 'entering';
  setFeatured(i);
  buildDetail(i);
  clearTransTimers();
  scene.classList.add('pushing');
  detail.style.willChange = 'opacity, transform';

  function arrive() {
    detail.classList.add('on');
    dfit();
    void detail.offsetWidth;                 // commit start state before transitioning
    detail.classList.add('in');
  }
  function settle() {
    state.mode = 'detail';
    if (!reduceMotion) { camState.push = 1; applyCamera(); }  // deterministic even if rAF was throttled
    detail.style.willChange = '';
    var f = document.getElementById('dfocus');
    if (f) f.focus({ preventScroll: true });
    route();                                 // catch hash changes made mid-transition
  }
  if (reduceMotion) {
    arrive();
    transTimers.push(setTimeout(settle, 260));
  } else {
    animatePush(1, 850, null);
    transTimers.push(setTimeout(arrive, 450));
    transTimers.push(setTimeout(settle, 870));
  }
}

function animExit() {
  state.mode = 'exiting';
  clearTransTimers();
  detail.classList.remove('in');            // recede + fade (250ms)
  detail.style.willChange = 'opacity, transform';

  function land() {
    state.mode = 'landing';
    camState.push = 0; applyCamera();        // deterministic even if rAF was throttled
    scene.classList.remove('pushing');
    detail.classList.remove('on');
    detail.style.willChange = '';
    var card = document.querySelector('.pcard.selected');
    if (card) card.focus({ preventScroll: true });
    route();
  }
  if (reduceMotion) {
    scene.classList.remove('pushing');
    transTimers.push(setTimeout(land, 260));
  } else {
    animatePush(0, 650, null);
    transTimers.push(setTimeout(function () { scene.classList.remove('pushing'); }, 300));
    transTimers.push(setTimeout(land, 670));
  }
}

// ---- router: #/ landing, #/p/{slug} detail ----
function currentRoute() {
  var m = location.hash.match(/^#\/p\/([a-z-]+)$/);
  if (!m) return -1;
  for (var i = 0; i < PROJECTS.length; i++) if (PROJECTS[i].slug === m[1]) return i;
  return -1;
}
function route(initial) {
  var i = currentRoute();
  if (state.mode === 'entering' || state.mode === 'exiting') return;  // re-checked on completion
  if (i >= 0 && state.mode === 'landing') {
    if (initial) {                            // deep link: no motion
      state.mode = 'detail';
      setFeatured(i); buildDetail(i);
      scene.classList.add('pushing');
      camState.push = 1; applyCamera();
      detail.classList.add('on'); detail.classList.add('in');
      dfit();
    } else animEnter(i);
  } else if (i < 0 && state.mode === 'detail') {
    animExit();
  } else if (i >= 0 && state.mode === 'detail' && i !== state.featured) {
    setFeatured(i); buildDetail(i);          // project switch while inside: rebuild in place
  }
}
addEventListener('hashchange', function () { route(false); });

function enterProject(i) { location.hash = '#/p/' + PROJECTS[i].slug; }
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape' && state.mode === 'detail') location.hash = '#/';
});
route(true);

// ---- room tone: generated, never autoplayed ----
var sound = document.getElementById('sound');
var sndState = document.getElementById('sndState');
var actx = null, gain = null;
sound.addEventListener('click', function () {
  var on = sound.getAttribute('aria-checked') !== 'true';
  sound.setAttribute('aria-checked', String(on));
  sndState.textContent = on ? 'ON' : 'OFF';
  if (!actx && on) {
    actx = new AudioContext();
    /* filtered noise: the room the plates are hung in */
    var len = actx.sampleRate * 4;
    var buf = actx.createBuffer(1, len, actx.sampleRate);
    var d = buf.getChannelData(0);
    var last = 0;
    for (var i = 0; i < len; i++) {
      var white = Math.random() * 2 - 1;
      last = (last + 0.02 * white) / 1.02;
      d[i] = last * 3.5;
    }
    var src = actx.createBufferSource();
    src.buffer = buf; src.loop = true;
    var lp = actx.createBiquadFilter();
    lp.type = 'lowpass'; lp.frequency.value = 520; lp.Q.value = 0.6;
    gain = actx.createGain(); gain.gain.value = 0;
    src.connect(lp).connect(gain).connect(actx.destination);
    src.start();
  }
  if (actx && gain) {
    actx.resume();
    gain.gain.cancelScheduledValues(actx.currentTime);
    gain.gain.linearRampToValueAtTime(on ? 0.06 : 0, actx.currentTime + 0.6);
  }
});

// headline calibration: pin each line's ink box exactly onto the measured mockup box
function calibrate() {
  document.querySelectorAll('.hl').forEach(function (el) {
    var cs = getComputedStyle(el);
    var fs = parseFloat(cs.fontSize);
    var lh = parseFloat(cs.lineHeight);
    var g = document.createElement('canvas').getContext('2d');
    g.font = cs.fontWeight + ' ' + fs + 'px ' + cs.fontFamily;
    var m = g.measureText(el.textContent);
    var capAsc = m.actualBoundingBoxAscent;
    var inkW = m.actualBoundingBoxLeft + m.actualBoundingBoxRight;
    var fbAsc = m.fontBoundingBoxAscent, fbDesc = m.fontBoundingBoxDescent;
    var targetW = parseFloat(el.dataset.w);
    var targetCapTop = parseFloat(el.dataset.captop);
    var targetCapH = 60;
    var sx = targetW / inkW, sy = targetCapH / capAsc;
    var baselineLocal = (lh - (fbAsc + fbDesc)) / 2 + fbAsc;
    var inkTopLocal = baselineLocal - capAsc;
    el.style.left = el.dataset.x + 'px';
    el.style.top = (targetCapTop - inkTopLocal * sy) + 'px';
    el.style.transform = 'scale(' + sx + ',' + sy + ')';
  });
}
document.fonts.ready.then(calibrate);
</script>
