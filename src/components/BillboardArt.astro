---
/* BillboardArt - what plays on the billboard screen, one variant per project.
   Lifted out of index.astro so the landing and the index lab render the same
   object instead of two drifting copies. The Poolside water canvas and the
   easing figure are animated by the landing's own script; without it the
   Plate underneath is the still fallback, which is what it was always for. */
import Plate from './Plate.astro';

interface Props { slug: string; glyphStill?: string; brailleStill?: string }
const { slug, glyphStill = '', brailleStill = '' } = Astro.props;
---
  {slug === 'poolside' ? (
    /* the Poolside app itself, landscape: its real UI is the billboard */
    <span class="bb-app" aria-label="Poolside — the app's home screen">
      <span class="bb-rail">
        <span class="bb-tab active"><svg viewBox="0 0 24 24"><path d="M12 3 C8.5 8 7 10.5 7 13.5 a5 5 0 0 0 10 0 C17 10.5 15.5 8 12 3 Z"/></svg><i></i></span>
        <span class="bb-tab"><svg viewBox="0 0 24 24"><path d="M3.5 16.5 9 11l4 4 7-7.5M15.5 7.5H20V12"/></svg></span>
        <span class="bb-tab"><svg viewBox="0 0 24 24"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v15.5H6.5A2.5 2.5 0 0 0 4 21z"/><path d="M4 18.5A2.5 2.5 0 0 1 6.5 16H20"/></svg></span>
        <span class="bb-tab"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3.6"/><path d="M5 20c.8-3.6 3.6-5.5 7-5.5s6.2 1.9 7 5.5"/></svg></span>
      </span>
      <span class="bb-main">
        <span class="bb-head">
          <span class="bb-greet">
            <span class="bb-gsub">Good morning</span>
            <span class="bb-gname">Backyard Pool</span>
          </span>
          <span class="bb-wpill">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4" fill="#eebb55" stroke="none"/><g stroke="#e0a63f" stroke-width="1.6" stroke-linecap="round"><path d="M12 2.8v2.4M12 18.8v2.4M2.8 12h2.4M18.8 12h2.4M5.2 5.2l1.7 1.7M17.1 17.1l1.7 1.7M5.2 18.8l1.7-1.7M17.1 6.9l1.7-1.7"/></g></svg>
            Sunny · 24°
          </span>
        </span>
        <span class="bb-water">
          <Plate slug="poolside" />
          <canvas id="bbwater" aria-hidden="true"></canvas>
          <span class="bb-pill"><i></i>Crystal clear</span>
          <span class="bb-badge"><b>97</b><em>Water clarity</em></span>
          <span class="bb-fab"><svg viewBox="0 0 24 24"><path d="M4 8.5a2 2 0 0 1 2-2h1.6l1.2-1.8h6.4l1.2 1.8H18a2 2 0 0 1 2 2V17a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><circle cx="12" cy="12.6" r="3.2"/></svg></span>
        </span>
      </span>
      <span class="bb-side">
        <span class="bb-chemhead">Chemistry<em>Tested 2h ago</em></span>
        <span class="bb-plate">
            <span class="bb-gauge"><span class="bb-glabel">pH</span><span class="bb-grow"><span class="bb-gval">7.4</span><span class="bb-gdot"></span></span><span class="bb-gtrack"><span class="bb-gband" style="left:35%;width:40%"></span><span class="bb-gmark" style="left:55%"></span></span><span class="bb-gnote">ideal 7.2–7.6</span></span>
            <span class="bb-gauge"><span class="bb-glabel">Chlorine</span><span class="bb-grow"><span class="bb-gval">2.4</span><span class="bb-gdot"></span></span><span class="bb-gtrack"><span class="bb-gband" style="left:25%;width:45%"></span><span class="bb-gmark" style="left:48%"></span></span><span class="bb-gnote">1–3 ppm</span></span>
            <span class="bb-gauge"><span class="bb-glabel">Alkalinity</span><span class="bb-grow"><span class="bb-gval">100</span><span class="bb-gdot"></span></span><span class="bb-gtrack"><span class="bb-gband" style="left:30%;width:50%"></span><span class="bb-gmark" style="left:50%"></span></span><span class="bb-gnote">80–120 ppm</span></span>
            <span class="bb-gauge"><span class="bb-glabel">Stabilizer</span><span class="bb-grow"><span class="bb-gval">40</span><span class="bb-gdot"></span></span><span class="bb-gtrack"><span class="bb-gband" style="left:28%;width:37%"></span><span class="bb-gmark" style="left:45%"></span></span><span class="bb-gnote">30–50 ppm</span></span>
        </span>
        <span class="bb-card bb-fc">
          <span class="bb-fchip"><svg viewBox="0 0 24 24"><path d="M3.5 16.5 9 11l4 4 7-7.5M15.5 7.5H20V12"/></svg>Forecast</span>
          <svg class="bb-spark" viewBox="0 0 260 104" preserveAspectRatio="none">
            <defs>
              <!-- under the threshold the water is no longer clear, so the
                   trace goes soft the way the pool does -->
              <filter id="bbFcHaze" x="-20%" y="-20%" width="140%" height="140%">
                <feGaussianBlur stdDeviation="1.5"/>
              </filter>
              <clipPath id="bbFcClear"><rect x="0" y="0" width="260" height="34"/></clipPath>
              <clipPath id="bbFcCloudy"><rect x="0" y="34" width="260" height="70"/></clipPath>
            </defs>
            <line class="fc-thresh" x1="4" y1="34" x2="256" y2="34"/>
            <g clip-path="url(#bbFcClear)">
              <polyline class="fc-line" points="6,20 34,24 62,30 90,26 118,38 146,48 174,44 202,58"/>
              <line class="fc-proj" x1="202" y1="58" x2="248" y2="80"/>
            </g>
            <g clip-path="url(#bbFcCloudy)" filter="url(#bbFcHaze)">
              <polyline class="fc-line" points="6,20 34,24 62,30 90,26 118,38 146,48 174,44 202,58"/>
              <line class="fc-proj" x1="202" y1="58" x2="248" y2="80"/>
              <circle class="fc-ghost" cx="248" cy="80" r="4"/>
            </g>
          </svg>
          <span class="bb-warn">Clarity has slipped 18 points over three weeks. A shock this week holds it clear.</span>
        </span>
      </span>
    </span>
  ) : slug === 'xaml-uno' ? (
    /* the skill's own figure at billboard scale: the EaseSmooth curve
       (EasingDemo.astro), animated by the house numbers */
    <span class="bb-ease">
      <svg class="bbe-plot" viewBox="0 0 160 140" aria-hidden="true">
        <line class="bbe-axis" x1="28" y1="12" x2="28" y2="122" />
        <line class="bbe-axis" x1="28" y1="122" x2="138" y2="122" />
        <path class="bbe-linear" d="M 28 122 L 138 12" />
        <line class="bbe-handle" x1="28" y1="122" x2="52.2" y2="12" />
        <line class="bbe-handle" x1="138" y1="12" x2="67.6" y2="12" />
        <circle class="bbe-cp" cx="52.2" cy="12" r="2.1" />
        <circle class="bbe-cp" cx="67.6" cy="12" r="2.1" />
        <path class="bbe-curve" d="M 28 122 C 52.2 12 67.6 12 138 12" />
        <circle class="bbe-marker" cx="28" cy="122" r="3" />
        <text class="bbe-lbl" x="24" y="15" text-anchor="end">1</text>
        <text class="bbe-lbl" x="24" y="124" text-anchor="end">0</text>
        <text class="bbe-lbl" x="136" y="133">t</text>
      </svg>
      <span class="bbe-rails">
        <span class="bbe-rail">
          <span class="bbe-tag">EaseSmooth · cubic-bezier(.22,1 .36,1)</span>
          <span class="bbe-track"><i class="bbe-target"></i><i class="bbe-tile ink"></i></span>
        </span>
        <span class="bbe-rail">
          <span class="bbe-tag">linear · for contrast</span>
          <span class="bbe-track"><i class="bbe-target"></i><i class="bbe-tile lin"></i></span>
        </span>
        <span class="bbe-foot">XAML: KeySpline 0.22,1 0.36,1 · Duration 280ms</span>
      </span>
    </span>
  ) : slug === 'braille-transition' ? (
    <span class="bb-braille"><pre class="braille-live" data-cols="56" data-rows="20" aria-hidden="true">{brailleStill}</pre></span>
  ) : slug === 'voice-assistant' ? (
    <span class="bb-voice">
      <iframe class="bb-embed" data-embed="/voice-assistant/index.html" title="Voice Assistant, live" loading="lazy"></iframe>
    </span>
  ) : slug === 'glyph-grid' ? (
    /* the lab itself, embedded: the billboard runs the real prototype rather
       than a port of it, so the two cannot drift. src is set only while this
       panel is the selected one - see setFeatured on the landing. */
    <span class="bb-glyph">
      <pre class="glyph-still big" aria-hidden="true">{glyphStill}</pre>
      <iframe class="bb-embed" data-embed="/glyph-grid/index.html" title="Magnetic Spring-Mass, live" loading="lazy"></iframe>
    </span>
  ) : (
    <Plate slug={slug} />
  )}

<style>
/* ---- poolside billboard: the app's real UI in landscape ----
   Inks are the app's own (--lg-* on /poolside/); Fraunces carries display
   numbers. The water surface runs the app's WebGL shader; the plate
   underneath it is the no-WebGL fallback. */
.bb-app {
  --bb-ink: #12333D; --bb-slate: #5F7B85; --bb-slate2: #8AA2AB;
  --bb-deep: #0A6C88; --bb-sage: #57B394; --bb-line: rgba(60,52,40,.11);
  position: absolute; inset: 0; display: flex;
  background: linear-gradient(170deg, #F2EDE3, #E9E3D6);
  font-family: 'Instrument Sans', system-ui, sans-serif; color: var(--bb-ink);
  text-align: left;
}
.bb-rail {
  width: 64px; flex: none; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 34px;
  border-right: 1px solid var(--bb-line);
}
.bb-tab { position: relative; color: var(--bb-slate2); }
.bb-tab svg { display: block; width: 24px; height: 24px; fill: none; stroke: currentColor; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
.bb-tab.active { color: var(--bb-deep); }
.bb-tab.active i { position: absolute; left: 50%; bottom: -9px; width: 4px; height: 4px; border-radius: 50%; background: var(--bb-deep); transform: translateX(-50%); }
.bb-main { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; padding: 24px 24px 26px 28px; }
/* the pill rides the pool-name line, not the greeting above it */
.bb-head { display: flex; align-items: flex-end; justify-content: space-between; padding-bottom: 18px; }
.bb-gsub { display: block; font-size: 13px; font-weight: 500; color: var(--bb-slate2); }
.bb-gname { display: block; font-family: 'Fraunces', serif; font-weight: 400; font-size: 30px; line-height: 1.1; letter-spacing: -.3px; }
.bb-wpill {
  display: inline-flex; align-items: center; gap: 7px; margin-bottom: 2px;
  font-size: 12.5px; font-weight: 500; color: var(--bb-slate);
  background: rgba(60,52,40,.05); border: 0;
  box-shadow: inset 0 1px 3px rgba(60,52,40,.13), 0 1px 0 rgba(255,255,255,.6);
  border-radius: 999px; padding: 6px 12px;
}
.bb-wpill svg { width: 15px; height: 15px; display: block; }
.bb-water { position: relative; flex: 1 1 auto; border-radius: 18px; overflow: hidden; background: #0E3444; box-shadow: inset 0 0 0 1px rgba(18,51,61,.35); }
.bb-water .plate, .bb-water canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
.bb-pill {
  position: absolute; left: 14px; top: 13px; display: inline-flex; align-items: center; gap: 7px;
  font-size: 12px; font-weight: 600; color: var(--bb-ink);
  background: rgba(255,255,255,.88); border-radius: 999px; padding: 6px 12px;
}
.bb-pill i { width: 7px; height: 7px; border-radius: 50%; background: var(--bb-sage); display: block; }
.bb-badge { position: absolute; left: 16px; bottom: 12px; color: #fff; }
.bb-badge b { display: block; font-family: 'Fraunces', serif; font-weight: 300; font-size: 46px; line-height: .9; }
.bb-badge em { display: block; font-style: normal; font-size: 12px; font-weight: 500; letter-spacing: .2px; opacity: .92; }
.bb-fab {
  position: absolute; right: 14px; bottom: 12px; width: 40px; height: 40px; border-radius: 50%;
  background: var(--bb-deep); display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8px 16px -8px rgba(10,58,74,.7);
}
.bb-fab svg { width: 18px; height: 18px; stroke: #fff; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
.bb-side { width: 340px; flex: none; display: flex; flex-direction: column; gap: 10px; padding: 24px 24px 26px 0; }
.bb-card {
  background: rgba(255,255,255,.55); border: 1px solid var(--bb-line);
  border-radius: 16px; padding: 14px 16px;
}
.bb-chemhead { display: flex; align-items: baseline; justify-content: space-between; padding: 0 2px 2px;
  font-size: 12px; font-weight: 600; letter-spacing: .6px; text-transform: uppercase; color: var(--bb-slate2); }
.bb-chemhead em { font-style: normal; font-size: 11.5px; font-weight: 500; letter-spacing: .2px; text-transform: none; color: var(--bb-slate2); }
/* the plate is engraved into the surface, not laid on it: the app's own
   stack - inner shadow from above, a white lip along the bottom, a white
   halo outside - plus the hairline cross between the four gauges */
.bb-plate {
  position: relative; flex: none; display: grid; grid-template-columns: 1fr 1fr;
  border-radius: 22px; padding: 4px;
  background: linear-gradient(180deg, rgba(60,52,40,.06), rgba(255,255,255,.14));
  box-shadow:
    inset 0 2px 7px rgba(60,52,40,.16),
    inset 0 -1px 0 rgba(255,255,255,.7),
    0 1px 0 rgba(255,255,255,.55);
}
.bb-plate::before {
  content: ''; position: absolute; top: 16%; bottom: 16%; left: 50%; width: 1px; z-index: 1;
  background: rgba(60,52,40,.1); box-shadow: 1px 0 0 rgba(255,255,255,.55);
}
.bb-plate::after {
  content: ''; position: absolute; left: 9%; right: 9%; top: 50%; height: 1px; z-index: 1;
  background: rgba(60,52,40,.1); box-shadow: 0 1px 0 rgba(255,255,255,.55);
}
.bb-gauge { position: relative; z-index: 2; display: block; padding: 8px 14px 7px; }
.bb-glabel { display: block; font-size: 10.5px; font-weight: 600; letter-spacing: .4px; text-transform: uppercase; color: var(--bb-slate2); }
.bb-grow { display: flex; align-items: center; gap: 7px; margin-top: 4px; }
/* the numerals are embossed: a white edge under the glyph, as on the plate */
.bb-gval { font-family: 'Fraunces', serif; font-weight: 300; font-size: 24px; line-height: 1;
  letter-spacing: -.5px; color: var(--bb-ink); text-shadow: 0 1px 0 rgba(255,255,255,.7); }
.bb-gdot { width: 8px; height: 8px; border-radius: 50%; background: var(--bb-sage); box-shadow: 0 0 6px rgba(0,0,0,.06); }
/* the track is a carved channel, the knob sits above it */
.bb-gtrack { position: relative; display: block; margin-top: 8px; height: 6px; border-radius: 3px;
  background: rgba(60,52,40,.1);
  box-shadow: inset 0 1px 2px rgba(60,52,40,.22), 0 1px 0 rgba(255,255,255,.6); }
.bb-gband { position: absolute; top: 0; bottom: 0; border-radius: 3px; background: rgba(87,179,148,.4); }
.bb-gmark { position: absolute; top: 50%; width: 12px; height: 12px; border-radius: 50%;
  transform: translate(-50%,-50%); background: var(--bb-sage);
  box-shadow: 0 2px 4px rgba(0,0,0,.28), 0 0 0 2px rgba(255,255,255,.85); }
.bb-gnote { display: block; margin-top: 6px; font-size: 10px; font-weight: 500; letter-spacing: .2px; color: var(--bb-slate2); }
.bb-fc { flex: 1 1 auto; min-height: 0; display: flex; flex-direction: column; padding: 12px 14px 12px; }
.bb-fchip { display: inline-flex; align-items: center; gap: 7px; font-size: 10.5px; font-weight: 700; letter-spacing: .9px; text-transform: uppercase; color: var(--bb-deep); }
.bb-fchip svg { width: 13px; height: 13px; stroke: var(--bb-deep); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
.bb-spark { display: block; width: 100%; flex: 1 1 auto; min-height: 92px; margin-top: 8px; }
.bb-spark .fc-thresh { stroke: rgba(87,179,148,.5); stroke-width: 1; stroke-dasharray: 3 4; }
.bb-spark .fc-line { fill: none; stroke: var(--bb-deep); stroke-width: 2; stroke-linejoin: round; stroke-linecap: round; }
.bb-spark .fc-proj { stroke: var(--bb-deep); stroke-width: 2; stroke-dasharray: 2 4; opacity: .7; }
.bb-spark .fc-ghost { fill: none; stroke: var(--bb-deep); stroke-width: 1.6; opacity: .7; }
.bb-warn { margin-top: 8px; font-size: 11.5px; line-height: 1.45; color: var(--bb-slate); }
/* the display darkens at its perimeter and carries a light sheen */
.vignette {
  position: absolute; inset: 0; pointer-events: none; z-index: 2;
  background: radial-gradient(118% 96% at 50% 42%, rgba(0,0,0,0) 52%, rgba(0,0,0,.38) 100%);
}
.sheen {
  position: absolute; inset: 0; pointer-events: none; z-index: 3;
  background: linear-gradient(116deg,
    rgba(255,255,255,.10) 0%, rgba(255,255,255,.035) 16%,
    rgba(255,255,255,0) 34%, rgba(255,255,255,0) 100%);
}
</style>
