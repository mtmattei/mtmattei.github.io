---
// Exploded isometric "general arrangement" of the portfolio: four stacked
// members (Code, Design, Writing, Skills), each a link to its category.
// A slider lifts the stack from assembled to exploded. Instrument-themed
// (JetBrains Mono, ink, single blue accent) — adapted from a joinery drawing.
---
<figure class="ga" aria-labelledby="ga-title">
  <figcaption class="ga-head">
    <span class="kicker">Fig.00 · general arrangement · exploded</span>
    <h2 id="ga-title">The work, in four members.</h2>
  </figcaption>

  <div class="ga-stage">
    <svg id="gaSvg" class="ga-svg" viewBox="0 0 1080 720" role="img"
         aria-label="Exploded isometric of the portfolio in four members: code, design, writing, skills. Each member links to that category."></svg>
  </div>

  <div class="ga-gauge">
    <div class="ga-gauge-top">
      <span class="kicker">exploded view</span>
      <span class="mono ga-readout" id="gaReadout">sep 16 · h 98</span>
    </div>
    <input type="range" id="gaSep" min="0" max="40" step="1" value="16" aria-label="Member separation, 0 assembled to 40 exploded" />
    <div class="ga-ticks"><span>0 · assembled</span><span>20</span><span>40 · exploded</span></div>
  </div>
</figure>

<style>
  .ga { margin: 0; }
  .ga-head { margin-bottom: var(--s4); }
  .ga-head .kicker { display: block; margin-bottom: 6px; }
  .ga-head h2 { font-size: 20px; font-weight: 600; letter-spacing: -0.01em; margin: 0; }

  .ga-stage {
    border: var(--bw) solid var(--line);
    border-radius: var(--radius);
    background: var(--gray-1);
    position: relative;
    padding: var(--s3);
  }
  .ga-svg { width: 100%; height: auto; display: block; }

  .ga-gauge {
    margin-top: var(--s3);
    border: var(--bw) solid var(--line);
    border-radius: var(--radius);
    padding: var(--s3) var(--s4) 10px;
    max-width: 320px;
    background: var(--paper);
  }
  .ga-gauge-top { display: flex; align-items: baseline; justify-content: space-between; gap: var(--s3); margin-bottom: 8px; }
  .ga-readout { color: var(--accent); font-variant-numeric: tabular-nums; white-space: nowrap; }
  .ga-gauge input[type=range] {
    -webkit-appearance: none; appearance: none; width: 100%; height: 20px; background: transparent; cursor: ew-resize; margin: 0;
  }
  .ga-gauge input[type=range]:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  .ga-gauge input[type=range]::-webkit-slider-runnable-track { height: 1px; background: var(--line-2); }
  .ga-gauge input[type=range]::-moz-range-track { height: 1px; background: var(--line-2); }
  .ga-gauge input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none; width: 10px; height: 18px; margin-top: -9px; border-radius: 1px;
    background: var(--paper); border: 1px solid var(--ink); box-shadow: inset 3px 0 0 -2px var(--accent);
  }
  .ga-gauge input[type=range]::-moz-range-thumb { width: 9px; height: 16px; border-radius: 1px; background: var(--paper); border: 1px solid var(--ink); }
  .ga-ticks { display: flex; justify-content: space-between; margin-top: 5px; }
  .ga-ticks span { font-family: var(--mono); font-size: 9px; color: var(--line-2); letter-spacing: .06em; }

  /* drawing motion */
  .ga-svg .shp { stroke-dasharray: 1; stroke-dashoffset: 1; fill-opacity: 0;
    animation: gadraw .8s cubic-bezier(.4,0,.3,1) forwards, gafill .5s ease forwards;
    animation-delay: var(--dl, 0s), calc(var(--dl, 0s) + .5s); }
  .ga-svg .lbl { opacity: 0; animation: gafade .5s ease forwards; animation-delay: calc(var(--dl, 0s) + .8s); }
  @keyframes gadraw { to { stroke-dashoffset: 0; } }
  @keyframes gafill { to { fill-opacity: 1; } }
  @keyframes gafade { to { opacity: 1; } }

  .ga-svg .layer { cursor: pointer; }
  .ga-svg .layer .nudge { transition: transform .45s cubic-bezier(.22,.8,.3,1); }
  .ga-svg .layer.hot .nudge { transform: translateY(-6px); }
  .ga-svg .lblg { cursor: pointer; }
  .ga-svg .lblg .lname { transition: fill .2s ease; }
  .ga-svg .lblg.hot .lname { fill: var(--ink); }
  .ga-svg .lblg.hot .lead { stroke: var(--ink); }
  .ga-svg .lblg.hot .goto { opacity: 1; }
  .ga-svg .goto { opacity: 0; transition: opacity .25s ease; }
  .ga-svg a:focus-visible { outline: none; }
  .ga-svg a:focus-visible .nudge, .ga-svg a:focus-visible .lname { outline: 2px solid var(--accent); }

  @media (max-width: 820px){
    .ga-gauge { max-width: none; }
  }
  @media (prefers-reduced-motion: reduce){
    .ga-svg .shp { animation: none; stroke-dashoffset: 0; fill-opacity: 1; }
    .ga-svg .lbl { animation: none; opacity: 1; }
    .ga-svg .layer .nudge { transition: none; }
  }
</style>

<script is:inline>
(function () {
  "use strict";
  var NS = "http://www.w3.org/2000/svg";
  var XLINK = "http://www.w3.org/1999/xlink";
  var reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

  // instrument palette
  var INK = "#14161A", MUTED = "#6B7077", LINE2 = "#C9CCD2", ACCENT = "#3656D4", TOP = "#FFFFFF";

  var CATEGORIES = [
    { id: "code",    href: "/poolside/", h: 16, name: "CODE",    sub: "apps · exhibits · systems",   count: "open the exhibit" },
    { id: "design",  href: "/logo/", h: 12, name: "DESIGN",  sub: "interfaces · identity · type", count: "open the logo" },
    { id: "writing", href: "/texts/",    h: 12, name: "WRITING", sub: "essays · series · notes",      count: "open the texts" },
    { id: "skills",  href: "/xaml-uno/", h: 10, name: "SKILLS",  sub: "the feel system · tooling",    count: "open the sheet" }
  ];

  function el(tag, attrs, parent) {
    var e = document.createElementNS(NS, tag);
    for (var k in attrs) e.setAttribute(k, attrs[k]);
    if (parent) parent.appendChild(e);
    return e;
  }
  function makeProjector(S, OX, OY) {
    return function (x, y, z) { return [(x - y) * 0.866 * S + OX, (x + y) * 0.5 * S - z * S + OY]; };
  }
  function pathFrom(pts) {
    return "M" + pts.map(function (p) { return p[0].toFixed(1) + " " + p[1].toFixed(1); }).join(" L") + " Z";
  }
  function plate(P, parent, x0, y0, zB, w, d, h) {
    var g = el("g", {}, parent);
    var zT = zB + h;
    var top = [P(x0, y0, zT), P(x0 + w, y0, zT), P(x0 + w, y0 + d, zT), P(x0, y0 + d, zT)];
    var right = [P(x0 + w, y0, zT), P(x0 + w, y0 + d, zT), P(x0 + w, y0 + d, zB), P(x0 + w, y0, zB)];
    var front = [P(x0, y0 + d, zT), P(x0 + w, y0 + d, zT), P(x0 + w, y0 + d, zB), P(x0, y0 + d, zB)];
    el("path", { d: pathFrom(front), "class": "shp", fill: "url(#gaHatchA)", stroke: INK, "stroke-width": 1.2, pathLength: 1 }, g);
    el("path", { d: pathFrom(right), "class": "shp", fill: "url(#gaHatchB)", stroke: INK, "stroke-width": 1.2, pathLength: 1 }, g);
    el("path", { d: pathFrom(top), "class": "shp", fill: TOP, stroke: INK, "stroke-width": 1.3, pathLength: 1 }, g);
    return g;
  }
  function faceGroup(P, parent, S, zTop) {
    var o = P(0, 0, zTop);
    return el("g", { transform: "matrix(" + (0.866 * S) + "," + (0.5 * S) + "," + (-0.866 * S) + "," + (0.5 * S) + "," + o[0] + "," + o[1] + ")" }, parent);
  }

  var S = 1.9, OX = 380, OY = 470;
  var P = makeProjector(S, OX, OY);
  var W = 170, D = 110;
  var svg = document.getElementById("gaSvg");
  if (!svg) return;

  var defs = el("defs", {}, svg);
  var pA = el("pattern", { id: "gaHatchA", width: 7, height: 7, patternUnits: "userSpaceOnUse", patternTransform: "rotate(45)" }, defs);
  el("rect", { width: 7, height: 7, fill: "#EDEEF1" }, pA);
  el("line", { x1: 0, y1: 0, x2: 0, y2: 7, stroke: LINE2, "stroke-width": 1 }, pA);
  var pB = el("pattern", { id: "gaHatchB", width: 9, height: 9, patternUnits: "userSpaceOnUse", patternTransform: "rotate(45)" }, defs);
  el("rect", { width: 9, height: 9, fill: "#F1F2F4" }, pB);
  el("line", { x1: 0, y1: 0, x2: 0, y2: 9, stroke: "#D5D8DD", "stroke-width": 1 }, pB);

  var zb = 0;
  CATEGORIES.forEach(function (L) { L.zB = zb; zb += L.h; });
  var totalH = zb;
  var GAPS = CATEGORIES.length - 1;

  var TEN_W = 16, TEN_H = 10;
  var tenonXs = [34, W - 34 - TEN_W];

  var dimG = el("g", { "class": "lbl", style: "--dl:1.1s" }, svg);

  CATEGORIES.forEach(function (L, i) {
    var a = el("a", { "class": "cat", href: L.href, "aria-label": L.name + " · " + L.count }, svg);
    a.setAttributeNS(XLINK, "xlink:href", L.href);
    var g = el("g", { "class": "layer", style: "--dl:" + (0.16 * i) + "s" }, a);
    var nudge = el("g", { "class": "nudge" }, g);
    L.el = g; L.link = a;

    if (i > 0) {
      tenonXs.forEach(function (tx) { plate(P, nudge, tx, D / 2 - TEN_W / 2, L.zB - TEN_H, TEN_W, TEN_W, TEN_H); });
    }
    plate(P, nudge, 0, 0, L.zB, W, D, L.h);

    var zT = L.zB + L.h;
    if (i < CATEGORIES.length - 1) {
      tenonXs.forEach(function (tx) {
        var m = [P(tx, D / 2 - TEN_W / 2, zT), P(tx + TEN_W, D / 2 - TEN_W / 2, zT),
                 P(tx + TEN_W, D / 2 + TEN_W / 2, zT), P(tx, D / 2 + TEN_W / 2, zT)];
        el("path", { d: pathFrom(m), fill: "none", stroke: MUTED, "stroke-width": 1, "stroke-dasharray": "4 3", "class": "shp", pathLength: 1 }, nudge);
      });
    }

    var f = faceGroup(P, nudge, S, zT);
    var det = el("g", { fill: "none", stroke: MUTED, "stroke-width": 0.9 }, f);
    function shp(e) { e.setAttribute("class", "shp"); e.setAttribute("pathLength", "1"); return e; }

    if (L.id === "code") {
      var indents = [22, 34, 46, 46, 34, 22], widths = [58, 74, 52, 66, 40, 30];
      indents.forEach(function (ind, k) { shp(el("line", { x1: ind, y1: 22 + k * 12, x2: ind + widths[k], y2: 22 + k * 12 }, det)); });
      shp(el("path", { d: "M136 22 h10 v68 h-10", fill: "none" }, det));
      shp(el("path", { d: "M16 22 h-2 v68 h2", fill: "none" }, det));
    } else if (L.id === "design") {
      shp(el("rect", { x: 18, y: 16, width: W - 36, height: D - 32 }, det));
      shp(el("line", { x1: 18, y1: 16, x2: W - 18, y2: D - 16, "stroke-dasharray": "5 4" }, det));
      shp(el("circle", { cx: 66, cy: 52, r: 22 }, det));
      shp(el("rect", { x: 98, y: 34, width: 38, height: 38 }, det));
    } else if (L.id === "writing") {
      shp(el("line", { x1: 22, y1: 22, x2: 84, y2: 22, "stroke-width": 1.6 }, det));
      [38, 50, 62, 74].forEach(function (yy, k) { shp(el("line", { x1: 22, y1: yy, x2: k === 3 ? 96 : W - 24, y2: yy }, det)); });
    } else if (L.id === "skills") {
      // an easing curve: the feel system as a motion path
      shp(el("path", { d: "M20 88 C60 88 78 20 148 20", fill: "none", stroke: ACCENT, "stroke-width": 1.3 }, det));
      shp(el("line", { x1: 20, y1: 20, x2: 20, y2: 88, "stroke-dasharray": "3 3" }, det));
      shp(el("line", { x1: 20, y1: 88, x2: 148, y2: 88, "stroke-dasharray": "3 3" }, det));
      shp(el("circle", { cx: 20, cy: 88, r: 3, fill: TOP }, det));
      shp(el("circle", { cx: 148, cy: 20, r: 3, fill: TOP }, det));
    }

    var mid = P(W, D * 0.45, L.zB + L.h / 2);
    L.attach = mid;
  });

  /* ---- fixed label slots + elbow leaders ---- */
  var LX = 700, SLOT0 = 150, SLOTSTEP = 116;
  CATEGORIES.forEach(function (L, i) {
    var slotY = SLOT0 + (CATEGORIES.length - 1 - i) * SLOTSTEP;
    var la = el("a", { href: L.href }, svg);
    la.setAttributeNS(XLINK, "xlink:href", L.href);
    var lg = el("g", { "class": "lbl lblg", style: "--dl:" + (0.16 * i) + "s" }, la);
    var lead = el("polyline", { points: "", fill: "none", stroke: MUTED, "stroke-width": 1, "class": "lead" }, lg);
    var dot = el("circle", { cx: L.attach[0] + 6, cy: L.attach[1], r: 2, fill: MUTED }, lg);
    var mono = "'JetBrains Mono', monospace";
    var t1 = el("text", { x: LX + 12, y: slotY - 16, "font-family": mono, "font-size": 12, fill: ACCENT, "letter-spacing": "1" }, lg);
    t1.textContent = "no.0" + (CATEGORIES.length - i);
    var t2 = el("text", { x: LX + 12, y: slotY + 4, "font-family": mono, "font-size": 17, fill: MUTED, "letter-spacing": "2", "class": "lname" }, lg);
    t2.textContent = L.name;
    var t3 = el("text", { x: LX + 12, y: slotY + 23, "font-family": mono, "font-size": 11, fill: MUTED }, lg);
    t3.textContent = L.sub;
    var t5 = el("text", { x: LX + 12, y: slotY + 42, "font-family": mono, "font-size": 10.5, fill: ACCENT, "letter-spacing": "1", "class": "goto" }, lg);
    t5.textContent = L.count + "  →";
    L.slotY = slotY; L.lead = lead; L.dot = dot; L.labelG = lg;

    function on() { lg.classList.add("hot"); L.el.classList.add("hot"); }
    function off() { lg.classList.remove("hot"); L.el.classList.remove("hot"); }
    [L.link, la].forEach(function (node) {
      node.addEventListener("mouseenter", on);
      node.addEventListener("mouseleave", off);
      node.addEventListener("focus", on, true);
      node.addEventListener("blur", off, true);
    });
  });

  /* ---- overall dimension (left) ---- */
  var DXL = 150;
  var baseGround = P(0, 0, 0);
  var dimLine = el("line", { x1: DXL, y1: 0, x2: DXL, y2: 0, stroke: MUTED, "stroke-width": 1 }, dimG);
  var extTop = el("line", { stroke: LINE2, "stroke-width": 1, "stroke-dasharray": "3 3" }, dimG);
  var extBot = el("line", { stroke: LINE2, "stroke-width": 1, "stroke-dasharray": "3 3" }, dimG);
  var tickT = el("path", { d: "", stroke: MUTED, "stroke-width": 1, fill: "none" }, dimG);
  var tickB = el("path", { d: "", stroke: MUTED, "stroke-width": 1, fill: "none" }, dimG);
  var dimTxt = el("text", { x: DXL - 12, y: 0, "font-family": "'JetBrains Mono',monospace", "font-size": 12, fill: ACCENT, "text-anchor": "end", "letter-spacing": "1" }, dimG);
  var dimTxt2 = el("text", { x: DXL - 12, y: 0, "font-family": "'JetBrains Mono',monospace", "font-size": 10, fill: MUTED, "text-anchor": "end" }, dimG);
  dimTxt2.textContent = "overall";

  /* ---- explosion control ---- */
  var slider = document.getElementById("gaSep");
  var readout = document.getElementById("gaReadout");

  function applySep(E) {
    var Ssep = E * S;
    CATEGORIES.forEach(function (L, i) {
      var dy = -(i * Ssep);
      L.el.setAttribute("transform", "translate(0," + dy.toFixed(1) + ")");
      var ax = L.attach[0] + 6, ay = L.attach[1] + dy;
      L.lead.setAttribute("points", ax.toFixed(1) + "," + ay.toFixed(1) + " " + (LX - 22) + "," + L.slotY + " " + LX + "," + L.slotY);
      L.dot.setAttribute("cy", ay.toFixed(1));
    });
    var topY = OY - (totalH + GAPS * E) * S;
    var botY = baseGround[1];
    dimLine.setAttribute("y1", topY); dimLine.setAttribute("y2", botY);
    var topPt = P(0, 0, totalH);
    extTop.setAttribute("x1", DXL); extTop.setAttribute("y1", topY);
    extTop.setAttribute("x2", topPt[0]); extTop.setAttribute("y2", topY);
    extBot.setAttribute("x1", DXL); extBot.setAttribute("y1", botY);
    extBot.setAttribute("x2", baseGround[0]); extBot.setAttribute("y2", botY);
    tickT.setAttribute("d", "M" + (DXL - 5) + " " + (topY + 5) + " L" + (DXL + 5) + " " + (topY - 5));
    tickB.setAttribute("d", "M" + (DXL - 5) + " " + (botY + 5) + " L" + (DXL + 5) + " " + (botY - 5));
    var Hval = totalH + GAPS * E;
    var midY = (topY + botY) / 2;
    dimTxt.setAttribute("y", midY - 2);
    dimTxt.textContent = "h = " + Hval;
    dimTxt2.setAttribute("y", midY + 12);
    readout.textContent = "sep " + String(E).padStart(2, "0") + " · h " + Hval;
  }

  slider.addEventListener("input", function () { applySep(+slider.value); });

  if (reduced) {
    applySep(+slider.value);
  } else {
    applySep(0);
    var target = +slider.value, t0 = null;
    setTimeout(function () {
      function step(ts) {
        if (!t0) t0 = ts;
        var p = Math.min((ts - t0) / 900, 1);
        var e = 1 - Math.pow(1 - p, 3);
        applySep(Math.round(target * e));
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }, 1200);
  }
})();
</script>
