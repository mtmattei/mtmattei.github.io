---
/* Plate — the artwork for a project, drawn rather than photographed.
   One 216 × 100 drawing per slug, used at billboard size and at thumb size. */
interface Props { slug: string; }
const { slug } = Astro.props;
---
<svg class="plate" viewBox="0 0 216 100" preserveAspectRatio="xMidYMid slice" role="img" aria-hidden="true">
  {slug === 'poolside' && (
    <g>
      <defs>
        <linearGradient id="pl-water" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#0E4C63" /><stop offset="0.55" stop-color="#12718C" /><stop offset="1" stop-color="#1FA0A8" />
        </linearGradient>
      </defs>
      <rect width="216" height="100" fill="url(#pl-water)" />
      {Array.from({ length: 13 }, (_, i) => (
        <path
          d={`M0 ${10 + i * 7} Q 36 ${4 + i * 7} 72 ${11 + i * 7} T 144 ${10 + i * 7} T 216 ${12 + i * 7}`}
          fill="none" stroke="#EAF7F6" stroke-opacity={0.1 + (i % 4) * 0.07} stroke-width={i % 3 === 0 ? 1.2 : 0.6}
        />
      ))}
      {Array.from({ length: 7 }, (_, i) => (
        <ellipse cx={18 + i * 31} cy={30 + (i % 3) * 22} rx={14 - (i % 3) * 4} ry={4 - (i % 3)} fill="none" stroke="#F6FEFD" stroke-opacity="0.22" stroke-width="0.8" />
      ))}
    </g>
  )}

  {slug === 'source-figure' && (
    <g>
      <rect width="216" height="100" fill="#14161A" />
      {Array.from({ length: 9 }, (_, r) =>
        Array.from({ length: 32 }, (_, c) => {
          const inMark = c > 8 && c < 24 && (Math.abs(c - 16) + r * 0.9) % 5 < 2.2;
          return (
            <text
              x={8 + c * 6.4} y={16 + r * 9.5}
              font-family="IBM Plex Mono, monospace" font-size="7"
              fill={inMark ? '#F6F2EE' : '#3656D4'} fill-opacity={inMark ? 0.95 : 0.34}
            >{'{}()[]=+-*/<>;.'.charAt((r * 7 + c * 3) % 15)}</text>
          );
        })
      )}
    </g>
  )}

  {slug === 'xaml-uno' && (
    <g>
      <rect width="216" height="100" fill="#1A1815" />
      {Array.from({ length: 11 }, (_, i) => (
        <line x1={0} y1={i * 10} x2={216} y2={i * 10} stroke="#F6F2EE" stroke-opacity="0.07" stroke-width="0.6" />
      ))}
      {Array.from({ length: 22 }, (_, i) => (
        <line x1={i * 10} y1={0} x2={i * 10} y2={100} stroke="#F6F2EE" stroke-opacity="0.07" stroke-width="0.6" />
      ))}
      <path d="M10 88 C 58 88 66 14 206 12" fill="none" stroke="#3656D4" stroke-width="2.4" />
      <path d="M10 88 C 58 88 66 14 206 12" fill="none" stroke="#F6F2EE" stroke-width="0.8" stroke-dasharray="3 4" />
      <circle cx="10" cy="88" r="3" fill="#F6F2EE" /><circle cx="206" cy="12" r="3" fill="#F6F2EE" />
      <text x="16" y="26" font-family="IBM Plex Mono, monospace" font-size="7" fill="#F6F2EE" fill-opacity="0.6">.22, 1, .36, 1</text>
    </g>
  )}

  {slug === 'poolside-iso' && (
    <g>
      {/* the isometric pool: the IsoBasin from the app, shader water on top */}
      <rect width="216" height="100" fill="#F2EDE3" />
      {/* thrown shadow on the deck, under the near edges */}
      <path d="M108 92 L190 51 L198 57 L112 99 L26 57 L34 51 Z" fill="#1A1815" fill-opacity="0.10" />
      {/* rim at deck level */}
      <path d="M108 11 L186 50 L108 89 L30 50 Z" fill="#E6E0D4" />
      <path d="M108 13 L182 50 L108 87 L34 50 Z" fill="#DCD5C6" />
      {/* far inner walls, exposed between rim and the lower water surface */}
      <path d="M108 13 L182 50 L174 52 L108 21 Z" fill="#0A566E" />
      <path d="M108 13 L34 50 L42 52 L108 21 Z" fill="#094B60" />
      {/* the water surface */}
      <defs>
        <linearGradient id="iso-water" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#1286A4" /><stop offset="1" stop-color="#1FA0A8" />
        </linearGradient>
        <clipPath id="iso-clip"><path d="M108 21 L174 52 L108 84 L42 52 Z" /></clipPath>
      </defs>
      <path d="M108 21 L174 52 L108 84 L42 52 Z" fill="url(#iso-water)" />
      <g clip-path="url(#iso-clip)">
        {/* the caustic web, drawn in the iso plane */}
        {Array.from({ length: 6 }, (_, i) => (
          <path
            d={`M${52 + i * 4} ${46 + i * 5 - (i % 2) * 3} q 14 ${-9 + (i % 3) * 3} 28 ${14 - (i % 2) * 4} t 28 ${13 - (i % 3) * 3} t 28 ${-8 + (i % 2) * 5}`}
            fill="none" stroke="#EAF7F6" stroke-opacity={0.16 + (i % 3) * 0.09} stroke-width={i % 3 === 0 ? 1.3 : 0.8}
            transform={`translate(${-14 * i} ${-8 * i}) rotate(${(i % 2) * 3 - 1.5} 108 52)`}
          />
        ))}
        <ellipse cx="92" cy="44" rx="13" ry="6" fill="none" stroke="#F6FEFD" stroke-opacity="0.3" stroke-width="0.9" transform="rotate(26 92 44)" />
        <ellipse cx="128" cy="58" rx="10" ry="4.5" fill="none" stroke="#F6FEFD" stroke-opacity="0.25" stroke-width="0.8" transform="rotate(26 128 58)" />
        <ellipse cx="112" cy="36" rx="7" ry="3" fill="none" stroke="#F6FEFD" stroke-opacity="0.2" stroke-width="0.7" transform="rotate(26 112 36)" />
      </g>
      {/* ladder on the near-right edge */}
      <g stroke="#F6F2EE" stroke-width="1.6" stroke-linecap="round">
        <path d="M146 62 L138 74" /><path d="M152 65 L144 77" />
        <path d="M147.5 66.5 L153.5 69.5" stroke-width="1.1" />
      </g>
    </g>
  )}

  {slug === 'poolside-app' && (
    <g>
      {/* the app's home screen, schematic — the gallery face of Poolside */}
      <rect width="216" height="100" fill="#F2EDE3" />
      <rect width="14" height="100" fill="#E9E3D6" />
      <circle cx="7" cy="34" r="2.2" fill="#0A6C88" />
      <circle cx="7" cy="48" r="2.2" fill="#93A8B0" fill-opacity="0.6" />
      <circle cx="7" cy="62" r="2.2" fill="#93A8B0" fill-opacity="0.6" />
      <rect x="22" y="10" width="46" height="6" rx="2" fill="#12333D" fill-opacity="0.85" />
      <rect x="22" y="20" width="26" height="3.4" rx="1.7" fill="#5F7B85" fill-opacity="0.5" />
      <rect x="176" y="10" width="26" height="9" rx="4.5" fill="#FFFFFF" fill-opacity="0.75" />
      <circle cx="182" cy="14.5" r="2.4" fill="#E8B25F" />
      <defs>
        <linearGradient id="pla-water" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#12718C" /><stop offset="1" stop-color="#1FA0A8" />
        </linearGradient>
      </defs>
      <rect x="22" y="30" width="112" height="60" rx="6" fill="url(#pla-water)" />
      {Array.from({ length: 5 }, (_, i) => (
        <path
          d={`M22 ${40 + i * 11} Q 50 ${35 + i * 11} 78 ${41 + i * 11} T 134 ${40 + i * 11}`}
          fill="none" stroke="#EAF7F6" stroke-opacity={0.18 + (i % 3) * 0.08} stroke-width="0.9"
        />
      ))}
      <rect x="27" y="35" width="30" height="8" rx="4" fill="#FFFFFF" fill-opacity="0.85" />
      <circle cx="32" cy="39" r="1.6" fill="#57B394" />
      <text x="27" y="84" font-family="Georgia, serif" font-size="13" fill="#FFFFFF">97</text>
      <g>
        <rect x="142" y="30" width="60" height="27" rx="4" fill="#FFFFFF" fill-opacity="0.7" />
        <rect x="147" y="36" width="18" height="3" rx="1.5" fill="#5F7B85" fill-opacity="0.6" />
        <rect x="147" y="43" width="40" height="3" rx="1.5" fill="#57B394" fill-opacity="0.45" />
        <circle cx="177" cy="44.5" r="2.6" fill="#57B394" />
        <rect x="147" y="50" width="34" height="3" rx="1.5" fill="#5F7B85" fill-opacity="0.3" />
      </g>
      <g>
        <rect x="142" y="61" width="60" height="29" rx="4" fill="#FFFFFF" fill-opacity="0.7" />
        <polyline points="148,70 158,72 166,76 174,74 182,80 190,84" fill="none" stroke="#0A6C88" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        <line x1="148" y1="68" x2="196" y2="68" stroke="#57B394" stroke-opacity="0.5" stroke-width="0.8" stroke-dasharray="2 2.5" />
      </g>
    </g>
  )}

  {slug === 'momentui' && (
    <g>
      <rect width="216" height="100" fill="#1C1511" />
      {/* fragments drifting in from the left… */}
      <g fill="#F7EFE9">
        <rect x="14" y="16" width="34" height="9" rx="2" fill-opacity="0.2" transform="rotate(-8 31 20)" />
        <rect x="26" y="44" width="22" height="22" rx="4" fill-opacity="0.14" transform="rotate(12 37 55)" />
        <rect x="12" y="76" width="42" height="7" rx="2" fill-opacity="0.24" transform="rotate(-5 33 79)" />
        <rect x="58" y="24" width="26" height="8" rx="2" fill-opacity="0.3" transform="rotate(6 71 28)" />
        <rect x="62" y="62" width="30" height="12" rx="3" fill-opacity="0.18" transform="rotate(-10 77 68)" />
      </g>
      <rect x="55" y="80" width="18" height="6" rx="2" fill="#E8896B" fill-opacity="0.85" transform="rotate(8 64 83)" />
      {/* …composing into an aligned interface on the right */}
      <g>
        <rect x="118" y="14" width="84" height="14" rx="3" fill="#F7EFE9" fill-opacity="0.9" />
        <rect x="118" y="34" width="52" height="8" rx="2" fill="#F7EFE9" fill-opacity="0.35" />
        <rect x="118" y="48" width="84" height="22" rx="4" fill="#F7EFE9" fill-opacity="0.14" />
        <rect x="118" y="76" width="40" height="10" rx="3" fill="#E8896B" />
        <rect x="164" y="76" width="38" height="10" rx="3" fill="#F7EFE9" fill-opacity="0.22" />
      </g>
    </g>
  )}

  {slug === 'unoannotation' && (
    <g>
      <rect width="216" height="100" fill="#101B15" />
      {/* the interface, as the agent cannot see it */}
      <g fill="#EAF5EE">
        <rect x="18" y="14" width="180" height="12" rx="3" fill-opacity="0.16" />
        <rect x="18" y="34" width="86" height="40" rx="4" fill-opacity="0.10" />
        <rect x="112" y="34" width="86" height="18" rx="3" fill-opacity="0.10" />
        <rect x="112" y="56" width="86" height="18" rx="3" fill-opacity="0.10" />
        <rect x="18" y="82" width="60" height="8" rx="2" fill-opacity="0.14" />
      </g>
      {/* …and the annotations that give it eyes */}
      <g fill="none" stroke="#5FC98F" stroke-width="1.4">
        <rect x="14" y="30" width="94" height="48" rx="5" />
        <rect x="108" y="52" width="94" height="26" rx="4" stroke-dasharray="4 3" stroke-opacity="0.7" />
        <path d="M61 10 v10 M56 15 h10" stroke-width="1.2" />
      </g>
      <text x="18" y="26" font-family="IBM Plex Mono, monospace" font-size="7" fill="#5FC98F">ref:a1</text>
      <text x="112" y="48" font-family="IBM Plex Mono, monospace" font-size="7" fill="#5FC98F" fill-opacity="0.7">ref:a2</text>
    </g>
  )}

  {slug === 'liquidglasslab' && (
    <g>
      <rect width="216" height="100" fill="#0C161D" />
      {Array.from({ length: 9 }, (_, i) => (
        <line x1={0} y1={10 + i * 10} x2={216} y2={10 + i * 10} stroke="#EAF4F8" stroke-opacity="0.09" stroke-width="0.7" />
      ))}
      {Array.from({ length: 17 }, (_, i) => (
        <line x1={8 + i * 12.5} y1={0} x2={8 + i * 12.5} y2={100} stroke="#EAF4F8" stroke-opacity="0.09" stroke-width="0.7" />
      ))}
      {/* the lens: the same grid, bent */}
      <clipPath id="pl-lens"><circle cx="86" cy="50" r="30" /></clipPath>
      <g clip-path="url(#pl-lens)">
        <rect x="56" y="20" width="60" height="60" fill="#10222D" />
        {Array.from({ length: 5 }, (_, i) => (
          <path d={`M56 ${30 + i * 10} q 30 ${(i - 2) * 7} 60 0`} fill="none" stroke="#EAF4F8" stroke-opacity="0.28" stroke-width="0.9" />
        ))}
        {Array.from({ length: 5 }, (_, i) => (
          <path d={`M${66 + i * 10} 20 q ${(i - 2) * 7} 30 0 60`} fill="none" stroke="#EAF4F8" stroke-opacity="0.28" stroke-width="0.9" />
        ))}
      </g>
      <circle cx="86" cy="50" r="30" fill="none" stroke="#E893B7" stroke-opacity="0.5" stroke-width="2.2" />
      <circle cx="86" cy="50" r="30" fill="none" stroke="#7FD4E8" stroke-width="1.4" />
      <circle cx="75" cy="39" r="7" fill="#EAF4F8" fill-opacity="0.14" />
      <text x="140" y="88" font-family="IBM Plex Mono, monospace" font-size="7" fill="#7FD4E8" fill-opacity="0.8">backdrop · sksl</text>
    </g>
  )}

  {(slug === 'ledger' || slug === 'design-ledger') && (
    <g>
      <rect width="216" height="100" fill="#F0EAE3" />
      {Array.from({ length: 10 }, (_, i) => (
        <g>
          <line x1={16} y1={12 + i * 9} x2={200} y2={12 + i * 9} stroke="#1A1815" stroke-opacity="0.16" stroke-width="0.7" />
          <rect x={16} y={8.5 + i * 9} width={((i * 37) % 120) + 22} height="2.4" fill="#1A1815" fill-opacity={i % 3 === 0 ? 0.72 : 0.3} />
          {i % 3 === 1 && <rect x={170} y={8.5 + i * 9} width="16" height="2.4" fill="#3656D4" />}
        </g>
      ))}
      <line x1={148} y1={6} x2={148} y2={98} stroke="#1A1815" stroke-opacity="0.2" stroke-width="0.7" />
    </g>
  )}

  {slug === 'program' && (
    <g>
      <rect width="216" height="100" fill="#14161A" />
      {Array.from({ length: 10 }, (_, i) => (
        <g>
          <text x="8" y={13 + i * 9} font-family="IBM Plex Mono, monospace" font-size="6" fill="#F6F2EE" fill-opacity="0.28">{String(i + 1).padStart(2, '0')}</text>
          <rect x={22 + (i % 3) * 8} y={8 + i * 9} width={((i * 53) % 96) + 30} height="2.6" fill="#F6F2EE" fill-opacity={i % 4 === 0 ? 0.55 : 0.22} />
          {i % 4 === 2 && <rect x={22 + (i % 3) * 8 + (((i * 53) % 96) + 36)} y={8 + i * 9} width="26" height="2.6" fill="#3656D4" />}
        </g>
      ))}
    </g>
  )}
</svg>

<style>
  .plate { display: block; width: 100%; height: 100%; }
</style>
