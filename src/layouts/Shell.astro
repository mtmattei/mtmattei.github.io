---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  crumb: string;
  description?: string;
  /* INSPECT readout: the tokens of the active view */
  tokens?: [string, string][];
  /* widen the content column (exploded exhibit views) */
  wide?: boolean;
}
const {
  title,
  crumb,
  description = 'Matt Mattei. Developer and designer in Montréal. Code, design, writing, and the toolchain behind them, measured in monochrome.',
  tokens = [],
  wide = false,
} = Astro.props;

type NavItem = { label: string; href: string; children?: NavItem[] };
type NavSub = { kicker: string; items: NavItem[] };
const NAV: { kicker: string; items?: NavItem[]; subs?: NavSub[] }[] = [
  { kicker: 'Overview', items: [{ label: 'Index', href: '/' }] },
  {
    kicker: 'Projects',
    subs: [
      { kicker: 'Code', items: [{ label: 'Poolside', href: '/poolside/' }] },
      {
        kicker: 'Design',
        items: [
          { label: 'Source / Figure', href: '/source-figure/' },
        ],
      },
      { kicker: 'Writing', items: [{ label: 'Texts', href: '/texts/' }] },
      {
        kicker: 'Skills',
        items: [
          {
            label: 'XAML / Uno',
            href: '/xaml-uno/',
            children: [
              { label: 'xaml-design-polish', href: '/skills/xaml-design-polish/' },
              { label: 'userinterface-wiki-uno', href: '/skills/userinterface-wiki-uno/' },
              { label: 'winui-xaml', href: '/skills/winui-xaml/' },
            ],
          },
          { label: 'Ledger', href: '/ledger/' },
        ],
      },
    ],
  },
  {
    kicker: 'About',
    items: [
      { label: 'Program', href: '/program/' },
      { label: 'Contact', href: '/contact/' },
    ],
  },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const h = href.replace(/\/$/, '') || '/';
  return h === '/' ? path === '/' : path === h;
};
/* an item is "lit" when it — or any nested child — is the active page */
const itemActive = (i: NavItem): boolean =>
  isActive(i.href) || (i.children?.some((c) => isActive(c.href)) ?? false);

/* breadcrumb trail derived from the nav tree; leaf is the page's crumb.
   Nested children keep the sub-level trail (projects / skills / <page>). */
let trail: string[] = [crumb];
for (const g of NAV) {
  if (g.items?.some((i) => isActive(i.href))) {
    trail = g.kicker === 'Overview' ? [crumb] : [g.kicker, crumb];
  }
  for (const s of g.subs ?? []) {
    if (s.items.some(itemActive)) trail = [g.kicker, s.kicker, crumb];
  }
}
const crumbs = trail.map((t) => t.toLowerCase());
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <meta property="og:title" content={`${title} · Matt Mattei`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="/og-card.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" href="/favicon.ico?v=4" sizes="any" />
  <link rel="icon" href="/favicon.svg?v=4" type="image/svg+xml" />
  <link rel="icon" href="/favicon-32x32.png?v=4" type="image/png" sizes="32x32" />
  <link rel="icon" href="/favicon-16x16.png?v=4" type="image/png" sizes="16x16" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=4" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#1C1B17" />
  <title>{title} · Matt Mattei</title>
</head>
<body>
<a class="skip-link" href="#main">Skip to content</a>
<div class="app">

  <!-- Brand -->
  <div class="brand">
    <a class="brand-link" href="/">
      <Logo height={26} />
      <span class="brand-name">MATT&nbsp;MATTEI</span>
    </a>
    <button class="toggle nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-pressed="false"><span class="dot"></span>MENU</button>
  </div>

  <!-- Top bar -->
  <div class="topbar">
    <div class="crumb mono">
      {crumbs.slice(0, -1).map((c) => (
        <Fragment><span class="ident-role">{c}</span><span class="sep ident-role">/</span></Fragment>
      ))}
      <span class="here">{crumbs[crumbs.length - 1]}</span>
    </div>
    <div class="controls">
      <span class="build">v0.2 · source → figure</span>
      <button class="toggle" id="gridToggle" aria-pressed="false"><span class="dot"></span>GRID</button>
      <button class="toggle" id="inspToggle" aria-pressed="false"><span class="dot"></span>INSPECT</button>
      <a class="icon-link" href="https://github.com/mtmattei" target="_blank" rel="noopener" aria-label="GitHub · mtmattei" title="github.com/mtmattei">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.63.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.36 9.36 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/></svg>
      </a>
    </div>
  </div>

  <!-- Sidebar nav -->
  <nav class="nav" id="nav" aria-label="Sections">
    {NAV.map((group) => (
      <div class:list={['nav-group', { 'nav-group-quiet': group.kicker === 'About' }]}>
        <button class="kicker fold" type="button" aria-expanded="true" data-fold={group.kicker}>
          <span class="caret" aria-hidden="true"></span>{group.kicker}
        </button>
        {group.items && (
          <div class:list={['nav-items', { 'has-active': group.items.some((i) => isActive(i.href)) }]}>
            {group.items.map((item) => (
              <a class:list={['nav-item', { 'is-active': isActive(item.href) }]} href={item.href}>
                <span class="tick"></span>{item.label}
              </a>
            ))}
          </div>
        )}
        {group.subs && (
          <div class:list={['nav-nest', { 'has-active': group.subs.some((s) => s.items.some(itemActive)) }]}>
            {group.subs.map((sub) => (
              <div class="nav-sub">
                <button class="kicker fold" type="button" aria-expanded="true" data-fold={sub.kicker}>
                  <span class="caret" aria-hidden="true"></span>{sub.kicker}
                </button>
                <div class:list={['nav-items', { 'has-active': sub.items.some(itemActive) }]}>
                  {sub.items.map((item) => (
                    <Fragment>
                      {item.children ? (
                        <div class="nav-parent">
                          <button class="fold fold-item" type="button" aria-expanded="true" data-fold={item.label} aria-label={`Toggle ${item.label}`}>
                            <span class="caret" aria-hidden="true"></span>
                          </button>
                          <a class:list={['nav-item', { 'is-active': isActive(item.href), 'has-child-active': !isActive(item.href) && itemActive(item) }]} href={item.href}>
                            <span class="tick"></span>{item.label}
                          </a>
                        </div>
                      ) : (
                        <a class:list={['nav-item', { 'is-active': isActive(item.href) }]} href={item.href}>
                          <span class="tick"></span>{item.label}
                        </a>
                      )}
                      {item.children && (
                        <div class:list={['nav-children', { 'has-active': item.children.some((c) => isActive(c.href)) }]}>
                          {item.children.map((c) => (
                            <a class:list={['nav-item', 'nav-child', { 'is-active': isActive(c.href) }]} href={c.href}>
                              <span class="tick"></span>{c.label}
                            </a>
                          ))}
                        </div>
                      )}
                    </Fragment>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>

  <!-- Main -->
  <main class="main" id="main" tabindex="-1">
    <div class:list={['main-inner', { wide }]}>
      <slot />
    </div>
  </main>
</div>

<!-- Inspector -->
<aside class="inspector" id="inspector" aria-label="Token inspector" aria-hidden="true">
  <div class="insp-head">
    <span class="kicker">Inspector</span>
    <button class="insp-close" id="inspClose" aria-label="Close inspector">✕</button>
  </div>
  <div class="insp-body">
    <div class="grp">
      <span class="kicker">{crumb}</span>
      {tokens.map(([k, v]) => (
        <div class="tok"><span class="k">{k}</span><span class="v">{v}</span></div>
      ))}
    </div>
  </div>
</aside>

<!-- Grid / measurement overlay -->
<div class="overlay" id="overlay" aria-hidden="true">
  <div class="col-guide"></div>
  <div class="dim">content · 960px · margin 48px · baseline 8px</div>
</div>

<script is:inline>
  // GRID and INSPECT survive page navigation via sessionStorage (MPA).
  const overlay = document.getElementById('overlay');
  const gridToggle = document.getElementById('gridToggle');
  const inspector = document.getElementById('inspector');
  const inspToggle = document.getElementById('inspToggle');
  const nav = document.getElementById('nav');

  function setGrid(on) {
    gridToggle.setAttribute('aria-pressed', String(on));
    overlay.classList.toggle('on', on);
    sessionStorage.setItem('mm.grid', on ? '1' : '0');
  }
  function setInsp(on) {
    inspToggle.setAttribute('aria-pressed', String(on));
    inspector.classList.toggle('open', on);
    inspector.setAttribute('aria-hidden', String(!on));
    sessionStorage.setItem('mm.inspect', on ? '1' : '0');
  }

  gridToggle.addEventListener('click', () => setGrid(gridToggle.getAttribute('aria-pressed') !== 'true'));
  inspToggle.addEventListener('click', () => setInsp(inspToggle.getAttribute('aria-pressed') !== 'true'));
  document.getElementById('inspClose').addEventListener('click', () => setInsp(false));

  document.getElementById('navToggle').addEventListener('click', (e) => {
    const t = e.currentTarget;
    const open = t.getAttribute('aria-pressed') === 'true';
    t.setAttribute('aria-pressed', String(!open));
    nav.classList.toggle('open', !open);
  });

  if (sessionStorage.getItem('mm.grid') === '1') setGrid(true);
  if (sessionStorage.getItem('mm.inspect') === '1') setInsp(true);

  // IDE-style folding: carets collapse categories; folds persist across pages.
  const FOLD_KEY = 'mm.folds';
  const readFolds = () => {
    try { return new Set(JSON.parse(localStorage.getItem(FOLD_KEY) || '[]')); } catch (e) { return new Set(); }
  };
  const folds = readFolds();
  const foldTarget = (btn) =>
    btn.classList.contains('fold-item')
      ? (btn.closest('.nav-parent') || {}).nextElementSibling
      : btn.parentElement;
  function applyFold(btn, folded) {
    const t = foldTarget(btn);
    btn.setAttribute('aria-expanded', String(!folded));
    if (t && t.classList) t.classList.toggle('folded', folded);
  }
  nav.querySelectorAll('.fold').forEach((btn) => {
    const key = btn.getAttribute('data-fold');
    if (folds.has(key)) applyFold(btn, true);
    btn.addEventListener('click', () => {
      const folded = btn.getAttribute('aria-expanded') === 'true';
      applyFold(btn, folded);
      if (folded) folds.add(key); else folds.delete(key);
      try { localStorage.setItem(FOLD_KEY, JSON.stringify([...folds])); } catch (e) {}
    });
  });
  // keep the current page visible: transiently expand its collapsed ancestors
  const active = nav.querySelector('.nav-item.is-active');
  if (active) {
    const kids = active.closest('.nav-children');
    const parentCaret = kids && kids.previousElementSibling && kids.previousElementSibling.querySelector('.fold-item');
    const subCaret = (active.closest('.nav-sub') || {}).querySelector && active.closest('.nav-sub').querySelector(':scope > .kicker.fold');
    const grpCaret = (active.closest('.nav-group') || {}).querySelector && active.closest('.nav-group').querySelector(':scope > .kicker.fold');
    [parentCaret, subCaret, grpCaret].forEach((b) => { if (b) applyFold(b, false); });
  }
</script>
</body>
</html>
